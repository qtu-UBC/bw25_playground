      <elementaryExchange id="ce8569e1-3763-5eb1-a69c-df328b4a3416" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="003926-62-3" amount="0.00781809194954007" elementaryExchangeId="1272f029-5d77-4c3d-9a26-6e989180f269" formula="C2H2ClO2Na">
        <name xml:lang="en">Sodium chloroacetate</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated losses, based on the boiling point of a chemical, to water or to air. In addition, unreacted chemicals are assumed to go to wastewater treatment, which has a conversion rate in biological treatment of 95% of carbon into carbon dioxide. The remaining 5% are released as emissions to water.</comment>
        <uncertainty>
          <lognormal meanValue="0.00781809194954007" mu="-4.851314750419336" variance="0.0006" varianceWithPedigreeUncertainty="0.004"/>
          <pedigreeMatrix reliability="3" completeness="3" temporalCorrelation="2" geographicalCorrelation="1" furtherTechnologyCorrelation="2"/>
        </uncertainty>
