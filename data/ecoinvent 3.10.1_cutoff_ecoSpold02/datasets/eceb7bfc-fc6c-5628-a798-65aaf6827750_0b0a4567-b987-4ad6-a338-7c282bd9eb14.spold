      <elementaryExchange id="8e3ab551-422c-5436-ab1f-6339ac4f39eb" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" amount="0.010505019" elementaryExchangeId="70d467b6-115e-43c5-add2-441de9411348">
        <name xml:lang="en">BOD5, Biological Oxygen Demand</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">The values for COD, BOD, TOC, and DOC used in this inventory are calculated from the amount of methanol in the treated waste water assuming a carbon conversion of 96% for COD. For the calculation of the values for BOD and DOC the worst case scenario BOD = COD and TOC = DOC is used.</comment>
        <uncertainty>
          <lognormal meanValue="0.010505019" mu="-4.555902136024267" variance="0.04" varianceWithPedigreeUncertainty="0.218"/>
          <pedigreeMatrix reliability="4" completeness="5" temporalCorrelation="5" geographicalCorrelation="5" furtherTechnologyCorrelation="5"/>
          <comment xml:lang="en">Estimation</comment>
        </uncertainty>
        <synonym xml:lang="en">bod5</synonym>
        <synonym xml:lang="en">bod</synonym>
        <synonym xml:lang="en">biological oxygen demand</synonym>
