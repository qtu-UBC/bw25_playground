      <elementaryExchange id="0d4279c3-e792-5b6a-8dac-327b6e1ee40d" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" amount="0.004140742" elementaryExchangeId="f65558fb-61a1-4e48-b4f2-60d62f14b085">
        <name xml:lang="en">TOC, Total Organic Carbon</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">The values for COD, BOD, TOC, and DOC used in this inventory are calculated from the amount of methanol in the treated waste water assuming a carbon conversion of 96% for COD. For the calculation of the values for BOD and DOC the worst case scenario BOD = COD and TOC = DOC is used.</comment>
        <uncertainty>
          <lognormal meanValue="0.004140742" mu="-5.4868802801510235" variance="0.04" varianceWithPedigreeUncertainty="0.218"/>
          <pedigreeMatrix reliability="4" completeness="5" temporalCorrelation="5" geographicalCorrelation="5" furtherTechnologyCorrelation="5"/>
          <comment xml:lang="en">Estimation</comment>
        </uncertainty>
        <synonym xml:lang="en">TOC</synonym>
        <synonym xml:lang="en">total organic carbon</synonym>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
