      <elementaryExchange id="80e447c4-e971-568b-be9f-49ca14104e61" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="016065-83-1" amount="1.00448491438537E-05" elementaryExchangeId="e34d3da4-a3d5-41be-84b5-458afe32c990" formula="Cr+3">
