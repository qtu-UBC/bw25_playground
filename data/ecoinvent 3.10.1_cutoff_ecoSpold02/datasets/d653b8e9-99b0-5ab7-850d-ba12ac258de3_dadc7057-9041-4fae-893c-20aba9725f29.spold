      <elementaryExchange id="dd832b73-9399-5042-a88c-8d81bce951e8" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" amount="3.42255812386423E-06" elementaryExchangeId="6d9550e2-e670-44c1-bad8-c0c4975ffca7">
