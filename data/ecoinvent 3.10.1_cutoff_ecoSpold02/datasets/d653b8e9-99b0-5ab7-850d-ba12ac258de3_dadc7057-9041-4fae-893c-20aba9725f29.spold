      <intermediateExchange id="7cbd0757-a207-5d70-9b61-3d10ef7c5083" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="002122-46-5" amount="6.37177948102318E-08" intermediateExchangeId="9f2fdfd0-e173-47e9-812f-2bee762d9d39" activityLinkId="9747ad8f-0713-5bef-887a-5e98970eae4a">
