      <elementaryExchange id="b9a61736-3f22-526c-92a0-b3582bd0e07d" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="016065-83-1" amount="3.85570216925967E-07" elementaryExchangeId="1c87de06-e58f-4684-a54c-d29f1a251a87" formula="Cr+3">
