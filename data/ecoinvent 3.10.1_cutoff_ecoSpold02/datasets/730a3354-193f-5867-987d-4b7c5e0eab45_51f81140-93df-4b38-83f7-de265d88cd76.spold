      <intermediateExchange id="e693b893-ef99-5428-b476-cdc1db2994aa" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" amount="-5.582444451470342E-08" intermediateExchangeId="e8a51ec1-60cb-4ead-a948-ad1142c61918" activityLinkId="20e699d5-3a06-5477-b776-c430f279abcd" productionVolumeMathematicalRelation="RP_PV*BP_wastewater_average/ABS(RP)">
        <name xml:lang="en">wastewater, average</name>
        <unitName xml:lang="en">m3</unitName>
        <comment xml:lang="en">Calculated based on literature data published by the GENDORF Chemical Park. The factory produced an average of 2462760 tonnes of chemical substances (including intermediates) per year in the years 2015-2019. The average ouput of wastewater going to an external wastewater treatment plant in the years 2015-2019 was 5608 m3 per year. This equals 0.000002277 m3/kg chemical produced.

References:
Chemiepark GENDORF, Umwelterklärung 2016, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit
Chemiepark GENDORF, Umwelterklärung 2017, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit
Chemiepark GENDORF, Umwelterklärung 2020, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit</comment>
        <uncertainty>
          <lognormal meanValue="5.582444451470342E-08" mu="-16.70105398974523" variance="0.0006" varianceWithPedigreeUncertainty="0.0438"/>
