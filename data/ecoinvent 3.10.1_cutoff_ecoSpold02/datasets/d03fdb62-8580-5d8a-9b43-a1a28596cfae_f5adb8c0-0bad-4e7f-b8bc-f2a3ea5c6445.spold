        <name xml:lang="en">BOD5, Biological Oxygen Demand</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value from the water emissions. The values for COD, BOD, TOC and DOC used in this inventory are calculated from the amount of dimethyl amine in the treated waste water assuming a carbon conversion of 96% for COD. For the calculation of the values for BOD and DOC the worst case scenario BOD = COD and TOC = DOC was used.</comment>
        <uncertainty>
          <lognormal meanValue="0.00722" mu="-4.930900326077402" variance="0.01" varianceWithPedigreeUncertainty="0.188"/>
          <pedigreeMatrix reliability="4" completeness="5" temporalCorrelation="5" geographicalCorrelation="5" furtherTechnologyCorrelation="5"/>
          <comment xml:lang="en">Calculated from the water emissions</comment>
        </uncertainty>
