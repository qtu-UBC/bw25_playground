  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="10" id="776469fa-69cd-5ffe-b3cb-897d1bbb03f0" activityNameId="e20cd6ec-bd1b-4558-902d-38614f76e85a" activityNameContextId="de659012-50c4-4e96-b54a-fc781bf987ab" parentActivityId="8dd23727-bc00-4970-a81e-a3dabfb13922" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market group for irrigation</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of markets that deliver 'irrigation', in geographies contained within the geography of this dataset.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'irrigation',  to the consumers of this product within the geography of Global.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset is a market group. Market groups represent a 'market of markets'. Their purpose is to group a set of markets into larger, geographically relevant datasets.</text>
          <text xml:lang="en" index="1">Market groups are created for convenience and ease of use. They only group other markets and/or market groups contained within their geography.</text>
          <text xml:lang="en" index="2">Losses and relevant exchanges (transport, transport infrastructure, etc.) are not included in this dataset. They are present in the contained markets.  </text>
          <text xml:lang="en" index="3">This is the market group for 'irrigation', in the Global geography.</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
