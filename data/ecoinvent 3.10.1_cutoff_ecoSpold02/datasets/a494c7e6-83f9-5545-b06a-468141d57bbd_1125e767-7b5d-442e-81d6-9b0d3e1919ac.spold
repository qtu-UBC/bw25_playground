      <parameter parameterId="3008d76c-a2ab-427f-9e20-3d89075b3ee9" amount="627500000.0" variableName="annualFuelConsumptionm3" mathematicalRelation="2.51E+09/4&#13;&#10;&#13;&#10;" isCalculatedAmount="true" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5">
        <name xml:lang="en">annual fuel consumption in m3</name>
        <unitName xml:lang="en">m3</unitName>
        <uncertainty>
          <lognormal meanValue="627500000.0" mu="20.25" variance="0.0006" varianceWithPedigreeUncertainty="0.0012"/>
          <pedigreeMatrix reliability="2" completeness="1" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
          <comment xml:lang="en">Variance from default value table.
DQP based on the quality of the data (primary data from Quebec gouvernment)</comment>
        </uncertainty>
        <comment xml:lang="en">Data on fuel consumption of industrial sectors provided by the MDDEP (Quebec Ministry of Sustainable Development, Environment, Wildlife and Parks).
Average of the period 2005-2009
Heat provided by cogen units contributing to the market has been subtracted in older versions. However, the PV is of the cogen units is now 0 and can thus be ignored.
The total has been split equally for the four natural gas technologies.</comment>
      </parameter>
    </flowData>
    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Literature, manufacturers; CO and NOx emissions from (SVGW 2002), sample size (number of selected devices for which emission values are given in SVGW list): CO 107 , NOx 107 .</samplingProcedure>
        <extrapolations xml:lang="en">see Geography This dataset has been extrapolated from the corresponding global dataset, which was itself extrapolated from a dataset covering the geography RER. The uncertainty has been adjusted accordingly.</extrapolations>
      </representativeness>
