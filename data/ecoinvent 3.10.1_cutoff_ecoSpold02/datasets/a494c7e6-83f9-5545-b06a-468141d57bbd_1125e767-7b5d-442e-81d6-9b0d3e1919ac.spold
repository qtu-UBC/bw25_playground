<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="a494c7e6-83f9-5545-b06a-468141d57bbd" activityNameId="67be614b-e8ef-4e1d-974c-1a86636f8d43" parentActivityId="9b5e2cf8-79ee-4828-a716-3f700dce990f" inheritanceDepth="-1" type="1" energyValues="1">
        <activityName xml:lang="en">heat production, natural gas, at boiler condensing modulating &gt;100kW</activityName>
        <includedActivitiesStart xml:lang="en">Activity starts with the combustion of the fuel.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with 1MJ of heat produced by the furnace. 
This dataset includes:
 
-fuel inputs;
-emissions due to combustion of fuel;
-inputs needed for combustion (electricity);
-by-products of combustion
-infrastructures</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of heat from natural gas at boiler condensing modulating &gt;100kW in Quebec.This is an adaptation for Quebec from the corresponding  global dataset. Only time period, annual production volume and heating value have been modified. Uncertainties have been adjusted accordingly.</text>
          <text xml:lang="en" index="1"></text>
          <text xml:lang="en" index="2">NOx and CO emissions derived from measurements under controlled conditions; no adjustment to real operation made due to lack of information. Other emission data from different references.</text>
        </generalComment>
        <tag>Recontextualization</tag>
      </activity>
      <classification classificationId="c65efce2-2d7a-4bd7-8b81-435287e9c801">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">natural gas/heating systems</classificationValue>
      </classification>
      <classification classificationId="be3540ee-592f-46fd-bd68-c362a3bbccc6">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3530:Steam and air conditioning supply</classificationValue>
      </classification>
      <geography geographyId="868a66d1-7428-4ba2-9125-253b07afc119">
        <shortname xml:lang="en">CA-QC</shortname>
        <comment>
          <text xml:lang="en" index="0">Quebec dataset based on Global dataset, which was itself based on european and swiss conditions. Uncertainty has been modified accordingly</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Models on european market. Uncertainty has been modified accordingly</text>
        </comment>
      </technology>
      <timePeriod startDate="2000-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Based on GLO dataset from 2000. It is considered valid until 2015. Uncertainty has been modified accordingly. </text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
