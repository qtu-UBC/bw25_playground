      <intermediateExchange id="0177a444-2c1c-5c9b-a2f3-799f4f197c90" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="007726-95-6" amount="1.85122747033997" intermediateExchangeId="c16db903-a356-4c17-9775-1ce1c4aa4e0b" activityLinkId="37af98cf-3ffe-54cd-b1d1-ecdc21d4f7a3">
