<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="1b9f2e9e-e6d0-5544-9971-3a24cd002d50" activityNameId="8a5ed080-9837-41c6-bb8c-b6d3a901dbd4" parentActivityId="4caf4699-f053-41ea-8b3a-daad10f2f15f" inheritanceDepth="-1" type="1" datasetIcon="https://db3.ecoinvent.org/images/3882ea81-1510-459d-ad01-f7b96c9753ba">
        <activityName xml:lang="en">fish canning plant construction and maintenance</activityName>
        <includedActivitiesStart xml:lang="en">From construction of the plant, through maintenance.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">End of life treatment of the plant</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">The activity represents the construction and maintenance along its lifetime of a fish canning (including fish pre-processing) plant, expressed as the installed capacity required to process 1000 kg of raw material. The life cycle inventories were produced based on a sample of 1 Peruvian plant (processing capacity: 461 t/y), 1 Ecuadorian plant (61 000 t/y) and data from other industry representatives. This dataset may be adapted to other global production sites.</text>
          <text xml:lang="en" index="1">System boundaries of fish processing plants and relations between activities</text>
          <imageUrl index="2">https://db3.ecoinvent.org/images/b933f84e-878a-413c-808d-439e6e21c9f1</imageUrl>
        </generalComment>
      </activity>
      <classification classificationId="d1a5808c-6d4a-4d8c-a748-b9fef65b7ed1">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">4290:Construction of other civil engineering projects</classificationValue>
      </classification>
      <geography geographyId="09db3260-7e2a-11de-9820-0019e336be3a">
        <shortname xml:lang="en">RLA</shortname>
        <comment>
          <text xml:lang="en" index="0">Representative of Peru and Ecuador. In Peru, as of 2017 there were 71 active fish canning plants, with an aggregated processing capacity of 545 000 t/y. In Ecuador, as of 2014 there were 27 active tuna canning plants, with an aggregated processing capacity of 671 400 t/y.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Construction and maintenance activities of Peruvian and Ecuadorian fish canning plants, per t of processing capacity. Plants have a lifespan of 40 years.</text>
          <text xml:lang="en" index="1">Process diagram of large fish canning</text>
          <imageUrl index="2">https://db3.ecoinvent.org/images/b812ba67-ea18-4027-a9fd-f5b02b98cc6e</imageUrl>
          <text xml:lang="en" index="3">Process diagram of small fish canning</text>
          <imageUrl index="4">https://db3.ecoinvent.org/images/6a1376fb-029a-40c4-bf7c-454be0be11c8</imageUrl>
        </comment>
      </technology>
      <timePeriod startDate="2011-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Production figures represent the period 2012-2014. Valid as of 2017.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
        <comment xml:lang="en">Fish caninng in Peru, a large global producer of canned fish. Fish caninng in Ecuador, the second largest global tuna processor after Thailand. </comment>
      </macroEconomicScenario>
    </activityDescription>
    <flowData>
