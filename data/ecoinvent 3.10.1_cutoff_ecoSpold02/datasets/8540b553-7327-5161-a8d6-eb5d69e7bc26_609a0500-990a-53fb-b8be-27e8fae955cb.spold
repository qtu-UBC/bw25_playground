<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="8540b553-7327-5161-a8d6-eb5d69e7bc26" activityNameId="e7ba637b-8c15-51b0-867d-95ed6ae2f6d4" parentActivityId="f7bd9a0a-af34-53db-ac0e-b1e4bfc1f55c" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">harvesting, by sweet corn picker</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts from the agricultural field foreseen to be processed.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the delivery of harvesting by combined harvester. The dataset includes the diesel fuel consumption and the amount of agricultural machinery and of the shed attributed to harvesting. It was also taken into consideration the amount of emissions to the air from combustion and the emission to the soil from tyre abrasion during the work process. The following activities were considered part of the work process: preliminary work at the farm, such as attaching the adequate machine to the tractor; driving to field (with an assumed distance of 1 km); field work (for a parcel of land of 1 ha surface); driving to farm and concluding work, like uncoupling the machine. The overlapping during the field work is considered.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset models the service of harvesting sweet corn picker. The working width is 4.5m. The functional unit (FU) is one ha harvested. The operation time is 1.3 h/FU. </text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is extrapolated from the geography of Switzerland. Data quality indicators are adjusted accordingly.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Fuel consumption and emissions per kg diesel have been extrapolated to the US, but others inputs were taken from the original values.</text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
