    <activityDescription>
      <activity specialActivityType="0" id="9a7946d9-e047-53da-8d3d-6a20752ff180" activityNameId="be42dfa6-5575-47c5-ad8f-885c7a4e1af0" parentActivityId="0ca01b9a-819e-577a-a641-3acee4c26453" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">electricity, high voltage, import from PY</activityName>
        <includedActivitiesStart xml:lang="en">This activity represents the point of 'handing over' the electricity from one country to the other at the border.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This dataset doesn't include any electricity losses or transmission infrastructure as these are accounted for in the market datasets.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the imported electricity from PY to BR. The import includes all electricity imports, independently whether used within the importing country, or re-exported. For a discussion of different ways of modeling electricity trade in LCI, please refer to (Itten &amp; Frischknecht 2012).</text>
        </generalComment>
      </activity>
      <classification classificationId="4c3b7870-d05d-41cf-9a2f-d901c183b0d8">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3510:Electric power generation, transmission and distribution</classificationValue>
      </classification>
      <geography geographyId="7e6d7407-6a88-50d1-8f56-eb53f1c12102">
        <shortname xml:lang="en">BR-South-eastern/Mid-western grid</shortname>
      </geography>
