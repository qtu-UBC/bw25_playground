<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="d4821237-b8f8-5768-95c6-7b4e9a716229" activityNameId="6700efd6-768e-476c-95ba-2d070fd322a8" parentActivityId="d4355d56-723c-56ba-87f1-1f45fa197d58" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">electricity, high voltage, import from BR-North-eastern grid</activityName>
        <includedActivitiesStart xml:lang="en">This activity represents the point of 'handing over' the electricity from one electricity grid to the other at the border.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This dataset doesn't include any electricity losses or transmission infrastructure as these are accounted for in the market datasets.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the amount of imported electricity from the Brazilian Southern electricity grid to the Brazilian South-eastern electricity grid. For a discussion of different ways of modeling electricity trade in LCI, please refer to Itten et al. 2014. Itten R., Frischknecht R. and Stucki M. (2014) Life Cycle Inventories of Electricity Mixes and Grid. Version 1.3 Report issued on behalf of Paul Scherrer Institut (PSI). treeze Ltd., Uster, Switzerland, retrieved from: www.lc-inventories.ch</text>
        </generalComment>
      </activity>
      <classification classificationId="4c3b7870-d05d-41cf-9a2f-d901c183b0d8">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3510:Electric power generation, transmission and distribution</classificationValue>
      </classification>
      <geography geographyId="7e6d7407-6a88-50d1-8f56-eb53f1c12102">
        <shortname xml:lang="en">BR-South-eastern/Mid-western grid</shortname>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
