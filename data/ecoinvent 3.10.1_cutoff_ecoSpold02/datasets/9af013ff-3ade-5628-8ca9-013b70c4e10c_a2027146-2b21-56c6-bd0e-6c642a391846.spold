      <activity specialActivityType="1" id="9af013ff-3ade-5628-8ca9-013b70c4e10c" activityNameId="5c85eb6d-bd68-5d16-82c6-2adb640c2889" parentActivityId="07cf92b1-210d-53d6-b512-4159af3397bc" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for tillage, disking</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts with the service generation.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the service supplied to its consumers. Transport or losses are considered irrelevant for this product.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant. </text>
          <text xml:lang="en" index="1">This is the market for 'tillage, disking' in the Global geography.</text>
          <text xml:lang="en" index="2">This market contains no transport or losses, as they are irrelevant for the delivered product.</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
      </classification>
