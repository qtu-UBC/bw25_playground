<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="ade121e8-178e-51c5-9675-4aece1ae6422" activityNameId="179043e7-b848-40c1-87c9-749d24d5154d" parentActivityId="b61c2d27-8876-469a-9ead-20452e5a5b71" inheritanceDepth="-1" type="1" datasetIcon="https://db3.ecoinvent.org/images/3882ea81-1510-459d-ad01-f7b96c9753ba">
        <activityName xml:lang="en">treatment of used trawler, steel</activityName>
        <includedActivitiesStart xml:lang="en">Treatment of used vessel (recycling)</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">End of life (decommissioning). Excludes engines and motors. Excludes energy for dismantling.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the end of life of steel trawlers, per 1000 kg of light ship weight, based on data from Peru (2004-3013), corresponding to 9 vessels (from a fleet of 54) for which data was avilable with different levels of detail. Specific data for specific inventory items may be based on sub-samples for which detailed data was available. Vessel dimensions: 34 - 275 m3 (16 - 34 m length).</text>
          <text xml:lang="en" index="1">System boundaries and relation between activities</text>
          <imageUrl index="2">https://db3.ecoinvent.org/images/85e3ba5c-106b-4a80-8abb-da911233fc2f</imageUrl>
        </generalComment>
      </activity>
      <classification classificationId="2fc70895-91b4-48a7-a362-8b22623ba3a4">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0311:Marine fishing</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">Data from Peru, extrapolated to global (GLO)</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Peru features various shipyards and relevant ship-building and ship-retrofitting expertise.</text>
        </comment>
      </technology>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
        <comment xml:lang="en">Peru is one of the countries exploiting EPO demersal fish. Peruvian vessels are of national construction. Peruvian steel trawlers end of life treatment represent global technologies/techniques</comment>
      </macroEconomicScenario>
    </activityDescription>
    <flowData>
      <intermediateExchange id="0acc7aca-0660-52ef-93ec-ef9c2cafa56f" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="LSW" amount="-1.0" isCalculatedAmount="true" mathematicalRelation="-1*(iron+copper+nylon+paint+rubber)" sourceId="d73f1cee-3c85-47cc-bdca-49f75b528787" sourceYear="2017" sourceFirstAuthor="Angel Avadí" intermediateExchangeId="199596a7-3977-4402-8c43-7e3aafa1b205" productionVolumeAmount="0.997077" productionVolumeVariableName="prod_vol" productionVolumeMathematicalRelation="">
        <name xml:lang="en">used trawler, steel</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">EOL of a trawler, per 1000 kg of light ship weight (LSW), after 35 years lifetime. Regressions based on mainly primary data were created to relate the weight of each inventory item to a purse seiner's LSW, adjusted for trawler's gear. The list of inventory items (granularity) contribute &gt;95% of environmental impacts, as described in the reference publication.</comment>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.011262405" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
