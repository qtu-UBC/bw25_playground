      <intermediateExchange id="a0d0e1e0-d9eb-559c-b40b-51c5d692a5b4" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="damaged_tiles" amount="-0.0416972777634374" isCalculatedAmount="true" mathematicalRelation="(250*0.84)/5036.3" intermediateExchangeId="1e16f9f6-0e0f-4cf0-ac68-a88372ee72de" activityLinkId="0bca4e96-52f9-5dde-8f5f-df8e7af42336" productionVolumeMathematicalRelation="damaged_tiles/clay_roof_tile*clay_roof_tile_PV">
        <name xml:lang="en">damaged clay material</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value. Multiplying the number of damaged bricks by the roof tile mass (250*0.84 kg). This value is divided by the kg of roof tiles produced per firing process, to obtain the kg of damaged bricks per kg of clay roof tile. About 250 roof tiles are damaged in the oven, for each firing process, as informed by the owner of the factory is considered.</comment>
        <uncertainty>
