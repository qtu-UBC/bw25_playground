    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce" percent="70.0">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Data gathered in a modern clay roof tile factory through a process assessment in a technical visit. Azuay is one of the main producers of clay tile and the production process is similar in Ecuador, according to literature.Land occupation exchange is used as an estimate of infrastructure. Machinery use is accounted for through their fuel / electricity consumption. </samplingProcedure>
        <extrapolations xml:lang="en">No extrapolation was applied.</extrapolations>
      </representativeness>
