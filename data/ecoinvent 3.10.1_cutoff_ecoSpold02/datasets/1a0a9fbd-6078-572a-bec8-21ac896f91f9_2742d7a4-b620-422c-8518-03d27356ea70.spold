<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="1a0a9fbd-6078-572a-bec8-21ac896f91f9" activityNameId="7a03a5ce-0b6c-5daa-af67-0a23f3fc3481" parentActivityId="97f418c5-bd90-59dc-8aea-e922d14f80a7" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">clay roof tile production</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts with the reception of raw materials at the clay roof tile production site.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This dataset ends with the storage of the produced tiles. It includes the reception of raw materials, dosing, mixing, forming, and cutting, drying, firing, cooling and storage. The dataset does not include the packaging.
</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset describes the production of modern clay roof tiles in the area of San José de Balzay in Ecuador. The dataset represents the production of 1 kg of tile, with the following characteristics: average weight of 0.84 kg and average dimensions of (31 x 17 x 6 x 0.82) cm (length x width x curvature arrow x thickness). Data was obtained from measurements and information provided in the factory visited in June 2022 ("El Artesano Fábrica de Tejas"). Some data was calculated using literature values. This dataset was developed by Estefania Barros, Kristi Padrón, Jonnathan Aguirre and Juan Sebastian Martines, under the supervision of Prof. Dolores Sucozhañay and Prof. Paul Vanegas, from the Inclusive Circular Economy and Sustainable Development Research Group of the University of Cuenca (ECI) in the frame of the CEELA (Strengthening capacities for energy efficiency in buildings in Latin America) project with the support of the Swiss Agency for Development and Cooperation (SDC).</text>
          <text xml:lang="en" index="1">The dataset includes the whole manufacturing process of the clay roof tile. It does not include solid waste from containers and packaging. </text>
        </generalComment>
        <tag>ConvertedDataset</tag>
      </activity>
      <classification classificationId="a5071d0a-6e4e-4fb6-a98b-940902b9a3c9">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2392:Manufacture of clay building materials</classificationValue>
      </classification>
      <geography geographyId="0d0e72a0-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">EC</shortname>
        <comment>
          <text xml:lang="en" index="0">Data was obtained in a factory of modern clay roof tile located in San José de Balzay and Racar, Cuenca, Ecuador. </text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Current production technology. This dataset corresponds to manufacturing of a clay roof tile factory, which incorporates machinery in their processes. The manufacturing process includes the reception of raw materials, dosing, mixing, forming by extrusion, drying, firing of wood, cooling and storage of tiles. The process begins by the mixing of raw materials. The mix is deposited in a mill, then moved to an extruder formed by a mixer and a matrix. </text>
        </comment>
      </technology>
      <timePeriod startDate="2022-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The time period is from 2022 (year of data collection) to 2023 (year of dataset compilation).</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
