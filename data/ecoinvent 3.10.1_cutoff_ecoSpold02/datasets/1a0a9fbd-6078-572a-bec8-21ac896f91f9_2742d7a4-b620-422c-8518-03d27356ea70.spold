      <intermediateExchange id="ef185e9f-257c-54d3-abae-b3d6c761bd6a" unitId="980b811e-3905-4797-82a5-173f5568bc7e" amount="0.37653" isCalculatedAmount="true" mathematicalRelation="0.0105*35.86" intermediateExchangeId="b0f4c2fb-5081-474a-8ffa-1457da8345db" activityLinkId="861c6081-904d-5f6c-91a1-715031fd2dfa">
        <name xml:lang="en">diesel, burned in building machine</name>
        <unitName xml:lang="en">MJ</unitName>
        <comment xml:lang="en">Calculated value. Multiplying the volume of diesel per kg of brick (0.0105 L/kg) by the heating value of diesel (35.86 MJ/L). Diesel is used in the extruder machine. </comment>
