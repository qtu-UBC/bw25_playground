      <intermediateExchange id="98dd32ae-163c-5ef7-9f11-a4268de9af27" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="wood_fuel" amount="0.54603578023549" isCalculatedAmount="true" mathematicalRelation="(110*25)/5036.3" intermediateExchangeId="7fe99768-d571-4bc2-a272-7df585bd0d48" activityLinkId="bd2a3b3f-1d76-5d82-80c1-70d3ff13a576">
        <name xml:lang="en">wood chips, wet, measured as dry mass</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value. The value represents the amount of used (old) pallets that are used as fuel in the firing process for the production of 1 kg of rustic clay roof tiles as informed by the owner of the factory. Wood chips are used as proxy for the used pallets used for the firing process. The number of pallets used per firing process is 110 units. Each unit weights 25kg. This is then divived by the kg of clay roof tiles per firing process (5036.3 kg).</comment>
        <uncertainty>
          <lognormal meanValue="0.54603578023549" mu="-0.6050707738174997" variance="0.0006" varianceWithPedigreeUncertainty="0.0026"/>
          <pedigreeMatrix reliability="1" completeness="4" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
