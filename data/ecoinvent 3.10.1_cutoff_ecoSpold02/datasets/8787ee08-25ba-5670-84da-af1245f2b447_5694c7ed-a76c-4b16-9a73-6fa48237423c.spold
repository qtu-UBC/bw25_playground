        <activityName xml:lang="en">soda ash, light, crystalline, heptahydrate, to generic market for neutralising agent</activityName>
        <synonym xml:lang="en">soda ash</synonym>
        <synonym xml:lang="en">sodium carbonate</synonym>
        <synonym xml:lang="en">ash</synonym>
        <includedActivitiesStart xml:lang="en">Activity starting with the input of soda ash, light, crystaline, heptahydrate, from Solvay process</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Activity ends with the proper conversion of soda ash to neutralising agent in NaOH-equivalents.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This activity links the output of the market for soda ash, light, crystalline, heptahydrate to the generic market for neutralising agent.</text>
        </generalComment>
      </activity>
