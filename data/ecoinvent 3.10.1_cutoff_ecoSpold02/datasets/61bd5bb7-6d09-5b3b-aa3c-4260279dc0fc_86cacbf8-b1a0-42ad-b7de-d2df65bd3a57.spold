  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="61bd5bb7-6d09-5b3b-aa3c-4260279dc0fc" activityNameId="6c6d53a7-df13-4420-8ffa-3b9ed65c9d52" parentActivityId="4ce5bc88-cd62-4c37-ad3c-f30ecf56b04e" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for indium rich leaching residues, from zinc production stockpiling</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce 'indium rich leaching residues, from zinc production stockpiling',  within the geography of Global.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'indium rich leaching residues, from zinc production stockpiling',  to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'indium rich leaching residues, from zinc production stockpiling', in the Global geography.</text>
          <text xml:lang="en" index="2">Transport from producers to consumers of this product in the geography covered by the market is included.</text>
        </generalComment>
      </activity>
      <classification classificationId="aeaec32d-b5a4-44e0-bb50-25c0f4fe3d37">
