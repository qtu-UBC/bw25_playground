      <elementaryExchange id="4430089f-d19a-58fb-9230-c10fb3891ad0" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" casNumber="007732-18-5" amount="0.0147069911293363" sourceId="026b0ec7-c20a-43c6-806d-db5afdeb78e6" sourceYear="2000" sourceFirstAuthor="Gendorf" elementaryExchangeId="fc1c42ce-a759-49fa-b987-f1ec5e503db1" formula="H2O">
        <name xml:lang="en">Water, cooling, unspecified natural origin</name>
        <unitName xml:lang="en">m3</unitName>
        <comment xml:lang="en">Calculated based on literature data published by the GENDORF Chemical Park. The factory produced an average of 2462760 tonnes of chemical substances (including intermediates) per year in the years 2015-2019. The average amount of cooling water released in the years 2015-2019 was 34408800 t per year. It was assumed that 5% of the cooling water was emitted to air during its use, therefore, to calculate the input of cooling water, the output value reported by GENDORF was scaled up by the factor 1/0.95. This equals 0.014707 m3/kg chemical produced.

References:
Chemiepark GENDORF, Umwelterklärung 2016, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit
Chemiepark GENDORF, Umwelterklärung 2017, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit
Chemiepark GENDORF, Umwelterklärung 2020, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit</comment>
        <uncertainty>
          <lognormal meanValue="0.0147069911293363" mu="-4.219432311223434" variance="0.0006" varianceWithPedigreeUncertainty="0.0532"/>
          <pedigreeMatrix reliability="2" completeness="4" temporalCorrelation="4" geographicalCorrelation="5" furtherTechnologyCorrelation="4"/>
          <comment xml:lang="en">The uncertainty could not be determined, it has then been maximized.</comment>
        </uncertainty>
        <synonym xml:lang="en">oxidane</synonym>
