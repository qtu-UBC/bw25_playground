      <intermediateExchange id="bfa18883-a65e-5776-92f1-976c9a419ca9" unitId="77ae64fa-7e74-4252-9c3b-889c1cd20bfc" amount="1.021375323" sourceId="f6ee6599-f8a7-4864-9f53-2b5d274f8be4" sourceYear="2014" sourceFirstAuthor="IEA" intermediateExchangeId="759b89bd-3aa6-42ad-b767-5bb9ef5d331d" activityLinkId="c51b545f-faee-5aec-a73a-0b849b9bf7a5">
        <name xml:lang="en">electricity, medium voltage</name>
        <unitName xml:lang="en">kWh</unitName>
        <comment xml:lang="en">Calculated value/estimation. This value compensates for the losses during transformation from high to medium voltage. The calculation is made based on total electricity losses between net electricity available at the busbar and the use of electricity calculated based on the IEA electricity information, data valid for the year 2020. These total losses over the whole chain are then allocated to the different voltage levels as well as transformation and transmission losses based on information in Itten et al. 2014. For details please see the documentation available on ecoQuery. IEA. 2016. Electricity Information 2016. International Energy Agency (IEA), Paris Cedex (FR). Itten R., Frischknecht R., Stucki M. 2014. Life Cycle Inventories of Electricity Mixes and Grid. Version 1.3. treeze, Uster, Switzerland</comment>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
