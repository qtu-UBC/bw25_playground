        <activityName xml:lang="en">treatment of used lorry with refrigeration machine, 16 metric ton</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts when the used lorry enters the waste treatment facility. The data on energy needed during dismantling are unknown. </includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends by different waste materials being ready for further treatment.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the treatment of used lorry with refrigeration machine, 16 metric tones.</text>
        </generalComment>
      </activity>
      <classification classificationId="c7c61217-b562-41bf-b976-28367154f536">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">transport systems/road</classificationValue>
      </classification>
      <classification classificationId="db303709-3eac-4c8b-9ed9-7e4888240c50">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3830:Materials recovery</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">The inventory is created by looking at the material composition of the lorry. </text>
        </comment>
      </technology>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
