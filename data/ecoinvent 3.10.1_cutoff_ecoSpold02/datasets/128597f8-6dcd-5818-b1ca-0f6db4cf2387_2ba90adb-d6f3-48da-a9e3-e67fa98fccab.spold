      <elementaryExchange id="470eb305-4643-5df4-b4f9-4b1d09ad8429" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="014265-45-3" amount="0.00448861962991223" isCalculatedAmount="true" mathematicalRelation="(((1/ process_efficiency-1)*sulfur_dioxide_input)- sulfur_dioxide_output)*(80.03/64.04)*0.1" elementaryExchangeId="24145938-f9e3-40ea-ab06-409187ca5d26" formula="O3S-2">
        <name xml:lang="en">Sulfite</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value based on literature and estimates. In case of sulfur dioxide (SO2), part of the unreacted volume is released as sulfur dioxide into air and part is released as sulfite into wastewater. The efficiency of the waste water treatment plant (WWTP) is assumed to be 90% . This means that 10% of the volume of sulfur on the inflow to the WWTP is released to the environment. 80.03 g/mol is the molar mass of sulfite (SO3); 64.04 g/mol is the molar mass of sulfur dioxide (SO2).</comment>
        <uncertainty>
          <lognormal meanValue="0.00448861962991223" mu="-5.406210056585724" variance="0.04" varianceWithPedigreeUncertainty="0.05920000000000001"/>
