  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="6747ba56-ad29-5252-8bb6-727f0849ac8c" activityNameId="58cf5f48-8f6e-4c94-a966-130c6f4dd62d" parentActivityId="72ab4715-acc3-49da-92ab-85778362fc91" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">treatment of spent sawing slurry from Si-wafer cutting</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts with the slurry being available at the gate of the treatment facility.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the slurry being treated and waste-specific emissions released to the environment. The output of silicon-iron mix is neglected in this inventory. Infrastructure is included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the treatment of a spent sawing slurry from Si-wafer cutting from an ordinary transforming activity.</text>
          <text xml:lang="en" index="1">The specific weight of input slurry 1.75kg/l (wet mass).</text>
        </generalComment>
        <tag>ConvertedDataset</tag>
      </activity>
      <classification classificationId="db303709-3eac-4c8b-9ed9-7e4888240c50">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3830:Materials recovery</classificationValue>
      </classification>
