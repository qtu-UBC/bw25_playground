<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="5fff3d78-30b8-5044-88ff-3d5f13a3c648" activityNameId="19178905-ca7c-46dc-b211-9ab4f721555e" parentActivityId="85f38819-4b1f-4ea0-9335-8da1e810bda5" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for mandarin</activityName>
        <synonym xml:lang="en">Satsumas</synonym>
        <synonym xml:lang="en">Clementine</synonym>
        <synonym xml:lang="en">Tangerine</synonym>
        <synonym xml:lang="en">Soft citrus</synonym>
        <includedActivitiesStart xml:lang="en">The activity includes the transport from the farm to the packhouse facilities.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Cold store is not included since it happens after the fruit has left the packhouse. Losses are included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This dataset represent the local market for mandarin in South Africa. Mandarins will then be sorted and graded at the sorting facilities (packhouses).</text>
          <text xml:lang="en" index="2">Data from Company Budget Report (Combuds), CGA (2016) and a previous study done on the soft citrus sector in South Africa (Konig, 2015)</text>
        </generalComment>
      </activity>
      <classification classificationId="562d396f-b27d-437b-b69f-3bfe87fcd737">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0123:Growing of citrus fruits</classificationValue>
      </classification>
      <geography geographyId="12b21766-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">ZA</shortname>
        <comment>
          <text xml:lang="en" index="0">This dataset represents the local market for mandarin in South Africa. From the farm the mandarin are transported to the packhouse where they will be graded and sorted. </text>
        </comment>
      </geography>
      <technology/>
      <timePeriod startDate="2015-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
