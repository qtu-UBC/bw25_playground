<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="7c331d8b-e9ad-53a1-a045-54b57f3e09cc" activityNameId="2bca23da-bbe7-4893-ab6f-3f148d684374" parentActivityId="4d92d3d2-dadd-48d5-90af-0b21856bead3" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">wood preservative production, organic, indoor use, occasionally wet</activityName>
        <includedActivitiesStart xml:lang="en">From reception of chemicals at the factory gate</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The datasets covers the components and preparation of a typical water-based/organic solvent based [as applicable] wood preservative for the use class according to EN 335-1:2006 as indicated in the name of the dataset, ready to be packed. In addition in contains an estimate for electricity consumption and for infrastructure. Packaging is not included</includedActivitiesEnd>
        <generalComment>
          <imageUrl index="0">https://db3.ecoinvent.org/images/56a9c2b5-cfbc-430f-ae98-d7918c345b17</imageUrl>
          <text xml:lang="en" index="1">According to EN 335-1:2005, five use classes are distinguished for chemical wood protection based on the general exposure of wood in its application, wetting regime in service and the biological agents to be expected. This exposure scenario determines the potentially vulnerable zone of wood and the required treatment for the application of the wood preservative (see table)</text>
        </generalComment>
        <tag>Swiss brush-up completed</tag>
      </activity>
      <classification classificationId="8a45a80b-336f-4a04-95fb-1a1be360d2d3">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2021:Manufacture of pesticides and other agrochemical products</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
        <comment>
          <text xml:lang="en" index="0">Data referring to (Central) European conditions</text>
        </comment>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2012-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
