<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="95d177e2-6e88-5f45-baf6-77b3e6fbfff1" activityNameId="a66dc616-b8b3-4de0-9b7e-7a02c30085cf" parentActivityId="b47a91ef-ef2e-4878-8c4b-c51bc0cd58c7" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">treatment of used refrigeration machine, carbon dioxide, liquid as refrigerant</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts when the used refrigeration machine enters the waste treatment facility.

The data on energy needed during dismantling are unknown. </includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends by different waste materials being ready for further treatment.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the treatment of used refrigeration machine which uses carbon dioxide, liquid as refrigerant.</text>
        </generalComment>
      </activity>
      <classification classificationId="db303709-3eac-4c8b-9ed9-7e4888240c50">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3830:Materials recovery</classificationValue>
      </classification>
      <classification classificationId="c7c61217-b562-41bf-b976-28367154f536">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">transport systems/road</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="2">
        <comment>
          <text xml:lang="en" index="0">The inventory is created by looking at the material composition of the container. </text>
          <text xml:lang="en" index="1">The most used refrigerant in refrigeration machines is the R134a. Since this refrigerant has a high global warming potential the refrigeration technology producers started producing referigeration machines with alternative refrigerants (Carrier, 2014, http://dms.hvacpartners.com//docs/2000/Public/0D/62-11665.pdf, accessed 20141105). One of them is liquid carbon dioxide.</text>
        </comment>
      </technology>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
