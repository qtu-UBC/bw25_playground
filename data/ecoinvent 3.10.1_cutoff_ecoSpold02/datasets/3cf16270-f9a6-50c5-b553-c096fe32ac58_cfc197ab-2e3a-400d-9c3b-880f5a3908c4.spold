  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="3cf16270-f9a6-50c5-b553-c096fe32ac58" activityNameId="b152f84e-3caf-4785-9acc-8aea71b50c29" parentActivityId="98421932-0f89-5a69-bc15-9c23131cf594" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">potato grading</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts from the agricultural field foreseen to be processed.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with potato planting. The dataset includes the diesel fuel consumption and the amount of agricultural machinery and of the shed attributed to the field work. It was also taken into consideration the amount of emissions to the air from combustion and the emission to the soil from tyre abrasion during the work process. Demand on machinery, buildings (shed) and electricity for potato grading and weighting.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset models the grading process of 1 kg ungraded potatoes.</text>
        </generalComment>
      </activity>
      <classification classificationId="2fbefa76-b10b-4120-9966-682ad1b66329">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0163:Post-harvest crop activities</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is a copy of the geography of Switzerland. Data quality indicators were adjusted accordingly.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">The inventory uses a potato grader and a weigh.</text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
