    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Transport assumptions have been extrapolated from the activity "sodium nitrate production, unrefined from caliche ore mining, CL". The road transport has been extrapolated. The train distance has been calculated from the distances to Coya Sur to the main mining facilities [https://www.sqm.com/sqmeninfografias/eng/presence.html] [Ordóñez, J. et al. (2017) “Heap Leaching of Caliche Ore. Modeling of a Multicomponent System with Particle Size Distribution” https://doi.org/10.3390/min7100180].</samplingProcedure>
        <extrapolations xml:lang="en">Transport assumptions were extrapolated from "sodium nitrate production, unrefined from caliche ore mining - CL".</extrapolations>
      </representativeness>
