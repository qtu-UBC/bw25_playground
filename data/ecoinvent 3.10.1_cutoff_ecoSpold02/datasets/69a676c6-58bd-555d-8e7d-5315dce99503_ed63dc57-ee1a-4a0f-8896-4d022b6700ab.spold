<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="69a676c6-58bd-555d-8e7d-5315dce99503" activityNameId="301bb4b6-be55-40ac-84dc-2e3c59b53446" parentActivityId="1e22dadb-9e6f-40f1-926d-d1d8d8d227d2" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for sodium nitrate, unrefined</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce 'sodium nitrate, unrefined', within the geography of Chile.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of sodium nitrate, unrefined', to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This activity represents the market for 1 kg of sodium nitrate, unrefined. Unrefined sodium nitrate has a purity of 45%-60%. The major natural resources of this product are found in caliche ore in Chile.</text>
          <text xml:lang="en" index="2">Sodium nitrate with this purity is usually not sold on the market. This sodium nitrate is used in the production of potassium nitrate or will be further processed to higher purities. </text>
        </generalComment>
      </activity>
      <classification classificationId="04d83550-7c85-44f3-916b-424730a81963">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2012:Manufacture of fertilizers and nitrogen compounds</classificationValue>
      </classification>
      <geography geographyId="0c852cde-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">CL</shortname>
        <comment>
          <text xml:lang="en" index="0">This dataset is valid within the geography of Chile.</text>
        </comment>
      </geography>
      <technology/>
      <timePeriod startDate="2017-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The dataset is assumed to be at least valid since the publication of the study used for the transport estimation (2017), until the year of assessment (2023).</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
