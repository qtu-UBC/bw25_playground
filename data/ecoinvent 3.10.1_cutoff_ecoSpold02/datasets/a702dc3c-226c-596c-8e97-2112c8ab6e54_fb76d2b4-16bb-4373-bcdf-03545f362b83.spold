      <activity specialActivityType="0" id="a702dc3c-226c-596c-8e97-2112c8ab6e54" activityNameId="17adbaae-7a63-4ccb-a9e6-5c403988c089" parentActivityId="575f2b81-9e88-474e-b959-2f1e08821f18" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">1,3-dichloropropene to generic market for pesticide, unspecified</activityName>
        <synonym xml:lang="en">1,3-D</synonym>
        <synonym xml:lang="en">1,3-dichloro-1-propene</synonym>
        <synonym xml:lang="en">1,3-dichloropropylene</synonym>
        <synonym xml:lang="en">DCP</synonym>
        <synonym xml:lang="en">3-chloroorpropenyl chloride</synonym>
        <synonym xml:lang="en">1,3-dichloro-2-propene</synonym>
        <synonym xml:lang="en">3-chloroallyl chloride</synonym>
        <synonym xml:lang="en">dichloro-1,3-propene</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts with the reception of dichloropropene</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the production of pesticide, unspecified</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a linking activity which links the product dichloropropene to the generic market for pesticide, unspecified. All chemicals that enter this market provide the function of a pesticide.</text>
        </generalComment>
      </activity>
      <classification classificationId="28f738cc-bb73-48f8-b633-f83fb9bc5ddc">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2011:Manufacture of basic chemicals</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
        <comment>
          <text xml:lang="en" index="0"> 1,3-dichloropropene is used as a pesticide in the United States, Europe, Japan, the Philippines, and Africa. It is phased out in the EU (http://eur-lex.europa.eu/LexUriServ/site/en/oj/2007/l_249/l_24920070925en00110013.pdf). </text>
        </comment>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2012-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
