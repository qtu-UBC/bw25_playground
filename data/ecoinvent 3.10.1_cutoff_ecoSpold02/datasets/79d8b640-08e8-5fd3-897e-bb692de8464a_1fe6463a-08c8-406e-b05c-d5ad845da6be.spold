      <intermediateExchange id="276d6df1-3f61-54c1-ac9b-9a9f2b4af090" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="water_deionised_input" casNumber="007732-18-5" amount="4.4" intermediateExchangeId="360e2eb0-f81c-4e4b-ba6b-c7a690f31275" activityLinkId="bc61eabb-a2d0-53dc-ad72-5bac649acdab">
        <name xml:lang="en">water, deionised</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Estimated value. Water is required to hydrate the activated cation exchanger resin to 50 wt-%, which means 0.5 kg of deionised water is needed. Furthermore, an amount of 5 bed volumes was estimated to be needed to rinse the produced resin. Using a density of
1.28 kg/L for the moist resin (Ullmann 2002), the demand for rinsing water is 3.9 kg. Therefore, in total, 4.4 kg of deionised water is consumed.</comment>
        <uncertainty>
          <lognormal meanValue="4.4" mu="1.4816045409242156" variance="0.03" varianceWithPedigreeUncertainty="0.030199999999999998"/>
          <pedigreeMatrix reliability="1" completeness="1" temporalCorrelation="2" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
