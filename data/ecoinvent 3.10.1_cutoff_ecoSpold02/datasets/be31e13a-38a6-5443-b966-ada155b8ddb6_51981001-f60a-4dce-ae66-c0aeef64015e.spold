<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="be31e13a-38a6-5443-b966-ada155b8ddb6" activityNameId="df86daec-80cb-4c4d-8119-ca6159726fc4" parentActivityId="3bcd9a12-f606-4295-a8db-3c0142406ae2" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for bamboo culm</activityName>
        <includedActivitiesStart xml:lang="en">Activity starts in the bamboo forest or intermediary processing facility with the delivery of bamboo culm. 
</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with bamboo culm being delivered to the consuming activity.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This dataset represents the Ecuadorian market for bamboo culm. The average transport distance is based on expert judgement.</text>
          <text xml:lang="en" index="2"></text>
          <text xml:lang="en" index="3">The stems of bamboo are called bamboo culms. Bamboo culms are characterized by their strength, flexibility, and versatility. However, due to their high water content (u= ca.80 %) the culms are not applied directly as construction material. The culms are used for the production of bamboo poles which can be used directly for the construction of columns, beams, or struts and the production of other bamboo-based construction materials.</text>
        </generalComment>
      </activity>
      <classification classificationId="3e174aa1-0f01-4267-a84d-fa211a90dc7f">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0230:Gathering of non-wood forest products</classificationValue>
      </classification>
      <geography geographyId="0d0e72a0-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">EC</shortname>
        <comment>
          <text xml:lang="en" index="0">Transport distance for bamboo culm is based on expert judgment and not region specific. </text>
        </comment>
      </geography>
      <technology/>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
