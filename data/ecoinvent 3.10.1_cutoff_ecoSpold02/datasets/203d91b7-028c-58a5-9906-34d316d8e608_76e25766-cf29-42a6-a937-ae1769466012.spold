<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="203d91b7-028c-58a5-9906-34d316d8e608" activityNameId="8d15ed48-822d-4323-ab96-71dfcdeef91e" parentActivityId="a568091e-2239-4e65-bbfa-bb1e7f5ab43b" inheritanceDepth="-1" type="1" datasetIcon="https://db3.ecoinvent.org/images/3882ea81-1510-459d-ad01-f7b96c9753ba">
        <activityName xml:lang="en">treatment of Cu-based antifouling paint emissions</activityName>
        <includedActivitiesStart xml:lang="en">Direct emissions to the marine environment</includedActivitiesStart>
        <generalComment>
          <text xml:lang="en" index="0">This activity represents the direct emissions to ocean of Cu-based antifouling paint. 2/3 of the dry matter of the active substances present in the paint are assumed to be emitted. Data from analysis of 2 antifouling paints used in Peru</text>
        </generalComment>
      </activity>
      <classification classificationId="2fc70895-91b4-48a7-a362-8b22623ba3a4">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0311:Marine fishing</classificationValue>
      </classification>
      <geography geographyId="11387d6c-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">PE</shortname>
        <comment>
          <text xml:lang="en" index="0">Data from Peru, extrapolated to global (GLO). Not representative of European conditions</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Two samples of common antifouling paints used in Peru, were analysed by the French laboratory UT2A (http://www.univ-pau.fr/ut2a) in 2010. Values are means from the two analyses, and uncertainty data are also based on measured values.</text>
        </comment>
      </technology>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
        <comment xml:lang="en">Peru is the second largest fishing country in the world, whose fleets mainly consist of purse seiners. Antifouling paints are both imported and nationally produced. Peruvian treatment of antifouling paints represents global technologies, except for Europe and other countries where certain active substances (e.g. Tributyltin) are forbidden and the prohibition enforced </comment>
      </macroEconomicScenario>
    </activityDescription>
