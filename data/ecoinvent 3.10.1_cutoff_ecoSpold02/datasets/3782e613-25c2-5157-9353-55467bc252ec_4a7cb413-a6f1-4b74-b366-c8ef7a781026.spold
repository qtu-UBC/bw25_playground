        <activityName xml:lang="en">sawnwood production, softwood, raw, dried (u=20%)</activityName>
        <includedActivitiesStart xml:lang="en">Entry of the specific products issued of the drying activity</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Delivery of the generic planed product</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This activity is providing a more generic sawnwood product, combining inputs from the specific products issued from drying in the sawmil. The relative contribution is based in their Production Volumes.</text>
        </generalComment>
      </activity>
      <classification classificationId="45e0d63f-f176-49f2-a053-8033c5f89e77">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1610:Sawmilling and planing of wood</classificationValue>
      </classification>
      <geography geographyId="131278d6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">CH</shortname>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2014-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
