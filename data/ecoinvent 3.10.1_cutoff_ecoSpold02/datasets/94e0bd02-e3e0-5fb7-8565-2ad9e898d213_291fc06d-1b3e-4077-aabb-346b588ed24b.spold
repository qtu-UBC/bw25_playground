    <activityDescription>
      <activity specialActivityType="10" id="94e0bd02-e3e0-5fb7-8565-2ad9e898d213" activityNameId="b350de54-fbdb-485b-8600-b566ebeea264" activityNameContextId="de659012-50c4-4e96-b54a-fc781bf987ab" parentActivityId="2699a5eb-b2b1-40f8-a0a6-64c1798ff2c3" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market group for diesel</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of markets that deliver 'diesel', in geographies contained within the geography of this dataset.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'diesel',  to the consumers of this product within the geography of Global.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset is a market group. Market groups represent a 'market of markets'. Their purpose is to group a set of markets into larger, geographically relevant datasets.</text>
          <text xml:lang="en" index="1">Market groups are created for convenience and ease of use. They only group other markets and/or market groups contained within their geography.</text>
          <text xml:lang="en" index="2">Losses and relevant exchanges (transport, transport infrastructure, etc.) are not included in this dataset. They are present in the contained markets.  </text>
          <text xml:lang="en" index="3">This is the market group for 'diesel', in the Global geography.</text>
        </generalComment>
      </activity>
      <classification classificationId="0bef4135-5b56-4012-a812-b78c9a8218a9">
