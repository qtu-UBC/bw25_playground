      <intermediateExchange id="8d03e27b-d7e6-50e9-b7dd-6b5c46390178" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="065997-15-1" amount="0.00096721989" isCalculatedAmount="true" mathematicalRelation="admix_amount * admix_density * share_cement" intermediateExchangeId="c5299a8e-d4b4-409c-9826-e8ae9e37c03d" activityLinkId="6ec894c5-1af5-50f6-873e-63d219d90a7c">
        <name xml:lang="en">cement, Portland</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculate value. Proxy for one component of PENETRON ADMIX®, which is a grey powder with pH equal to 10-13, mostly consisting of Portland cement and various active, proprietary chemicals. The original amount of ADMIX for the production process of 1 kg concrete block is 0.000001286 m3, as informed by the owner of the factory. The value is calculated considering the density of the admix (1.131 kg/m3) and the share in % of the cement Portland (66.5% weighted average from Penetron. (2020). Environmental Product Declaration: Penetron Admix. https://api.environdec.com/api/v1/EPDLibrary/Files/b3b1f43c-d7d9-4bb9-ad14-08da599e304a/Data </comment>
        <uncertainty>
          <lognormal meanValue="0.00096721989" mu="-6.9410846943590085" variance="0.0006" varianceWithPedigreeUncertainty="0.0026"/>
          <pedigreeMatrix reliability="1" completeness="4" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
        <synonym xml:lang="en">Ordinary Portland Cement</synonym>
