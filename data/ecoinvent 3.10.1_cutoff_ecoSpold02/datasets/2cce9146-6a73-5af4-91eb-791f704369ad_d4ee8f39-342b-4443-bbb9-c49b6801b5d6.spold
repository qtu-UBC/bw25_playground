    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce" percent="60.0">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Data obtained by a process assessment in a technical visit in a concrete block factory. It is assumed that this dataset represents 60% of the concrete block production activity in Ecuador, since the process is semi mechanized and it could change between factories in Ecuador. Land occupation exchange is used as an estimate of infrastructure. Machinery use is accounted for through their fuel / electricity consumption. 


</samplingProcedure>
        <extrapolations xml:lang="en">No extrapolation was applied.</extrapolations>
      </representativeness>
