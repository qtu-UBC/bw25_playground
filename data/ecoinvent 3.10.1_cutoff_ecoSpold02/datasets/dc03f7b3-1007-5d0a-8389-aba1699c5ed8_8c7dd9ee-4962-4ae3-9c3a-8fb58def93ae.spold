  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="dc03f7b3-1007-5d0a-8389-aba1699c5ed8" activityNameId="9aa8c628-ada0-49c6-a29e-2564c68f8b05" parentActivityId="ce414557-f238-4fe6-b4a2-b6cb7b8e5f73" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">nitrobenzene production</activityName>
        <synonym xml:lang="en">nitrobenzol</synonym>
        <synonym xml:lang="en">oil of mirbane</synonym>
        <synonym xml:lang="en">oil of bitter almonds</synonym>
        <includedActivitiesStart xml:lang="en">From the reception of benzene at the factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with 1 kg of nitrobenzene,100% at the factory gate.  The dataset includes the input materials, energy uses, infrastructure and emissions.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This data represents the production of 1 kg of nitrobenzene.  Raw materials, auxiliaries, energy consumption and emissions are based on literature that is based on actual plant throughputs and measurements. Infrastructure is included with a default value. </text>
          <text xml:lang="en" index="1">[This dataset was already contained in the ecoinvent database version 2. It was not individually updated during the transfer to ecoinvent version 3. Life Cycle Impact Assessment results may still have changed, as they are affected by changes in the supply chain, i.e. in other datasets. This dataset was generated following the ecoinvent quality guidelines for version 2. It may have been subject to central changes described in the ecoinvent version 3 change report (http://www.ecoinvent.org/database/ecoinvent-version-3/reports-of-changes/), and the results of the central updates were reviewed extensively. The changes added e.g. consistent water flows and other information throughout the database. The documentation of this dataset can be found in the ecoinvent reports of version 2, which are still available via the ecoinvent website. The change report linked above covers all central changes that were made during the conversion process.]</text>
        </generalComment>
        <tag>ConvertedDataset</tag>
      </activity>
      <classification classificationId="28f738cc-bb73-48f8-b633-f83fb9bc5ddc">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2011:Manufacture of basic chemicals</classificationValue>
      </classification>
      <classification classificationId="7ac1cbc6-1385-4a68-8647-ed7aa78db201">
