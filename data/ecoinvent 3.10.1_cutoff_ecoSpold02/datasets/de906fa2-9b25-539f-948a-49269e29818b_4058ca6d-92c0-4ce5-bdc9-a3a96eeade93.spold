<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="de906fa2-9b25-539f-948a-49269e29818b" activityNameId="c3b6c8aa-55e3-44e8-830d-98d62a0c1667" parentActivityId="b1e2d64e-4fbd-4941-8694-cd4afce40de7" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">treatment of waste gypsum plasterboard, collection for final disposal</activityName>
        <synonym xml:lang="en"> natural gypsum (has CAS 13397-24-5</synonym>
        <synonym xml:lang="en"> selenite</synonym>
        <synonym xml:lang="en"> alabaster</synonym>
        <synonym xml:lang="en">calcium sulfate dihydrate (has  CAS 10101-41-4)</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts when the building demolition activity is ready to be performed. Transportation of the waste to the treatment plant is not included.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity includes energy for dismantling, particulate matter emissions from dismantling and handling, and final disposal of waste material.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">The process represents the collection of 'waste gypsum plasterboard' for final disposal. The waste contains 1kg gypsum, while its density is 1000 kg/m3.</text>
        </generalComment>
      </activity>
      <classification classificationId="9a63625a-358b-4c1d-bf95-50ba038a759b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3821:Treatment and disposal of non-hazardous waste</classificationValue>
      </classification>
      <geography geographyId="131278d6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">CH</shortname>
        <comment>
          <text xml:lang="en" index="0">Modelling parameters specific to the technology mix encountered in Switzerland in late 1990ies</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Building demolition with skid-steer loaders.</text>
        </comment>
      </technology>
      <timePeriod startDate="1994-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
