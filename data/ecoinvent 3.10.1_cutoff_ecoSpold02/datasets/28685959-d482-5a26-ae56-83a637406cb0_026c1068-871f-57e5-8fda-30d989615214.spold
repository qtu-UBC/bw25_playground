<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="28685959-d482-5a26-ae56-83a637406cb0" activityNameId="e0c850cf-9927-57d7-9483-1f94020b89b5" parentActivityId="e8ed4723-a3fc-5428-ad66-eaaa9d6599fa" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for container, for collection of post-consumer waste plastic for recycling</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce 'container, for collection of post-consumer waste plastic for recycling',  within the geography of United States.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of  container, for collection of post-consumer waste plastic for recycling', to the consumers of this product. Transport or losses are considered irrelevant for this product.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'container, for collection of post-consumer waste plastic for recycling', in the geography of United States.</text>
          <text xml:lang="en" index="2">This market contains no transport or losses, as they are irrelevant for the delivered product.</text>
          <text xml:lang="en" index="3">This is a mobile infrastructure, representing the product of an average waste container that represents material requirements for the collection of 1 kg of post-consumer waste plastic for recycling. The process excludes any losses during production, use, end-of-life and infrastructure needed.</text>
        </generalComment>
      </activity>
      <classification classificationId="14363e31-908b-4e16-a794-638f2affef72">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2220:Manufacture of plastics products</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
      </geography>
      <technology/>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
