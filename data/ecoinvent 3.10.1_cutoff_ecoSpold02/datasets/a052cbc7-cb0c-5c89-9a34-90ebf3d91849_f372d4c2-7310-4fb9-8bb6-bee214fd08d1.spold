    <activityDescription>
      <activity specialActivityType="10" id="a052cbc7-cb0c-5c89-9a34-90ebf3d91849" activityNameId="b113fb0a-d9cb-417c-a1b3-cc854fbf0336" parentActivityId="3d9ef25e-720b-4b6c-823c-faaec7a31738" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market group for land use change, perennial crop</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of markets that deliver 'land use change, perennial crop', in geographies contained within the geography of this dataset.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'land use change, perennial crop',  to the consumers of this product within the geography of Brazil.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset is a market group. Market groups represent a 'market of markets'. Their purpose is to group a set of markets into larger, geographically relevant datasets.</text>
          <text xml:lang="en" index="1">Market groups are created for convenience and ease of use. They only group other markets and/or market groups contained within their geography.</text>
          <text xml:lang="en" index="2">Losses and relevant exchanges (transport, transport infrastructure, etc.) are not included in this dataset. They are present in the contained markets.  </text>
          <text xml:lang="en" index="3">This is the market group for 'land use change, perennial crop', in Brazil.</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
