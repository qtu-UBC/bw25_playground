        <activityName xml:lang="en">coke, import from CN</activityName>
        <includedActivitiesStart xml:lang="en">This activity represents the point of 'handing over' the coke from China to the global market at the border.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This dataset doesn't include any losses, transport or infrastructure.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the amount of imported coke from China to the Global supply. The import value is valid for 2015 and includes all imports, independently whether used within the importing region, or re-exported.</text>
        </generalComment>
      </activity>
      <classification classificationId="3aa0f2c5-1d26-4f98-8c2c-7406d4b7f2ae">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1910:Manufacture of coke oven products</classificationValue>
      </classification>
