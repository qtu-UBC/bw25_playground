<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="7de18139-aaeb-5251-8bba-0a12338c5bfd" activityNameId="feb6796d-4222-4101-a6e8-fd2724a1dc44" parentActivityId="7d46fefa-f6bb-4af8-b090-3fec83db5bf9" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">ethylene glycol monoethyl ether production</activityName>
        <includedActivitiesStart xml:lang="en">From the reception of ethylene oxide at the factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the production of 1 kg of ethylene glycol monoethyl ether, 100% at the factory gate.  The dataset includes the input materials, energy uses, infrastructure and emissions.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This data represents the production of 1 kg of ethylene glycol monoethyl ether from ethylene oxide.  Raw materials are modelled with a stoichiometric calculation. Energy consumptions and emissions estimated.  Infrastructure is included with a default value.</text>
          <text xml:lang="en" index="1">This data represents the production of 1 kg of ethylene glycol monoethyl ether from ethylene oxide.  Raw materials are modelled with a stoichiometric calculation, Energy consumptions,  emissions, infrastructure and transports are calculated with standard values.</text>
        </generalComment>
        <tag>ConvertedDataset</tag>
      </activity>
      <classification classificationId="7ac1cbc6-1385-4a68-8647-ed7aa78db201">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">chemicals/organics</classificationValue>
      </classification>
