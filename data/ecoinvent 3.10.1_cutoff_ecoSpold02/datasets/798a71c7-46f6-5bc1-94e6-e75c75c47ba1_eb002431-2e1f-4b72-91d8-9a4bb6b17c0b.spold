<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="798a71c7-46f6-5bc1-94e6-e75c75c47ba1" activityNameId="11dd5c3c-2f41-4aff-a31b-04b790b3a7eb" parentActivityId="8cd20ee7-6fc7-4741-8c6e-268718df8775" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">copper smelting facility construction</activityName>
        <synonym xml:lang="en">Kaldo Converter</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts with the transformation of unspecified land to industrial area.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Construction of facilities and housing, and their disposal. No transports and construction work considered.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">Production of Kaldo converter and converter aisle: chromium steel, refractory bricks and concrete foundation. Building hall houses the facilities, covering 1200m2. Service lifetime 50 year. Service lifetime 50 year, 250'000 t of metals produced per year.</text>
          <text xml:lang="en" index="1">[This dataset was already contained in the ecoinvent database version 2. It was not individually updated during the transfer to ecoinvent version 3. Life Cycle Impact Assessment results may still have changed, as they are affected by changes in the supply chain, i.e. in other datasets. This dataset was generated following the ecoinvent quality guidelines for version 2. It may have been subject to central changes described in the ecoinvent version 3 change report (http://www.ecoinvent.org/database/ecoinvent-version-3/reports-of-changes/), and the results of the central updates were reviewed extensively. The changes added e.g. consistent water flows and other information throughout the database. The documentation of this dataset can be found in the ecoinvent reports of version 2, which are still available via the ecoinvent website. The change report linked above covers all central changes that were made during the conversion process.]</text>
        </generalComment>
        <tag>ConvertedDataset</tag>
      </activity>
      <classification classificationId="7f668b02-5461-48bd-ae18-dfec04cce529">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">4100:Construction of buildings</classificationValue>
      </classification>
      <classification classificationId="aeaec32d-b5a4-44e0-bb50-25c0f4fe3d37">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">metals/extraction</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">Data describes a Swedish plant that is singular in the region and ranges worldwide among the big producer. It may be taken as approximation for the global situation</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Due to high temperature chromium steel and refractory materials are used. Kaldo converter and converter aisle considered.</text>
        </comment>
      </technology>
      <timePeriod startDate="2000-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
