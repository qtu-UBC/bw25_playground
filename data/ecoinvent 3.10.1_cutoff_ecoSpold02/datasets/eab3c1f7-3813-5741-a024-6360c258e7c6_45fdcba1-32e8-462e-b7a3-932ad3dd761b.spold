<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="eab3c1f7-3813-5741-a024-6360c258e7c6" activityNameId="4f9cef3a-078a-442e-934b-686345fb8409" parentActivityId="1ee6ad12-d7e4-53d6-8dd2-0c0b93f55244" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">chromium trioxide production, flakes</activityName>
        <synonym xml:lang="en">Dichromium trioxide</synonym>
        <synonym xml:lang="en">Chromium(III) oxide</synonym>
        <synonym xml:lang="en">Chromium oxide (Cr2O3)</synonym>
        <synonym xml:lang="en">Chromia</synonym>
        <synonym xml:lang="en">Chromium sesquioxide</synonym>
        <synonym xml:lang="en">Chrome Green</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts when the raw materials enter the process.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the production of chromium(VI) oxide flakes. The dataset includes the processing of the raw materials and chemicals used for production. It also includes estimated emissions to air and water from production (incomplete), as well as estimated energy demand and infrastructure of the plant (approximation). Solid wastes are omitted.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of 1 kg of chromium oxide flakes. Chromium oxide forms dark red crystals at room temperature. Chromium oxide is primarily used for electroplating. Other uses include the passivation of zinc, aluminium, cadmium and brass, the production of chromium dioxide as well as wood preservation.</text>
          <text xml:lang="en" index="1">This dataset is based on stoechiometric calculations as well as approximations based on data from a large chemical plant (Gendorf 2016).</text>
          <text xml:lang="en" index="2">References:</text>
          <text xml:lang="en" index="3">Anger, G., Halstenberg, J., Hochgeschwender, K., Scherhag, C., Korallus, U., Knopf, H., Schmidt, P. and Ohlinger, M. 2000. Chromium Compounds. Ullmann's Encyclopedia of Industrial Chemistry.</text>
          <text xml:lang="en" index="4">Althaus H.-J., Chudacoff M., Hischier R., Jungbluth N., Osses M. and Primas A. (2007) Life Cycle Inventories of Chemicals. ecoinvent report No. 8, v2.0. EMPA Dübendorf, Swiss Centre for Life Cycle Inventories, Dübendorf, CH.</text>
          <text xml:lang="en" index="5">Gendorf (2016) Umwelterklärung 2015, Werk Gendorf Industriepark, www.gendorf.de.</text>
        </generalComment>
      </activity>
      <classification classificationId="28f738cc-bb73-48f8-b633-f83fb9bc5ddc">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2011:Manufacture of basic chemicals</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">The data used has no specific geographical origin as it is based on stoechiometric calculations and estimations. It is assumed to be representative of the production processes in this geography. Some values are based on data from a large chemical factory located in Germany. These are assumed to be valid for this geography.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Production from sodium dichromate and sulphuric acid according to the wet process scheme, with a process yield of 98%. The inventory is based on stoechiometric calculations. The emissions to air (0.2 wt% of raw material input) and water were estimated using mass balance. Treatment of the waste water in an internal waste water treatment plant assumed (elimination efficiency of 50% for Cr-compounds).</text>
          <text xml:lang="en" index="1">References:</text>
          <text xml:lang="en" index="2">Anger, G., Halstenberg, J., Hochgeschwender, K., Scherhag, C., Korallus, U., Knopf, H., Schmidt, P. and Ohlinger, M. 2000. Chromium Compounds. Ullmann's Encyclopedia of Industrial Chemistry.</text>
          <text xml:lang="en" index="3">Althaus H.-J., Chudacoff M., Hischier R., Jungbluth N., Osses M. and Primas A. (2007) Life Cycle Inventories of Chemicals. ecoinvent report No. 8, v2.0. EMPA Dübendorf, Swiss Centre for Life Cycle Inventories, Dübendorf, CH.</text>
        </comment>
      </technology>
      <timePeriod startDate="2000-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Date of published literature. Some values are based on data published by the Gendorf factory that were collected between 2011 and 2015. The time period has been adjusted accordingly. For more details, see the comments of the exchanges.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
