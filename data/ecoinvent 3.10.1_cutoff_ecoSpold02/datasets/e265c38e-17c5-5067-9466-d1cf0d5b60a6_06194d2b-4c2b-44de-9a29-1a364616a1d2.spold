          <text xml:lang="en" index="0">Data-set is representive for Europe</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">MAG-welding of unalloyed steel with 83% Ar, 13% CO2 and 4% O2 protective gas and a wire consumption of 0.0536 kg/m.</text>
        </comment>
      </technology>
      <timePeriod startDate="1997-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
