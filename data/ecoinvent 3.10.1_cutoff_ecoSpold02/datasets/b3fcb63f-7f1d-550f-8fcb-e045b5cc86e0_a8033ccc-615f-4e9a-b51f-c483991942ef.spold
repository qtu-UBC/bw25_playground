      <review reviewedMajorRelease="3" reviewedMinorRelease="0" reviewedMajorRevision="0" reviewedMinorRevision="19" reviewerId="87296ea5-2149-44c3-8e36-b1256c92666a" reviewerName="Gregor Wernet" reviewerEmail="wernet@ecoinvent.org" reviewDate="2012-03-27">
        <otherDetails xml:lang="en"/>
      </review>
      <review reviewedMajorRelease="3" reviewedMinorRelease="0" reviewedMajorRevision="0" reviewedMinorRevision="19" reviewerId="9011fbce-fc4b-4755-890b-96728c23c4d3" reviewerName="Bo Weidema" reviewerEmail="bow@lca-net.com" reviewDate="2012-03-27">
        <details>
          <text xml:lang="en" index="0">This dataset has been accepted as a temporary production route for sodium tetrafluoroborate, due to the lack of data for the main production route. This dataset actually represents a minor production route for sodium tetrafluoroborate, which should rather be sen as a treatment activity for BF3 (catalyst) contamination in the product stream, i.e. with a waste "boron trifluoride contaminant" as a negative reference product. This may be changed later, when a dataset representing the main production route has been made available.</text>
        </details>
        <otherDetails xml:lang="en"/>
      </review>
