<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="df8b53c8-ab35-5e73-aaa7-42d094ec2b87" activityNameId="ebcd1357-a6ce-4608-9663-bb0a1df7476c" parentActivityId="a6fc89a9-9cb6-5ebf-9b72-2dc19dbecade" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for maize grain</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts at the gate of maize grain cultivation farm.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'maize grain', to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for 'maize grain', in the geography of South Dakota state in the United States of America.</text>
          <text xml:lang="en" index="2">This dataset represents the transport of 1 kg of maize grain, from the production farm to the place it is later used, i.e. maize grain feed production or maize grain processing, dry milling. No losses are considered in this dataset.</text>
          <text xml:lang="en" index="3">The product 'maize grain' is a grain. It is an annual crop. The ecoinvent database also contains this product from organic, Swiss integrated and rainfed production.</text>
        </generalComment>
      </activity>
      <classification classificationId="e2e1f67d-3393-4182-86f6-1ada2f77c3e5">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0111:Growing of cereals (except rice), leguminous crops and oil seeds</classificationValue>
      </classification>
      <geography geographyId="18288eee-911f-4f54-8881-39c0c0b70779">
        <shortname xml:lang="en">US-SD</shortname>
        <comment>
          <text xml:lang="en" index="0">Data represent the situation in South Dakota state in the United States of America.</text>
        </comment>
      </geography>
      <technology/>
      <timePeriod startDate="2014-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The time period is the same as stated in the transforming activity for the same reference product.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
