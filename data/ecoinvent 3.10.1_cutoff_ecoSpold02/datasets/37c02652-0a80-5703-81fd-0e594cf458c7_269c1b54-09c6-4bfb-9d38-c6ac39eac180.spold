  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="37c02652-0a80-5703-81fd-0e594cf458c7" activityNameId="fc0bad64-3ef6-4347-9b04-490ddf20d74d" parentActivityId="5ea85695-a1b8-4b32-89c3-40798c4b8ca2" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for pyrolysis fuel gas</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce pyrolysis fuel gas, within the geography of Global.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of pyrolysis fuel gas,  to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'pyrolysis fuel gas' in the Global geography.</text>
          <text xml:lang="en" index="2">'pyrolysis fuel gas' is usually not transported and directly consumed on site.</text>
          <text xml:lang="en" index="3">The product 'pyrolysis fuel gas' represents a liquid hydrocarbon mix with substances ranging from 10 to 22 carbon atoms. It can be used in the following applications: fuel.</text>
        </generalComment>
      </activity>
      <classification classificationId="8714dc59-0b7b-4e7a-8227-e639051eb6e1">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">202:Manufacture of other chemical products</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology/>
      <timePeriod startDate="2022-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
