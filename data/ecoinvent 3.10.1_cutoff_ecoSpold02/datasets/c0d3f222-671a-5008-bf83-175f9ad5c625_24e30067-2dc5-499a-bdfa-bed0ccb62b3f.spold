      <intermediateExchange id="31a1ab98-4f70-571e-89d2-aaa1df677892" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="m_waste_pb" amount="-0.00119" intermediateExchangeId="ad38bbd2-e41c-4509-9dc3-c5c708a36606" activityLinkId="42b62312-c7d0-5151-be05-5d774daf61f6" productionVolumeMathematicalRelation="(m_waste_pb/wet_mass)*pv_bc*wet_mass">
