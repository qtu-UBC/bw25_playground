    <activityDescription>
      <activity specialActivityType="10" id="8ffcf5d7-97fa-53f8-bde8-0a2193ccd05e" activityNameId="2f7b22f6-ceb7-423d-92b3-487218538617" activityNameContextId="de659012-50c4-4e96-b54a-fc781bf987ab" parentActivityId="7109dd3c-5601-4f90-a150-760480bb8e88" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market group for natural gas, high pressure</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of markets that deliver 'natural gas, high pressure', in geographies contained within the geography of this dataset.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'natural gas, high pressure',  to the consumers of this product within the geography of Europe without Switzerland.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset is a market group. Market groups represent a 'market of markets'. Their purpose is to group a set of markets into larger, geographically relevant datasets.</text>
          <text xml:lang="en" index="1">Market groups are created for convenience and ease of use. They only group other markets and/or market groups contained within their geography.</text>
          <text xml:lang="en" index="2">Losses and relevant exchanges (transport, transport infrastructure, etc.) are not included in this dataset. They are present in the contained markets.  </text>
          <text xml:lang="en" index="3">This is the market group for 'natural gas, high pressure', in Europe without Switzerland.</text>
        </generalComment>
      </activity>
      <classification classificationId="5020424a-5b73-4722-8000-ac205dbd592d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3520:Manufacture of gas; distribution of gaseous fuels through mains</classificationValue>
