          <classificationValue xml:lang="en">34110: Hydrocarbons and their halogenated, sulphonated, nitrated or nitrosated derivatives</classificationValue>
        </classification>
        <classification classificationId="6d63c7a7-fdff-5280-b6d7-7efd3399479c">
          <classificationSystem xml:lang="en">HS2017</classificationSystem>
          <classificationValue xml:lang="en">290339: Fluorinated, brominated or iodinated derivatives of acyclic hydrocarbons; other than ethylene dibromide (IS[...]</classificationValue>
        </classification>
