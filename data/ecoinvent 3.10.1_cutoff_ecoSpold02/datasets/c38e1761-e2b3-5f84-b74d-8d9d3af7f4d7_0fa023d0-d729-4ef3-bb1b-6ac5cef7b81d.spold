        <activityName xml:lang="en">cement production, CEM III/A</activityName>
        <synonym xml:lang="en">blast furnace cement</synonym>
        <synonym xml:lang="en"> Portlandhüttenzement</synonym>
        <synonym xml:lang="en"> CEM III/A</synonym>
        <synonym xml:lang="en"> Hochofenzement</synonym>
        <includedActivitiesStart xml:lang="en">From cradle, i.e. including all upstream activities. As source of gypsum, waste gypsum from flue gas treatment is assumed.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the cement produced in the cement mill. The dataset does not include packaging and administration.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">The dataset describes the production of cement (CEM III/A)</text>
        </generalComment>
      </activity>
