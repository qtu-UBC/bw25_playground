<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="a5be27de-3202-5e7b-9e4e-257dc6cc0c8b" activityNameId="159cdf69-f5b8-4439-a759-907b9da43b46" parentActivityId="66fd9e36-03d4-47e6-ac08-be06ef3f6167" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">charger production, for electric scooter</activityName>
        <includedActivitiesStart xml:lang="en">The dataset takes as input the various electronic components required to build the charger and includes the components' production efforts. Assembly energy not included due to lack of data.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The dataset returns the assembled device and production waste as a by-product.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset describes the production of a charger suitable for an electric scooter. The entries are given as a function of kg of device. The original data was collected for a device of approximately 3 kg weight. The dataset is based on direct inspection of existing commercial devices of current technology.</text>
        </generalComment>
      </activity>
      <classification classificationId="af350670-f4bc-4b99-a1be-c4710646270c">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2790:Manufacture of other electrical equipment</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2005-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
    <flowData>
      <intermediateExchange id="fae56a2d-8af6-5ab5-b045-3d9af348e6e3" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="RP_amount_1" amount="1.0" intermediateExchangeId="bbd1420d-2c93-45f3-bda3-73ef11d0c3dc" productionVolumeAmount="2350000.0" productionVolumeVariableName="RP_PV_1">
        <name xml:lang="en">charger, for electric scooter</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en"/>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
          <name xml:lang="en">carbon allocation</name>
          <unitName xml:lang="en">kg</unitName>
        </property>
        <property propertyId="a301a838-7975-4d89-9e74-8eb77ad03cd1" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
          <name xml:lang="en">carbon content</name>
          <unitName xml:lang="en">dimensionless</unitName>
        </property>
        <property propertyId="38f94dd1-d5aa-41b8-b182-c0c42985d9dc" amount="143.0" unitId="7b75baf0-cbee-45e6-bf66-af119da06553">
          <name xml:lang="en">price</name>
          <unitName xml:lang="en">EUR2005</unitName>
          <comment xml:lang="en">Calculated value based on estimates and literature. The price of the batterry is 32.06euro/kg. The weight of a battery for an electric scooter is 30kg (producer's information: http://vespino.ch/?page_id=6, accessed 20130726). The market price for an electric scooter is approximatelly 4600euro (producer's information: http://vespino.ch/?page_id=6, accessed: 20130726). It is estimated, that the basic price is 1/3 lower than the market price (expert judgement). The basic price of a scooter without batterry is then calculated to be ((4600*2/3)-(32.06*30)=) 2105euro. The ratio between the price of powertrain and glider in case of electric cars is 1:17 (for more details see the comment field of these products' prices). The resulting prices are 8.4euro/kg of glider, for electric scooter and 142euro/kg of powertrain, for electric scooter. The price is considered to be the same (142euro/kg) for all the parts of the powertrain, such as motor, controller and charger.</comment>
        </property>
        <productionVolumeComment xml:lang="en">Rough estimate based on 1% electric scooters out of 466E6 world two wheeler production projection between 2010 and 2016.(www.electric-bicycle-guide.com)</productionVolumeComment>
        <classification classificationId="39b0f0ab-1a2f-401b-9f4d-6e39400760a4">
          <classificationSystem xml:lang="en">By-product classification</classificationSystem>
          <classificationValue xml:lang="en">allocatable product</classificationValue>
        </classification>
        <classification classificationId="83069466-9f15-4957-b202-bb879168078a">
          <classificationSystem xml:lang="en">CPC</classificationSystem>
          <classificationValue xml:lang="en">49941: Parts and accessories of motorcycles and side-cars</classificationValue>
        </classification>
        <classification classificationId="e024543a-edfb-5c19-946e-144dcc8a2116">
          <classificationSystem xml:lang="en">HS2017</classificationSystem>
          <classificationValue xml:lang="en">850790: Electric accumulators; parts n.e.c. in heading no. 8507</classificationValue>
        </classification>
        <outputGroup>0</outputGroup>
      </intermediateExchange>
