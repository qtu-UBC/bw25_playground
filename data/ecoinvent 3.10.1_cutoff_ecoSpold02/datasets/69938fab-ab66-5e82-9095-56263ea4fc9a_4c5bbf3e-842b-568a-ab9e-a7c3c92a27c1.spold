  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="69938fab-ab66-5e82-9095-56263ea4fc9a" activityNameId="2edaf0a9-d644-45bf-8af1-cf8be8b78163" parentActivityId="df767d60-e686-4283-896d-afef5d134407" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for cooling energy, at -55 °C</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce cooling at -55 °C.
</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the supply of cooling energy to the customers of this product. As this service is considered to be generated and used at the production site, no transport requirements are included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'cooling energy, at -55 °C', in the Global geography.</text>
          <text xml:lang="en" index="2">This market contains no transport or losses, as they are irrelevant for the delivered product.</text>
          <text xml:lang="en" index="3">This product represents cooling energy measured in MJ aiming on cooling process streams at -55°C. The dataset is targeted for industrial-scale cooling systems. </text>
        </generalComment>
      </activity>
      <classification classificationId="be3540ee-592f-46fd-bd68-c362a3bbccc6">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3530:Steam and air conditioning supply</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology/>
      <timePeriod startDate="2017-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
