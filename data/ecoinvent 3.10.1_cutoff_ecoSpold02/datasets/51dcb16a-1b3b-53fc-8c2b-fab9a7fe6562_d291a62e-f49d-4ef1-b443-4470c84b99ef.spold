        <activityName xml:lang="en">treatment of used diesel-electric generating set, 18.5kW</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts when the used diesel-electric generating set enters the waste treatment facility.

The data on energy needed during dismantling are unknown. </includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends by different waste materials being ready for further treatment.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the treatment of used diesel-electric generating set.</text>
        </generalComment>
      </activity>
      <classification classificationId="db303709-3eac-4c8b-9ed9-7e4888240c50">
