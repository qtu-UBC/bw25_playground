<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="a8c70fa4-4d73-5296-a03e-4d321e58c9a6" activityNameId="2d7645b6-0d5f-40d3-bdd0-05098d370e76" parentActivityId="ceddaaf1-c4c1-4354-a4f8-fdb99c0a6b4f" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">benzo[thia]diazole-compound production</activityName>
        <synonym xml:lang="en">Piazthiole(van)</synonym>
        <synonym xml:lang="en">Benzo[c][1,2,5]thiadiazole</synonym>
        <synonym xml:lang="en">Piazthiole</synonym>
        <synonym xml:lang="en">Benzisothiadiazole</synonym>
        <includedActivitiesStart xml:lang="en">From reception of raw materials at the factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the production of 1 kg of benzo[thia]diazole-compound.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of 1 kg of benzo(thia)diazole compounds. Benzo(thia)diazole compounds represent a class of pesticides. This dataset is estimated based on the production of herbicides, using stoichiometric calculations.</text>
          <text xml:lang="en" index="1">References:</text>
          <text xml:lang="en" index="2">Nemecek T. &amp; Kägi T. (2007) Life Cycle Inventories of Swiss and European Agricultural Production Systems. Final report ecoinvent V2.0 No. 15a. Agroscope Reckenholz-Taenikon Research Station ART, Swiss Centre for Life Cycle Inventories, Zurich and Dübendorf, CH.</text>
        </generalComment>
      </activity>
      <classification classificationId="8a45a80b-336f-4a04-95fb-1a1be360d2d3">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2021:Manufacture of pesticides and other agrochemical products</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is modelled for Europe but is assumed to be representative of the global production.</text>
        </comment>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2000-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Time of publications.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
