  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="74ac5074-a097-543d-bb5a-8df8444ce8ec" activityNameId="b874afae-b2b8-47d5-af0f-c37fc64e413d" parentActivityId="d422b7ac-55bc-59e0-b632-5a3c3ce03392" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for clinker</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce 'clinker', within the geography of Ecuador.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'clinker', to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This market represents the 'clinker' for cement in Ecuador.</text>
          <text xml:lang="en" index="2">Transport from producers to consumers of this product in the geography covered by the market is included. In this market, expert judgement was used to develop product specific transport distance estimations.</text>
          <text xml:lang="en" index="3">Clinker is the main constituent of cement and the main responsible for its environmental impacts. Clinker is made by heating at high temperature in a rotary kiln a mixture of limestone and clays.</text>
        </generalComment>
      </activity>
      <classification classificationId="36cd730c-4485-4fe9-8efe-8850f771796d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2394:Manufacture of cement, lime and plaster</classificationValue>
      </classification>
      <geography geographyId="0d0e72a0-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">EC</shortname>
        <comment>
          <text xml:lang="en" index="0">Transportation distance and truck type based on expert opinion specific for Ecuador.</text>
        </comment>
      </geography>
      <technology/>
      <timePeriod startDate="2019-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Time period was set identical to the corresponding transformation activity.</text>
        </comment>
