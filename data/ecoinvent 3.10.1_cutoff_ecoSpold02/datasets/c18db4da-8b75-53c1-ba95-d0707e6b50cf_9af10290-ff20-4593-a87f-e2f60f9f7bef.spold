      <elementaryExchange id="72411460-64c8-56f6-8346-5e13f13fb5b5" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" casNumber="007732-18-5" amount="0.000816521839372613" elementaryExchangeId="67c40aae-d403-464d-9649-c12695e43ad8" formula="H2O">
