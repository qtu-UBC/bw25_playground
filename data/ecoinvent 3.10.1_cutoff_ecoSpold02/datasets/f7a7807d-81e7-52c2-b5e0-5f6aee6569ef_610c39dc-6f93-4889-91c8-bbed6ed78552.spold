      <elementaryExchange id="bbfb7b18-fa59-5902-9354-eb6399f83195" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" casNumber="007732-18-5" amount="0.000816521839372613" elementaryExchangeId="67c40aae-d403-464d-9649-c12695e43ad8" formula="H2O">
