        <shortname xml:lang="en">CH</shortname>
        <comment>
          <text xml:lang="en" index="0">Certain elementary flows or intermediate product flows are RER or GLO modules</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Example representing current metal industrial structures in Switzerland</text>
        </comment>
      </technology>
