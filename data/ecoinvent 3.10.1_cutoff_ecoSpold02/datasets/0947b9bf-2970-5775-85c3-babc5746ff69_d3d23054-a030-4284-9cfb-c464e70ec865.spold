<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="0947b9bf-2970-5775-85c3-babc5746ff69" activityNameId="840812de-d00d-4729-94b9-10908af1ef60" parentActivityId="a7256e03-0264-4829-bb6e-b6c8fa29b5c4" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">coke production, dry quenching</activityName>
        <synonym xml:lang="en">CDQ</synonym>
        <includedActivitiesStart xml:lang="en">Activity starts with the reception of coal at plant-site.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the supply of 1 kg of coke, considering the by-product recovery, to the chinese and global market. Transport is not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This multioutput-process represents the supply of coke by using the dry quenching (CDQ) technology, producing coal gas, coal tar, sulfur and benzene as a byproduct whithin the geography of China.</text>
          <text xml:lang="en" index="1">The dataset is based on the article “Life cycle environmental performance of by-product coke production in China” from Liu, X. and Yuan, Z. (2016).</text>
        </generalComment>
      </activity>
      <classification classificationId="3aa0f2c5-1d26-4f98-8c2c-7406d4b7f2ae">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1910:Manufacture of coke oven products</classificationValue>
      </classification>
      <geography geographyId="0c40fa1e-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">CN</shortname>
        <comment>
          <text xml:lang="en" index="0">Domestic coking coal reserves for coke production are very rich</text>
          <text xml:lang="en" index="1">and centrally distributed in Shanxi, Anhui and Shandong Provinces,</text>
          <text xml:lang="en" index="2">which accounted for approximately 70% of the Chinese total coking</text>
          <text xml:lang="en" index="3">coal resources (Fan, W.T., 2005. Chinese Coking Coal Resources, Production and Quality. China National Coal Association, Beijing, China.) By that it is assumed for the entire country.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Dry quenching is an alternative method of cooling hot coke in the coke production process. Instead of using water, the hot coke is rapidly cooled by circulating an inert gas, such as nitrogen or recycled flue gas, in a sealed chamber. Dry quenching offers benefits such as improved energy efficiency, reduced water consumption, minimized emissions, and enhanced coke quality. It allows for higher production rates, reduces the risk of coke breakage, and is particularly suitable for larger-scale coke plants.</text>
        </comment>
      </technology>
      <timePeriod startDate="2013-01-01" endDate="2024-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
