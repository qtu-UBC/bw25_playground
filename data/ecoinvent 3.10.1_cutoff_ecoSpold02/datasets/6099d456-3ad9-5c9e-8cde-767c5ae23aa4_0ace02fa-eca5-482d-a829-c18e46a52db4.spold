  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="6099d456-3ad9-5c9e-8cde-767c5ae23aa4" activityNameId="71709d2e-445f-46d3-9794-43be953cfa02" parentActivityId="4c1a21f7-5884-4230-bb54-addc57870e4d" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">transport, freight train, electricity</activityName>
        <includedActivitiesStart xml:lang="en">The dataset starts with the production of a locomotive.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Based on Swiss, Chinese and European electric freight train; it includes operation of electric freight train only. This dataset calls the modules 'production, maintenance of vehicle'; 'construction of railway track'.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">Based on Swiss, Chinese and European electric freight train. The datasets represents the entire transport life cycle of an electric freight train.</text>
          <text xml:lang="en" index="1">[This dataset is meant to replace the following datasets:]</text>
        </generalComment>
      </activity>
      <classification classificationId="820a781e-a787-46f3-8ede-6f741c2745d8">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">4912:Freight rail transport</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">Extrapolated from "transport, freight train, electricity, CH 2000", "transport, freight train, electricity, CN 2004" and "transport, freight train, electricity, Europe without Switzerland 2000"</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Average technology</text>
        </comment>
      </technology>
      <timePeriod startDate="1999-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
