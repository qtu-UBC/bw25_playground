    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">This dataset has been extrapolated from respective regional geographies (RER). Data were collected from the producers by CCB (Cepi ContainerBoard)and FEFCO (European Federation of Corrugated Board Manufacturers) for the European Database for Corrugated Board Life Cycle Studies), checked by technical experts and reviewed by the Institut für Energie- und Umweltforschung Heidelberg (ifeu). The data for the production of Testliner and Wellenstoff were collected from mills, which together represent about 71 % of the total yearly production of corrugated base papers from recovered paper in Europe. Reference(s): FEFCO. 2021. European Database for Corrugated Board Life Cycle Studies 2021. Reference(s): https://www.fefco.org/sites/default/files/documents/2022-07-07_FEFCO%20LCA%202021.pdf, last acessed March 2023</samplingProcedure>
        <extrapolations xml:lang="en">This dataset has been extrapolated from respective regional geographies (RER). Additional air emissions from the combustion of fossil fuels estimated based on industrial heating datasets from the ecoinvent database and matched as follows: light fuel oil and diesel: heat production, light fuel oil, at industrial furnace 1MW, Europe without Switzerland; heavy fuel oil: heat production, heavy fuel oil, at industrial furnace 1MW, Europe without Switzerland; Coal: heat production, at hard coal industrial furnace 1-10MW, Europe without Switzerland; natural gas, LPG and biogas and biosludges: heat production, natural gas, at industrial furnace &gt;100kW, Europe without Switzerland; lignite: heat production, lignite briquette, at stove 5-15kW, Europe without Switzerland; Biofuel (bark. scrap wood. tall oil): heat production, wood chips from industry, at furnace 1000kW, CH; refused derived fuel, biomass: heat production, wood chips from post-consumer wood, at furnace 300kW Emissions of stemming from biogas were approximated with the combustion of natural gas, whereby CO2, CO and CH4 emissions stemming from biogas were modelled as non-fossil.</extrapolations>
      </representativeness>
      <review reviewedMajorRelease="3" reviewedMinorRelease="0" reviewedMajorRevision="0" reviewedMinorRevision="1" reviewerId="847a56f5-d9e5-4a65-ab51-b056e0039130" reviewerName="Avraam Symeonidis" reviewerEmail="Symeonidis@ecoinvent.org" reviewDate="2023-09-06">
        <otherDetails xml:lang="en"/>
      </review>
