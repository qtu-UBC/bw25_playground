<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="7b18dd55-6d46-5fbe-8a41-8f76cfa53131" activityNameId="292f7b09-f9a2-4733-aa5d-be7ab74cb86c" parentActivityId="2a931841-b8d0-4e65-978b-a99aa857a1cc" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">fibre production, jute, retting</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts with the immersion of the jute plant bundles into the water.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the extraction of the jute fibres from the retted plants. In Bangladesh, Single Stem Stripping is mostly used to extract fibres. It is done manually by hand. The Jute Fibre is then gets dried in the sun.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">In practice, jute retting activity involves immersion of the bundles of jute into stagnant water in the jute cultivation field, tanks, ponds, ditches etc., or in slowly flowing clear water in canals, rivulets, rivers etc. After several days of immersion, the jute fibre gets loosen from the stalk and is extracted from the jute stalk which becomes the byproduct.</text>
          <text xml:lang="en" index="1">This dataset serves as the transformation process of jute plant to fibre. </text>
          <text xml:lang="en" index="2">[This dataset was recalculated on 20230912, since the BD dataset was corrected on the same period.]</text>
        </generalComment>
      </activity>
      <classification classificationId="57576906-1fe0-4105-b904-91f03d66057f">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1311:Preparation and spinning of textile fibres</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">This dataset is a weighted average built from the following geographies: BD, IN.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">The retting activity is usually accomplished either on the jute growing field or in canals, by immersion of the bundles of jute into stagnant water.</text>
        </comment>
      </technology>
      <timePeriod startDate="2016-03-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
