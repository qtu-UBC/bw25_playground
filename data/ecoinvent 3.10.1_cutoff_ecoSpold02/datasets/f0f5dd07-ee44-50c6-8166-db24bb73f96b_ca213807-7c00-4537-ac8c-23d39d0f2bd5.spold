    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Inventory data for the RER dataset were collected for the year 2021 ("corrugated board box production, RER" with main reference: FEFCO. 2021. European Database for Corrugated Board Life Cycle Studies. 2021. &lt;https://www.fefco.org/sites/default/files/documents/Fefco_AnnualEvaluation_2021_0.pdf &gt;, accessed March 2023). Data for the CA-QC dataset represent the year 2008 ("corrugated board box production, CA-QC", main data source is data from a manufacturing plant located in the region of Québec,) and data for the US represent the year 2014 ("corrugated board box production, US", main source NCASI, 2017).</samplingProcedure>
        <extrapolations xml:lang="en">This dataset was built as a weighted average of regional datasets of the same activityName.  Weights are based on production volumes.
US: production volume = 2.68e+10 kg/year, weight = 0.48031
RER: production volume = 2.80e+10 kg/year, weight = 0.50181
CA-QC: production volume = 9.97e+08 kg/year, weight = 0.01786</extrapolations>
      </representativeness>
