  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="f0f5dd07-ee44-50c6-8166-db24bb73f96b" activityNameId="d8fbd861-07be-493d-925d-8a41488a486f" parentActivityId="66d129e4-e609-5533-842a-eecccaca32bd" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">corrugated board box production</activityName>
        <includedActivitiesStart xml:lang="en">The process starts with the feeding of linerboard and corrugated medium to converting facilities.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with a mix of folded and unfolded boxes which are then ready for delivery.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset was built as a weighted average of regional datasets of the same activityName.  Weights are based on production volumes.</text>
          <text xml:lang="en" index="1">US: production volume = 2.68e+10 kg/year, weight = 0.48031</text>
          <text xml:lang="en" index="2">RER: production volume = 2.80e+10 kg/year, weight = 0.50181</text>
          <text xml:lang="en" index="3">CA-QC: production volume = 9.97e+08 kg/year, weight = 0.01786</text>
          <imageUrl index="4">https://db3.ecoinvent.org/images/fb7c96f2-1933-4a81-a33a-515d0a5fb151</imageUrl>
        </generalComment>
      </activity>
      <classification classificationId="5682ee05-067a-4dd3-a2b5-93f3f1d25c75">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1702:Manufacture of corrugated paper and paperboard and of containers of paper a</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
