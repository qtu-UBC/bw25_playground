<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="2374a52b-836b-53bd-acdc-188a7b7daa94" activityNameId="0b0caf44-d39d-4062-b16e-48b62aa5e93d" parentActivityId="269be4b8-8ca9-5c88-92ea-76a9d5c75c2c" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">tillage, rotary cultivator</activityName>
        <includedActivitiesStart xml:lang="en">Cultivator tillage process starting from preliminary work at farm, like attaching the adequate machinery to the tractor</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with transfer back to farm and concluding work, like uncoupling the machine; The dataset includes transfer to field; field work for an area of land of 1 ha, including turning, idling and overlapping. Also taken into consideration is the amount of emissions to the air from combustion and the emission to the soil from tyre abrasion during the work process. The dataset doesn`t include dust other than from combustion and noise.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the service of cultivating 1 ha of agricultural land with a rotary cultivator. An average machinery width of 7.8 m, working at a depth of 5 cm, is considered.</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is extrapolated from the geography of Quebec, Canada. Data quality indicators are adjusted accordingly.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Fuel consumption and emissions per kg diesel have been extrapolated to the US, but others inputs were taken from the original values.</text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
