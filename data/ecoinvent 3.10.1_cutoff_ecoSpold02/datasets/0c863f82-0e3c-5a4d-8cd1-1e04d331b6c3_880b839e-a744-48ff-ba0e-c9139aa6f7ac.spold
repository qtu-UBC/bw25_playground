<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="0c863f82-0e3c-5a4d-8cd1-1e04d331b6c3" activityNameId="da1e0cde-7047-434a-a1ec-a801b00d18b7" parentActivityId="0c1a1e54-ec70-4463-8cdd-614ae4681cc6" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">furnace production, logs, 6kW</activityName>
        <synonym xml:lang="en">wood stove production</synonym>
        <synonym xml:lang="en"> wood burning stove production</synonym>
        <includedActivitiesStart xml:lang="en">From reception of furnace components at the factory gate</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the disposal of the device in the end of its lifetime.The dataset includes the most important materials used for the fabrication of the stove and the chimney flue pipes: steel, cast iron, rock wool, lubricating oil, glass, refractory fireclay. It includes also the energy and heat for the construction and the disposal of the elements of the furnace. The dataset doesn't include the basement in concrete for the stove installation (not necessary) and any covers (e.g. ceramic tiles or stone). Since it is used for domestic heating, transformation and land occupation are not considered.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represent the production and the disposal of a wood burning stove for domestic heating (small furnace for room heating).</text>
        </generalComment>
        <tag>biomass power</tag>
      </activity>
      <classification classificationId="844bb5bd-c3ab-491d-bd6b-baea2f2ba27b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2815:Manufacture of ovens, furnaces and furnace burners</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
      </geography>
      <technology technologyLevel="2">
        <comment>
          <text xml:lang="en" index="0">Wood stove of modern technology, available on European and Swiss market, designed for an optimal combustion process. The model of reference is the stove mod.Bando from the Swiss brand Attika (without stone covering). Represent the typical stove for residential wood combustion in a domestic environment.</text>
          <imageUrl index="1">https://db3.ecoinvent.org/images/3745beb2-28e9-436c-9856-a2081f7f0a71</imageUrl>
          <text xml:lang="en" index="2">Source of the image: http://www.attika.ch/uebersicht_kaminoefen.php</text>
        </comment>
      </technology>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">This stove model is commercialized since 2010 in Switzerland and is still available on the market (end 2011)</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
