      <elementaryExchange id="ea4c6ef6-6467-53c7-82ff-a0f1603a9c52" unitId="1017f68a-f818-4f9d-a34d-a31e7386f628" amount="0.0653061224489796" isCalculatedAmount="true" mathematicalRelation="10000/(30625*5)" elementaryExchangeId="e717f3cc-ac70-4c9b-be56-1614239b917e">
        <name xml:lang="en">Transformation, from forest, intensive</name>
        <unitName xml:lang="en">m2</unitName>
        <comment xml:lang="en">Value has been calculated based on an average yearly harvest of 30,625 kg per hectare. The value is specific for Guadua Angustifolia Kuhnt bamboo. Guadua Angustifolia Kunth is mostly of natural regeneration. The plant needs generally 8 years before being harvested (more than 9 cm in diameter). Once the forest produces commercial culms, the harvest can be annual. Even, depending on the cutting plan, it can take place twice a year. The harvest is selective of the culms that are 5 years old, but while these are cut, new shoots emerge (every year) so the harvest is continuous. Approximately 25% of the commercial culms are extracted each year.</comment>
        <uncertainty>
          <lognormal meanValue="0.0653061224489796" mu="-2.728669488304946" variance="0.12" varianceWithPedigreeUncertainty="0.130825"/>
          <pedigreeMatrix reliability="3" completeness="3" temporalCorrelation="2" geographicalCorrelation="2" furtherTechnologyCorrelation="3"/>
        </uncertainty>
