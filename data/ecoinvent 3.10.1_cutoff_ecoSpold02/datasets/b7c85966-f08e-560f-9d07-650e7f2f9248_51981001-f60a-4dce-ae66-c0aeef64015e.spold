    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">This data is based on the dataset "bamboo forestry, sustainable forest management, CO, 2010-2020" available in ecoinvent v.3.9.1, due to its similarities with Ecuador and the fact that the bamboo species is the same (Guadua Angustifolia Kuhnt).</samplingProcedure>
        <extrapolations xml:lang="en">The input of bamboo is approximated with “wood, unspecified, standing”. The properties have been modified in order to reflect bamboo (Species: Guadua angustifolia Kunth). The data is based on Colombia (CO) original dataset due to the similarities with Ecuador and the fact that the bamboo specie is the same (Guadua Angustifolia Kuhnt).</extrapolations>
      </representativeness>
