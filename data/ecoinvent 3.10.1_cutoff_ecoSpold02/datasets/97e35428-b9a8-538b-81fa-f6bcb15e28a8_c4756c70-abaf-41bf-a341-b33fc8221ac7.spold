      <elementaryExchange id="4919a78e-7976-5ead-8877-d83621e5bba0" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="000124-38-9" amount="0.12747" elementaryExchangeId="f9749677-9c9f-4678-ab55-c607dfdc2cb9" formula="CO2">
        <name xml:lang="en">Carbon dioxide, fossil</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">The remaining amount of unreacted o-nitropohenol is assumed to leave the production process with the wastewater. Further it is assumed that this wastewater is treated in a internal wastewater plant. The removal efficiency for o-nitropohenol is assumed with 100%. The carbon contained in the removed o-nitropohenol is accounted as CO2 emissions to air. The nitrogen in the removed o-nitropohenol is accounted as nitrogen emission to air.</comment>
        <uncertainty>
          <lognormal meanValue="0.12747" mu="-2.0598742361873073" variance="0.0006" varianceWithPedigreeUncertainty="0.17859999999999998"/>
          <pedigreeMatrix reliability="4" completeness="5" temporalCorrelation="5" geographicalCorrelation="5" furtherTechnologyCorrelation="5"/>
          <comment xml:lang="en">Estimation</comment>
        </uncertainty>
        <synonym xml:lang="en">Carbon dioxide</synonym>
