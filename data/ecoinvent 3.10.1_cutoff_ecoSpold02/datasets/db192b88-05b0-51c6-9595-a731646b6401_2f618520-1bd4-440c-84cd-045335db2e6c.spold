<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="db192b88-05b0-51c6-9595-a731646b6401" activityNameId="8737c948-38b7-4cd8-8a0b-04a1941365c2" parentActivityId="91d4ac48-fe95-59ad-a7b7-58dd4b9d0d25" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">tillage, harrowing, by offset disc harrow</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts from the agricultural field foreseen to be processed.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with harrowing. The dataset includes the diesel fuel consumption and the amount of agricultural machinery and shed. Also taken into consideration is the amount of emissions to the air from diesel combustion and the emission to the soil from tyre abrasion during the work process.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the harrowing operation, by offset disc harrow in one hectare (ha). This tillage operation is mainly performed to break up the surface of the soil and to incorporate the limestone and gypsum. Functional Unit (FU) is one hectare of tillage harrowing. The operation time is about 1.38 hours per ha (62.5% of this time is effectively worked, discounting time for maintenance, waiting in the field and re-allocations between the plots).</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is extrapolated from the Global geography. Data quality indicators from adjusted accordingly.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Fuel consumption and emissions per kg diesel have been extrapolated to the US, but others inputs were taken from the original values.</text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
