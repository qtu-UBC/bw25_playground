<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="61f282b5-c364-55d6-9592-4c9ac4bb0534" activityNameId="87f92aec-77a0-5673-a0ab-cd19d331d159" parentActivityId="5861873a-7e3f-5b5b-a8ff-d392c250070e" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">application of plant protection product, by airplane</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts from the agricultural field foreseen to be processed.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the application of plant protection product. The inventory includes the airplane input, kerosene consumption, and emissions from the fuel. The amount of protection products is not taken into account.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the application of protection product by an agricultural airplane in one hectare (ha). The Functional Unit (FU) is one hectare and the operation time is about 0.00625 hour per ha. Plant protection product is not included. This is a service activity. </text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is modeled for agricultural production system in the United States.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">This activity is performed by an agricultural airplane, with a weight of 2012 kg and an operation capacity of 160ha/hour. </text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
    <flowData>
