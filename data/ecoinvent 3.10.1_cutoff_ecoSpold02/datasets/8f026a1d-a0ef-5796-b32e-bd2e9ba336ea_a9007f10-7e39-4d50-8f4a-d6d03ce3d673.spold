    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce" percent="100.0">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">The distance of the GASBOL pipeline, which connects Bolivian production fields to the Brazilian boarder, is reported in the Monthly Bulletin of the Natural Gas Industry (MME, 2018).
Reference:
[MME 2018] 
Ministry of Mines and Energy (2019). Monthly Bulletin of the Natural Gas Industry. December 2018. Edition number 142. Available at: http://www.mme.gov.br/web/guest/secretarias/petroleo-gas-natural-ebiocombustiveis/publicacoes/boletim-mensal-de-acompanhamento-da-industria-de-gas-natural. Accessed in: 10/06/2020.</samplingProcedure>
        <extrapolations xml:lang="en">Gas losses and emissions during seasonal storage are extrapolated from the ‘natural gas, high pressure, import from NO’ dataset for The Netherlands, valid for the year of 2012, available in database version 3.6. The uncertainties were adjusted accordingly.</extrapolations>
      </representativeness>
