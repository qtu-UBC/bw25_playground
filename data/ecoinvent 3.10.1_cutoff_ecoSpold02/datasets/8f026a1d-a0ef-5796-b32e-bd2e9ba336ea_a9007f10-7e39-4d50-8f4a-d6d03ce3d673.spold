<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="8f026a1d-a0ef-5796-b32e-bd2e9ba336ea" activityNameId="29de059e-bb1c-426a-a5b0-2904e830309d" parentActivityId="cb62bfb1-96c2-58cf-8175-2bd66a9eb1a7" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">natural gas, high pressure, import from BO</activityName>
        <includedActivitiesStart xml:lang="en">'exit gate' of natural gas production field</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">'entry gate' of natural gas national market (i.e., at the BO-BR border)</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset describes the transport needed for the export of Bolivian natural gas (expressed in tkm). Gas losses and emissions during seasonal storage are extrapolated from the ‘natural gas, high pressure, import from NO’ dataset for The Netherlands, valid for the year of 2012, available in database version 3.6. The GASBOL onshore pipeline distance is 557 km for the export on the Bolivian side, i.e., the length of the Bolivian pipeline section (MME, 2018).</text>
          <text xml:lang="en" index="1">[MME 2018]</text>
          <text xml:lang="en" index="2">Ministry of Mines and Energy (2019). Monthly Bulletin of the Natural Gas Industry. December 2018. Edition number 142. Available at: http://www.mme.gov.br/web/guest/secretarias/petroleo-gas-natural-ebiocombustiveis/publicacoes/boletim-mensal-de-acompanhamento-da-industria-de-gas-natural. Accessed in: 10/06/2020.</text>
          <text xml:lang="en" index="3">Characteristics are based on the ecoinvent report v2 'Erdgas' from 2007: HV; 44.21 MJ/m-3; density, 0.84 kg/m-3, 0.719 kg CH4/m-3, 0.013 kg CO2/m-3</text>
        </generalComment>
      </activity>
      <classification classificationId="4bb326bb-e3df-4d71-b77c-f9a2f7e55536">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">4930:Transport via pipeline</classificationValue>
      </classification>
      <geography geographyId="0a2c8c66-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">BR</shortname>
        <comment>
          <text xml:lang="en" index="0">Brazil.</text>
        </comment>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2018-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Pipeline distance and production are updated to the year of 2018. Gas losses and emissions during seasonal storage are extrapolated from the ‘natural gas, high pressure, import from NO’ dataset for The Netherlands, valid for the year of 2012, available in database version 3.6. Data is assumed to be valid from 2018 to 2021.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
