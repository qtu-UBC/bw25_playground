      <elementaryExchange id="817c2dff-e053-50af-b49f-d61b45536115" unitId="1017f68a-f818-4f9d-a34d-a31e7386f628" amount="0.307054187104951" elementaryExchangeId="4b420f19-0421-461e-a0b6-7efbf580089b">
        <name xml:lang="en">Transformation, from annual crop, non-irrigated</name>
        <unitName xml:lang="en">m2</unitName>
        <comment xml:lang="en">Transformation of land for planting.  Land is under rotation with other annual crop production (~80% corn-soy, ~20% corn-corn, Socolar et al 2021). US NRCS data indicates that land is leaving agricultural production rather than being transitioned into it, thus the continuous flux to/from annual crop is effectively steady state. Annual production averaged  0.2  million tonnes from  2016-2021 on . million ha planted and . million ha harvested. Thus occupation is 0.709 ha/t or 7090.176 m2/t (0.7.09m2/kg). This overall land use is split into irrigated ( 56.69% ) and non-irrigated ( 43.3% ) based on agricultural census data ( USDA NASS ) 4.02E-1 m2 planted/kg harvested maize of irrigated land, and 3.07E-1 m2 planted/kg harvested maize of non-irrigated land</comment>
        <uncertainty>
          <lognormal meanValue="0.307054187104951" mu="-1.1807310417423014" variance="0.008" varianceWithPedigreeUncertainty="0.0089"/>
          <pedigreeMatrix reliability="2" completeness="2" temporalCorrelation="2" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
