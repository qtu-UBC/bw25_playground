<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="b93b9fc1-2e00-5947-a634-b6a40f9876f6" activityNameId="d5c63e04-91a1-4a4e-af3f-08970ebb79f5" parentActivityId="317ead7c-af29-4885-93b3-4eb90849b474" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">treatment of waste plaster-cardboard sandwich, collection for final disposal</activityName>
        <synonym xml:lang="en"> selenite</synonym>
        <synonym xml:lang="en"> alabaster</synonym>
        <synonym xml:lang="en">calcium sulfate dihydrate (has  CAS 10101-41-4)</synonym>
        <synonym xml:lang="en"> natural gypsum (has CAS 13397-24-5</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts when the building demolition activity is ready to be performed. Transportation of the waste to the treatment plant is not included.
</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity includes energy for dismantling, particulate matter emissions from dismantling and handling, and final disposal of waste material.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">The process represents the collection of 'waste plaster-cardboard sandwich' for final disposal. The waste contains 0.834kg gypsum and 0.166kg cardboard, while its density is 1000 kg/m3. </text>
        </generalComment>
      </activity>
      <classification classificationId="9a63625a-358b-4c1d-bf95-50ba038a759b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3821:Treatment and disposal of non-hazardous waste</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">Modelling parameters are not specific to this geography.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Building demolition with skid-steer loaders.</text>
        </comment>
      </technology>
      <timePeriod startDate="1994-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
