      <intermediateExchange id="675e2d50-82ea-54d1-8699-00d8f6f9a4ef" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="007722-76-1" amount="0.00405588483850066" intermediateExchangeId="d1567df0-6921-5a69-adb0-71cacf11683c" activityLinkId="af317044-6689-57af-bf74-129120fc4910">
        <name xml:lang="en">monoammonium phosphate</name>
