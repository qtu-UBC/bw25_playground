<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="3ede0c75-6dff-5325-a6a1-e3c74e465bf8" activityNameId="82a25026-09cc-484f-a9bd-e13a64160bd7" parentActivityId="12ca1bae-dc00-4971-8e81-5decb3e1387a" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">inductor production, ring core choke type</activityName>
        <includedActivitiesStart xml:lang="en">From reception of metals, plastics at the factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This dataset includes raw material input and production efforts for the production of currently used ring core choke type inductors.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of 1 kg of ring core choke type inductors. It is based on the assumption that a typical ring core choke inductor electronic module has an average weight of 6 g. The data represent a typical ring core choke type inductor used in the information and communication technology. Material data are taken from datasheets of producers of such inductors and from the literature. Infrastructure and production efforts are based on own assumptions. The production efforts represent not a specific inductor type and have thus, accordingly higher uncertainties.</text>
        </generalComment>
      </activity>
      <classification classificationId="49f4c661-1394-4116-a572-ea9b4d04b235">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2610:Manufacture of electronic components and boards</classificationValue>
      </classification>
      <classification classificationId="6488bf8b-d05f-4a0e-adcb-1fa34e691ab8">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">electronics/component</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
        <comment>
          <text xml:lang="en" index="0">Data represent a global valuable composition of ring core choke type inductors.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">average production comprising the following steps: core mounting; epxoy-curing; winding; welding; molding; marking; bending; testing and final control.</text>
        </comment>
      </technology>
      <timePeriod startDate="2005-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
    <flowData>
      <intermediateExchange id="8ffaa5a7-cdd7-5425-8978-2bfc046c1ac0" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" amount="1.0" intermediateExchangeId="3c3632b8-ce5b-4957-ac59-54e931ccd247" productionVolumeAmount="1.0">
        <name xml:lang="en">inductor, ring core choke type</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Inductors are used extensively in analog circuits and signal processing, in conjunction with capacitors and other components form tuned circuits which can emphasize or filter out specific signal frequencies. This can range from the use of large inductors as chokes in power supplies, now obsolete, which in conjunction with filter capacitors remove residual hum or other fluctuations from the direct current output, to such small inductances as generated by a ferrite bead or torus around a cable to prevent radio frequency interference from being transmitted down the wire. Smaller inductor/capacitor combinations provide tuned circuits used in radio reception and broadcasting, for instance. (Wikipedia (2007))
EcoSpold01Location=GLO</comment>
