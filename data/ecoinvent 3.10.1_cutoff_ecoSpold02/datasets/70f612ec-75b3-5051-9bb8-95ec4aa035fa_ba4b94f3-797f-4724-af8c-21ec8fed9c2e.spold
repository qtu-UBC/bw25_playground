<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="70f612ec-75b3-5051-9bb8-95ec4aa035fa" activityNameId="911db675-3f5d-4038-86c5-a1c96aa34316" parentActivityId="f802470a-a9ee-522c-95d2-5fa998947e56" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">swath, by rotary windrower</activityName>
        <includedActivitiesStart xml:lang="en">The rotary windrower process starts with preliminary work at the farm, like attaching the adequate machine to the tractor.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with transfer back to farm and concluding work, like uncoupling the machine. The inventory includes transfer to field; field work (for a parcel of land of 1 ha surface); the diesel fuel consumption and the amount of agricultural machinery and of the shed, which has to be attributed to the swathing. Also taken into consideration is the amount of emissions to the air from combustion and the emission to the soil from tyre abrasion during the work process. The overlapping during the field work is considered. The amount of swathed good is not taken into account. Not included are dust other than from combustion and noise.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the use of rotary windrower for one hectare. The working width is 4.0 m (average).</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is extrapolated from the geography of Quebec, Canada. Data quality indicators are adjusted accordingly.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Fuel consumption and emissions per kg diesel have been extrapolated to the US, but others inputs were taken from the original values.</text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
