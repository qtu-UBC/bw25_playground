        <property propertyId="38f94dd1-d5aa-41b8-b182-c0c42985d9dc" amount="3.46" unitId="7b75baf0-cbee-45e6-bf66-af119da06553">
          <name xml:lang="en">price</name>
          <unitName xml:lang="en">EUR2005</unitName>
          <comment xml:lang="en">Assumed same price as pesticide, unspecified. Price calculated by Thomas Nemecek. The price is assumed to be equal to the import price of crude oil. According to http://www.iea.org/textbase/stats/surveys/mps.pdf  - Take the average prices of 4 countries in EU; 1 ton of crude oil  = 1 metric ton of crude oil = appr. 7.3 barrels of crude oil (assuming a specific gravity of 33 API) (http://www.eppo.go.th/ref/UNIT-OIL.html downloaded 4 July 2009).</comment>
        </property>
        <property propertyId="a9358458-9724-4f03-b622-106eda248916" amount="0.0" isDefiningValue="true" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
