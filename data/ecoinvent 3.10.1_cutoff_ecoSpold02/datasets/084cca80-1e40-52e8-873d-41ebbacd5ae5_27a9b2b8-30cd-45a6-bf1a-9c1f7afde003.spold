  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="084cca80-1e40-52e8-873d-41ebbacd5ae5" activityNameId="a49928c7-de6d-48f9-86b2-8daff36c7078" parentActivityId="c4c47dea-6cd0-4628-a0ff-c48bab6b4e5b" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">treatment of waste gypsum, inert material landfill</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts with the waste being available at the gate of the treatment facility. Collection and transportation of the waste to the treatment plant is not included.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the waste being treated and no direct emissions from inert material landfill (leachate) are inventoried, as they are considered negligible. The dataset contains only exchanges to process-specific burdens (energy, land use) and infrastructure.             </includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the activity of waste disposal of 'waste gypsum'  in an inert material landfill.</text>
        </generalComment>
      </activity>
      <classification classificationId="9a63625a-358b-4c1d-bf95-50ba038a759b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3821:Treatment and disposal of non-hazardous waste</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">Modelling parameters affecting the treatment technology are not specific to this geography.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Inert material landfill with leachate collection system and renaturation after closure. 50% of the sites is equipped with a base seal.</text>
        </comment>
      </technology>
      <timePeriod startDate="1995-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
