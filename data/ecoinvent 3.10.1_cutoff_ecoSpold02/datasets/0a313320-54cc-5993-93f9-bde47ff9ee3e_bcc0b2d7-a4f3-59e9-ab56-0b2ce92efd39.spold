    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce" percent="80.0">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Industry data, representative for 80 % of the short chain polyether polyols coverage in terms of production volumes in the EU region in 2018.

The industrial data used originate from three different polyether polyols producers with four plants in three different European countries. </samplingProcedure>
        <extrapolations xml:lang="en">Small input quantities of (i) generic or specific stabilizer (calcium stearate), (ii) magnesium silicate, (iii) antioxidant, (iv) dipropylene glycol, and (v) cellulose, with a representation on dry mass input lower than 0.7%, was cut-off. 
</extrapolations>
      </representativeness>
