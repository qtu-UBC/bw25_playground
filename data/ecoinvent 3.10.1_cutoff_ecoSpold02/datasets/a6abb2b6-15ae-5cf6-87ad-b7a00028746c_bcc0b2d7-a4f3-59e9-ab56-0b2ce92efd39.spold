  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="a6abb2b6-15ae-5cf6-87ad-b7a00028746c" activityNameId="79d896ab-6aaf-401d-b9c9-68f1cd903615" parentActivityId="905f21de-b5ca-4ac8-a121-0b300b201d93" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for polyether polyols, long chain</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce 'long chain polyether polyols' within the geography of Europe.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'long chain polyether polyols', to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'long chain polyether polyols, in the European geography.</text>
          <text xml:lang="en" index="2">'long chain polyether polyol' represents an organic substance with a generic molecular formula of: HO--(AO)m ZO--(BO)n –H  whereas A, B and Z are organic rests. It is waxy solid under normal conditions of temperature and pressure with a molecular weight over 1000 g/mol There are no publicly available information about the consumption of this substance on a consumer level. On industrial sites, the substance is used with TDI to produce flexible polyurethane foams.</text>
        </generalComment>
      </activity>
      <classification classificationId="4a11cbd4-74bf-47fb-9fe5-6e97e3db136b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2013:Manufacture of plastics and synthetic rubber in primary forms</classificationValue>
      </classification>
      <geography geographyId="0723d252-7e2a-11de-9820-0019e336be3a">
        <shortname xml:lang="en">RER</shortname>
      </geography>
      <technology/>
      <timePeriod startDate="2023-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
