<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="3ebc51ab-b28e-5e9e-9167-8dfb8c1ad85d" activityNameId="d4e439a5-f8cd-41cd-8baa-ac27abbdd8b3" parentActivityId="8e3d278d-21f2-4852-abb3-f8ddb2446b28" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">polyacrylamide production</activityName>
        <includedActivitiesStart xml:lang="en">Starts with the delivery of material and energy inputs on site.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the production of polyacrylamide.
This dataset includes raw materials, energy uses, infrastructure. Further inputs (in particular, nitrile hydratase enzyme for the hydrolysis of acrylonitrile into acrylamide), solid wastes and emissions are excluded.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the combined production of acrylamide and its polymerization into polyacrylamide from the basic chemical reactants (acrylonitrile and water) for acrylamide production. This is a rough estimation created for the Tap water production dataset. Polyacrylamide, in the straight-chain form, is a not toxic thickener and suspending agent. It is an important flocculant in the water treatment industry.  </text>
        </generalComment>
      </activity>
      <classification classificationId="7ac1cbc6-1385-4a68-8647-ed7aa78db201">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">chemicals/organics</classificationValue>
      </classification>
      <classification classificationId="28f738cc-bb73-48f8-b633-f83fb9bc5ddc">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2011:Manufacture of basic chemicals</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Idealized reaction of acrylonitrile with water to give acrylamide which is then polymerized (chain-growth polymerization) to form the homopolymer polyacrylamide: C3H3N + H2O =&gt; C3H5NO =&gt; (C3H5NO)n</text>
        </comment>
      </technology>
      <timePeriod startDate="2012-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
