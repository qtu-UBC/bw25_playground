        <activityName xml:lang="en">granulated blast furnace slag to generic market for supplementary cementitious materials</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts with the input of GGBFS.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">With the provision of a generic kg of supplementary cementitious materials.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This activity is a renaming activity, linking granulated blast furnace slag to the generic market for supplementary cementitious materials (SCM).</text>
        </generalComment>
      </activity>
