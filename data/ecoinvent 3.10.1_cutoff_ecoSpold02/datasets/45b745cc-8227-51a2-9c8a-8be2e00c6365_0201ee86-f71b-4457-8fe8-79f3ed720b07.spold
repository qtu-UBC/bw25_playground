<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="45b745cc-8227-51a2-9c8a-8be2e00c6365" activityNameId="d5dbf2cc-a70e-4794-bd89-fc871cafb882" parentActivityId="9e163c53-512a-55f3-8445-e955588492f4" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for wheat grain</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts at the gate of wheat grain cultivation farm.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'wheat grain', to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for 'wheat grain', in the geography of Queensland state in Australia.</text>
          <text xml:lang="en" index="2">This dataset represents the transport of 1 kg of wheat grain from the farm to the corresponding market, i.e. whole wheat processing facility (dry mill) . No losses are considered in this dataset.</text>
          <text xml:lang="en" index="3">The product 'wheat grain' is a grain. It is an annual crop. The ecoinvent database also contains this product from organic and Swiss integrated production.</text>
        </generalComment>
      </activity>
      <classification classificationId="e2e1f67d-3393-4182-86f6-1ada2f77c3e5">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0111:Growing of cereals (except rice), leguminous crops and oil seeds</classificationValue>
      </classification>
      <geography geographyId="3624a72f-ca5a-48d6-be41-27e705be5b61">
        <shortname xml:lang="en">AU-QLD</shortname>
        <comment>
          <text xml:lang="en" index="0">Data represent the situation in Queensland state in Australia.</text>
        </comment>
      </geography>
      <technology/>
      <timePeriod startDate="2011-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The time period is the same as the in transforming activity for the same reference product.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
