  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="01c99d93-cacc-5eba-8e86-38386f157cbd" activityNameId="fbabf3b9-9551-429d-b1e2-dd61c0d19346" parentActivityId="8f916918-50fc-4332-84e6-a13a0211dbd9" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">insulated gate bipolar transistor production, for electric vehicle applications</activityName>
        <includedActivitiesStart xml:lang="en">The dataset takes as input the various electronic components required to build the transistor and includes the components' production efforts. Assembly energy not included due to lack of data.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The dataset returns the assembled device and production waste as a by-product.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset describes the production of an insulated gate bipolar transistor (IGBT) used in the power electronics of electric vehicles. It is based on the direct inspection of a commercial device.</text>
        </generalComment>
      </activity>
      <classification classificationId="49f4c661-1394-4116-a572-ea9b4d04b235">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2610:Manufacture of electronic components and boards</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2005-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
