          <classificationSystem xml:lang="en">CPC</classificationSystem>
          <classificationValue xml:lang="en">47150: Diodes, transistors and similar semi-conductor devices; photosensitive semi-conductor devices; light emitting […]</classificationValue>
        </classification>
        <classification classificationId="eb368236-8380-5f44-b4b2-536254bd8a41">
          <classificationSystem xml:lang="en">HS2017</classificationSystem>
          <classificationValue xml:lang="en">854129: Electrical apparatus; transistors, (other than photosensitive), with a dissipation rate of 1W or more</classificationValue>
        </classification>
        <outputGroup>0</outputGroup>
      </intermediateExchange>
