        <property propertyId="38f94dd1-d5aa-41b8-b182-c0c42985d9dc" amount="14.0" unitId="7b75baf0-cbee-45e6-bf66-af119da06553">
          <name xml:lang="en">price</name>
          <unitName xml:lang="en">EUR2005</unitName>
          <comment xml:lang="en">Calculated based on literature values and estimates. The producer's price of a bicycle in Europe is approximatelly 100 Euro (UN Commodity trade database). The average purchaser's price of a bicycle in Europe is approximatelly 300 Euro (estimated based on; Association of the European Two-Wheeler Parts' &amp; Acessories' Industry, http://www.ziv-zweirad.de/public/european-bicycle-market-industry-profile-2010.pdf). The purchaser's price of an electric scooter is app. 4600 Euro (estimated based on producer's information; http://vespino.ch/?page_id=6) for electric scooter which weight 110kg. The purchaser's price is thus (1/110*4600=) 41.8 Euro/kg. The producer's price is calculated as 1/3 of the purchaser's price (based on the information on bicycles) (1/3*41.8=)  14 Euro/kg.</comment>
        </property>
        <productionVolumeComment xml:lang="en">Rough estimate based on 1% electric scooters out of 466E6 world two wheeler production projection between 2010 and 2016.(www.electric-bicycle-guide.com)</productionVolumeComment>
        <classification classificationId="39b0f0ab-1a2f-401b-9f4d-6e39400760a4">
          <classificationSystem xml:lang="en">By-product classification</classificationSystem>
          <classificationValue xml:lang="en">allocatable product</classificationValue>
        </classification>
