    <activityDescription>
      <activity specialActivityType="1" id="b4f120b8-a673-5a4d-9c09-811056af2cb1" activityNameId="f5d3a883-bec9-4a33-ae22-f66ed75782e2" parentActivityId="047febc5-90b9-493e-ad88-7d6da061ac26" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for cable, printer cable, without plugs</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce 'cable, printer cable, without plugs',  within the geography of Global.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'cable, printer cable, without plugs',  to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'cable, printer cable, without plugs', in the Global geography.</text>
          <text xml:lang="en" index="2">In this market, expert judgement was used to develop product specific transport distance estimations.</text>
        </generalComment>
        <tag>ConvertedDataset</tag>
      </activity>
      <classification classificationId="6488bf8b-d05f-4a0e-adcb-1fa34e691ab8">
