    <activityDescription>
      <activity specialActivityType="10" id="abb1b830-5855-5c92-838c-054628e5378b" activityNameId="66e9a031-aca1-4765-aede-c46f966fd8f8" activityNameContextId="de659012-50c4-4e96-b54a-fc781bf987ab" parentActivityId="a63ed821-e8e9-4e5c-b7d7-f4c4c73e027c" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market group for waste plastic, mixture</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of markets that deliver 'waste plastic, mixture', in geographies contained within the geography of this dataset.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'waste plastic, mixture',  to the consumers of this product within the geography of Europe without Switzerland.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset is a market group. Market groups represent a "market of markets". Their purpose is to group a set of markets into larger, geographically relevant datasets.</text>
          <text xml:lang="en" index="1">Market groups are created for convenience and ease of use. They only group other markets and/or market groups contained within their geography.</text>
          <text xml:lang="en" index="2">Losses and relevant exchanges (transport, transport infrastructure, etc.) are not included in this dataset. They are present in the contained markets.  </text>
          <text xml:lang="en" index="3">This is the market group for 'waste plastic, mixture', in Europe without Switzerland.</text>
        </generalComment>
      </activity>
      <classification classificationId="9a63625a-358b-4c1d-bf95-50ba038a759b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3821:Treatment and disposal of non-hazardous waste</classificationValue>
      </classification>
      <geography geographyId="f9221622-cc45-11de-98ed-0019e336be3a">
        <shortname xml:lang="en">Europe without Switzerland</shortname>
      </geography>
