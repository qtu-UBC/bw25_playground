      <parameter parameterId="2e93b53e-a6ea-4516-b1a3-76a1aa9ddd9b" amount="0.1667" variableName="water_dilution" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
        <name xml:lang="en">water_dilution</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Original value from the industrial partner in Ecuador. It represents the amount of water inside the pool, which is absorbed by the poles and therefore needs to be re-integrated in the pool to re-fill it up to the initial 13000 L. It is calculated as 13000L / (130000 L /3 L/pole * 18 kg/pole) = 0.1667 kg water per kg bamboo pole.</comment>
      </parameter>
      <parameter parameterId="6e9bd495-a854-445e-93f7-48a27ba71b74" amount="1.111" variableName="water_washing" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
        <name xml:lang="en">water_washing</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Original value from the industrial partner in Ecuador. Water used for cleaning/washing the bamboo culms.</comment>
      </parameter>
