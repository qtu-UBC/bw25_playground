      <intermediateExchange id="2b5b0372-53f6-5996-8456-22a14d8acb43" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="001330-43-4" amount="0.00416666666666667" isCalculatedAmount="true" mathematicalRelation="(25*13)/(13000/3)*(1/18)" intermediateExchangeId="6a0bd6ed-8952-4f65-9117-b864669b9235" activityLinkId="fe21b318-252e-582e-8381-e134a87e5fb7">
        <name xml:lang="en">borax, anhydrous, powder</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Amount of borax used to prepare the treatment solution of the poles. The treatment solution is kept in a pool where the poles are submerged, once the treatment is finished the poles are extracted and the solution is recovered. The value is calculated considering that 25kg/m3 borax is used in a 13 m3 pool. Each pole absorbs 3L of solution, which means that with 13m3 water (13000L) in a pool approx. 433 pole can be treated -&gt; (25 kg/pool)/ (433 poles/pool) * (poles/18 kg) 
</comment>
        <uncertainty>
          <lognormal meanValue="0.00416666666666667" mu="-5.48063892334199" variance="0.0006" varianceWithPedigreeUncertainty="0.0026"/>
          <pedigreeMatrix reliability="1" completeness="4" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
