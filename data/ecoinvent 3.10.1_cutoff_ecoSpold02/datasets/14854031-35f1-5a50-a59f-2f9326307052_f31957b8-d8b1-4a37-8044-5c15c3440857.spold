      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Data were gathered in a bamboo pole factory located in Portoviejo, Ecuador, through a process assessment in a technical visit. The data from the facility visited can be seen as representative for the average EC production. </samplingProcedure>
        <extrapolations xml:lang="en"/>
      </representativeness>
