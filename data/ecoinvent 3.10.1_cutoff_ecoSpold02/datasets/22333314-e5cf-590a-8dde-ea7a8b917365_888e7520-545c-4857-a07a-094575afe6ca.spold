    <activityDescription>
      <activity specialActivityType="1" id="22333314-e5cf-590a-8dde-ea7a8b917365" activityNameId="fdc705f8-5bef-4d24-809f-f113dbeb933a" parentActivityId="0700551a-d4cd-45f9-bcf1-15961c35803f" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for sealing tape, aluminium/PE, 50 mm wide</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce 'sealing tape, aluminium/PE, 50 mm wide',  within the geography of Global.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'sealing tape, aluminium/PE, 50 mm wide',  to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'sealing tape, aluminium/PE, 50 mm wide', in the Global geography.</text>
          <text xml:lang="en" index="2">In this market, expert judgement was used to develop product specific transport distance estimations.</text>
        </generalComment>
        <tag>ConvertedDataset</tag>
      </activity>
      <classification classificationId="feabab46-84a1-4601-aba8-e5a78411025e">
