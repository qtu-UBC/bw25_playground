      <intermediateExchange id="4449ee4a-6929-5d7e-8012-e00129fa5594" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" amount="-0.0023689603893887485" sourceId="a4eb86c5-bbcb-4cb7-b1b7-0375b4612c6d" sourceYear="2004" sourceFirstAuthor="Svara, J." intermediateExchangeId="240c1a3c-1aba-4528-afc3-3f27f56583be" activityLinkId="93b702f6-21b1-5f36-9562-e29a8fb402ff" productionVolumeMathematicalRelation="RP_PV*BP_inert_waste_for_final_disposal/ABS(RP)">
        <name xml:lang="en">inert waste, for final disposal</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Stoechiometric calculation. The sodium phosphate from the phosphoric acid neutralization is assumed to leave the production process with the wastewater. Further it is assumed that this wastewater is treated in a internal wastewater plant. The removal efficiency for phosphate is assumed with 51.8%. The removed phosphate is accounted as inert waste. The remaining phosphorus (5% of the input) and the removed phosphate are assumed to be disposed as inert waste.</comment>
        <uncertainty>
          <lognormal meanValue="0.0023689603893887485" mu="-6.045304074338375" variance="0.02" varianceWithPedigreeUncertainty="0.036000000000000004"/>
          <pedigreeMatrix reliability="4" completeness="5" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
          <comment xml:lang="en">S</comment>
        </uncertainty>
