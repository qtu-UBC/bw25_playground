      <intermediateExchange id="54ab6d15-7eb1-510a-9dce-2b7bd78a39f3" unitId="77ae64fa-7e74-4252-9c3b-889c1cd20bfc" amount="1.0" intermediateExchangeId="66c93e71-f32b-4591-901c-55395db5c132" activityLinkId="b31f9b70-886c-509a-b9da-04e0f975e0eb">
        <name xml:lang="en">electricity, high voltage</name>
        <unitName xml:lang="en">kWh</unitName>
        <comment xml:lang="en">The origin (thermal or hydro) of the imported electricity from Brazil to Argentina varies with the season. Since the amounts of electricity imported from Brazil during 2014 are distributed over many months of the year, the import was modelled as Electricity market, high voltage, BR. Value taken from the file BASE_INFORME_MENSUAL.xls, available from CAMMESA "COMPAÑÍA ADMINISTRADORA DEL MERCADO MAYORISTA ELÉCTRICO SOCIEDAD ANÓNIMA" Supporting documentation available at: http://portalweb.cammesa.com/Memnet1/default.aspx Informe mensual</comment>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
