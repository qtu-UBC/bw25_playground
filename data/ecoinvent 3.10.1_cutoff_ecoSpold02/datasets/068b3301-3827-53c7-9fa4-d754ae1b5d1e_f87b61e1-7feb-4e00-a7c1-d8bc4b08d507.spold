    <activityDescription>
      <activity specialActivityType="1" id="068b3301-3827-53c7-9fa4-d754ae1b5d1e" activityNameId="33926729-aa86-41b2-97fc-aa705ec85791" parentActivityId="92656aea-a506-4995-a6cb-5065f4e87375" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for butadiene, crude</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce crude butadiene, within the geography of Global.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of crude butadiene,  to the consumers of this product.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  ''butadiene, crude' in the Global geography.</text>
          <text xml:lang="en" index="2">Crude butadiene is usually not transported and directly consumed on site.</text>
        </generalComment>
      </activity>
      <classification classificationId="8714dc59-0b7b-4e7a-8227-e639051eb6e1">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">202:Manufacture of other chemical products</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology/>
