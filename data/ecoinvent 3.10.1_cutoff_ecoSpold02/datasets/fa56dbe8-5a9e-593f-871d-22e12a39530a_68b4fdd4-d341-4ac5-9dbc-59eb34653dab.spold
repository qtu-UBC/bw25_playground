      <elementaryExchange id="e0ce96f4-bfb9-59c3-af54-e87648704f65" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" variableName="water_cooling_UNO_input" casNumber="007732-18-5" amount="0.013583434399118" sourceId="ffd0d7ae-31a0-43a6-8cd5-701b92593bbd" sourceYear="2003" sourceFirstAuthor="Byers, W." elementaryExchangeId="fc1c42ce-a759-49fa-b987-f1ec5e503db1" formula="H2O">
        <name xml:lang="en">Water, cooling, unspecified natural origin</name>
        <unitName xml:lang="en">m3</unitName>
        <comment xml:lang="en">Calculated based on literature, (Vionnet, S., Quantis Water Database - Technical Report, 2012). Assumed to have same or very similar water use as "sheet rolling, steel". Water is used for chromium conditioning, which basically means it is directly sprayed on the hot metal to cool it down. In this case the water comes into contact with the product, i.e. It is treated as process water, not cooling water. It includes the processes: hot rolling, acid pockling, cold rolling and finishing. The process ends when finished, rolled metal sheets leaves the plant.</comment>
        <uncertainty>
          <lognormal meanValue="0.013583434399118" mu="-4.29890428756519" variance="0.01" varianceWithPedigreeUncertainty="0.059300000000000005"/>
          <pedigreeMatrix reliability="2" completeness="3" temporalCorrelation="5" geographicalCorrelation="3" furtherTechnologyCorrelation="3"/>
        </uncertainty>
        <synonym xml:lang="en">oxidane</synonym>
