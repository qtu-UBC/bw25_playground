<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="2f0af0c1-5efe-5837-9ffe-dc62426c0419" activityNameId="b3679824-11e8-4782-9e3b-84756ab8b11f" parentActivityId="b380e3ef-8e56-43a7-b0ef-a22f5c6c9036" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for thermal spraying, cold spray, tungsten carbide-cobalt, on carbon steel substrate</activityName>
        <synonym xml:lang="en">CSP</synonym>
        <synonym xml:lang="en">CS</synonym>
        <includedActivitiesStart xml:lang="en">This activity starts with the service generation.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the service supplied to its consumers. Transport or losses are considered irrelevant for this product.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. In the case of services or immobile infrastructures, markets are connecting suppliers and consumers at a global level. For specific connections at regional level, direct links between the local producing activities and the local consumers are preferred. Transport or losses are logically not relevant for this type of products.</text>
          <text xml:lang="en" index="1">This is the market for 'cold spray, carbon steel substrate, tungsten carbide-cobalt', in the Global geography.</text>
          <text xml:lang="en" index="2">This market contains no transport or losses, as they are irrelevant for the delivered product.</text>
          <text xml:lang="en" index="3">This is delivering the service of ' cold spray, carbon steel substrate, tungsten carbide-cobalt'. The cold spray (CS) is a spray coating process which uses the kinetic energy to deposite powders (tungsten carbide-cobalt powders) on a substrate (carbon steel). The dataset represent the coating of 1 square metre of substrate with a coating thickness of 150 micrometre. The cold spray process is used in key industries such as oil and gas, power, water, mining, petrochemical, chemicals, aerospace, paper, engineering, and manufacturing.</text>
        </generalComment>
      </activity>
      <classification classificationId="873e2688-4fb3-4acb-bfaf-1b99b3dca83d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2592:Treatment and coating of metals; machining</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology/>
      <timePeriod startDate="2022-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
