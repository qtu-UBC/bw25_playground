      <elementaryExchange id="1b843d81-2719-5ad4-8529-26fe91ef789f" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="000106-97-8" amount="6.352049999999982E-07" elementaryExchangeId="fa5512cf-04a2-4014-8e96-d3e2d137f0df" formula="C4H10">
        <name xml:lang="en">Butane</name>
        <unitName xml:lang="en">kg</unitName>
