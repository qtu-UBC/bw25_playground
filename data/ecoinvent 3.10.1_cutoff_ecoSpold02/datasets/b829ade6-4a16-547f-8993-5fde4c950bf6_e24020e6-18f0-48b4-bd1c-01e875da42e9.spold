      <parameter parameterId="d8e60b2c-8034-434e-8f85-653c267ad57b" amount="0.15" variableName="fraction_30MPa_concrete" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
        <name xml:lang="en">fraction of 30-32 MPa concrete to overall concrete production</name>
        <unitName xml:lang="en">dimensionless</unitName>
        <uncertainty>
          <lognormal meanValue="0.15" mu="-1.61" variance="0.0006" varianceWithPedigreeUncertainty="0.0014"/>
          <pedigreeMatrix reliability="2" completeness="2" temporalCorrelation="1" geographicalCorrelation="3" furtherTechnologyCorrelation="1"/>
        </uncertainty>
        <comment xml:lang="en">For Annual production volume purpose. Extrapolated value. In Quebec, Canada, 30-32MPa concrete represent 15%  of the overall ready-mix concrete production. Source; Personal communication, ABQ (Association Béton Québec), October 2013.</comment>
      </parameter>
      <parameter parameterId="daadf2d4-7bbb-4f69-8ab5-58df4c1685eb" amount="0.15" variableName="fraction_PW_to_air" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
        <name xml:lang="en">fraction, process water, to air</name>
        <unitName xml:lang="en">dimensionless</unitName>
        <uncertainty>
          <lognormal meanValue="0.15" mu="-1.9" variance="0.0006" varianceWithPedigreeUncertainty="0.022600000000000002"/>
          <pedigreeMatrix reliability="4" completeness="4" temporalCorrelation="3" geographicalCorrelation="5" furtherTechnologyCorrelation="3"/>
        </uncertainty>
        <comment xml:lang="en">Rough estimation to represent water evaporation of process water. Source: 2007, Kellenberger D et al. (ecoinvent "Concrete production, normal" dataset)</comment>
      </parameter>
      <parameter parameterId="785415a1-4edd-4d52-8c0f-5f3ee2389204" amount="0.8" variableName="fraction_ethylene_oxide" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
        <name xml:lang="en">fraction_01</name>
        <unitName xml:lang="en">dimensionless</unitName>
        <uncertainty>
          <lognormal meanValue="0.8" mu="-0.22" variance="0.0006" varianceWithPedigreeUncertainty="0.0427"/>
          <pedigreeMatrix reliability="3" completeness="1" temporalCorrelation="1" geographicalCorrelation="3" furtherTechnologyCorrelation="4"/>
        </uncertainty>
        <comment xml:lang="en">Literature value. Superplastisizer assumed to be 80% ehtlyne oxide. Extrapolated from 20 MPa mix admixtures. Source: Athena and morrison Hershfield (2012): Life Cycle Assessment of Precast Concrete Commerical Buildings Cradle-to-Grave </comment>
      </parameter>
      <parameter parameterId="e6c5b1c8-fbcc-4aa1-a390-c6471de8009b" amount="0.2" variableName="fraction_acetic_acid" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
        <name xml:lang="en">fraction_02</name>
        <unitName xml:lang="en">dimensionless</unitName>
        <uncertainty>
          <lognormal meanValue="0.2" mu="-1.61" variance="0.0006" varianceWithPedigreeUncertainty="0.0427"/>
          <pedigreeMatrix reliability="3" completeness="1" temporalCorrelation="1" geographicalCorrelation="3" furtherTechnologyCorrelation="4"/>
        </uncertainty>
        <comment xml:lang="en">Literature value. Superplastisizer assumed to be 20% acetic acid. Extrapolated from 20 MPa mix admixtures. Source: Athena and morrison Hershfield (2012): Life Cycle Assessment of Precast Concrete Commerical Buildings Cradle-to-Grave </comment>
      </parameter>
      <parameter parameterId="81f8bf42-3b77-4377-ae7d-00f1f394eb44" amount="136778115.50152" variableName="PV_ready_mix_RNA" mathematicalRelation="270E09/2350/0.84" isCalculatedAmount="true" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5">
        <name xml:lang="en">north america production volume in cubic meter</name>
        <unitName xml:lang="en">m3</unitName>
        <uncertainty>
          <lognormal meanValue="136778115.50152" mu="18.73" variance="0.0006" varianceWithPedigreeUncertainty="0.0032999999999999995"/>
          <pedigreeMatrix reliability="3" completeness="2" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="2"/>
        </uncertainty>
        <comment xml:lang="en">Based on U.S. Ready-Mix concrete production in 2008 (270 Mt, assuming an average density of 2350 kg/m³), Literature  value from: Sakai, K and Noguchi, T. (2012) The Sustainable Use of Concrete. CRC Press, 188 pages. (p.27). </comment>
      </parameter>
      <parameter parameterId="8708743c-8ef8-4247-a448-428062483d40" amount="4700000.0" variableName="PV_ready_mix_Qc" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5">
