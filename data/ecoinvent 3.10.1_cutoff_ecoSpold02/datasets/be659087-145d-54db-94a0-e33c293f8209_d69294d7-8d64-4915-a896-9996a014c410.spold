      <elementaryExchange id="2c1a68ab-bea7-5962-91e6-104e8792c7c1" unitId="980b811e-3905-4797-82a5-173f5568bc7e" amount="3.87096774193548" isCalculatedAmount="true" mathematicalRelation="3.6/0.93" elementaryExchangeId="57c71b25-4663-4fad-9167-7ce5be3e8268">
        <name xml:lang="en">Energy, kinetic (in wind), converted</name>
        <unitName xml:lang="en">MJ</unitName>
        <comment xml:lang="en">Literature value. The kinetic energy converted (harvested) by a wind power plant equals the rotation energy of the turbine blades delivered to the gearbox. The efficiency of the blades to convert kinetic wind energy to rotation energy is not taken into account.
Frischknecht, R., Wyss, F., Büsser Knöpfel, S., Lützkendorf, T. and Balouktsi, M., 2015. Cumulative energy demand in LCA: the energy harvested approach. The International Journal of Life Cycle Assessment, 20, pp.957-969.</comment>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
