        <shortname xml:lang="en">CH</shortname>
        <comment>
          <text xml:lang="en" index="0">This dataset represents 'cement, unspecified' import from Europe to Switzerland.</text>
        </comment>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The annual production volume is assumed to be valid for the current year.</text>
        </comment>
