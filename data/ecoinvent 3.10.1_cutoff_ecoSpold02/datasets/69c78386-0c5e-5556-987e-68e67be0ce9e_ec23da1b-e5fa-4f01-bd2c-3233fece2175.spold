        <activityName xml:lang="en">cement, unspecified, import from Europe</activityName>
        <includedActivitiesStart xml:lang="en">This activity represents the point of 'handing over' the cement, unspecified from one country to the other at the border.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with cement, unspecified which is supplied to the generic market for cement, unspecified.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the amount of imported cement, unspecified from Europe to Switzerland. The import value is assumed to be valid for the current year.</text>
        </generalComment>
      </activity>
      <classification classificationId="36cd730c-4485-4fe9-8efe-8850f771796d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2394:Manufacture of cement, lime and plaster</classificationValue>
      </classification>
