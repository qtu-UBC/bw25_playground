  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="20866136-aa6d-5973-8b5e-fce8135565d8" activityNameId="fe9f78fd-69d6-475f-9ac6-a1fafd0d00db" parentActivityId="fa176da2-91d9-4886-b3ff-5192e0bbf495" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">light fuel oil to generic market for residual hydrocarbon mix, from steam cracking operations</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts with the reception of raw materials at the factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the production of residual hydrocarbon mix, from steam cracking operations for the generic market.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a linking activity which links the product light fuel oil to the generic market for residual hydrocarbon mix, from steam cracking operations. All chemicals that enter this market provide the function of a fuels.</text>
        </generalComment>
      </activity>
      <classification classificationId="0bef4135-5b56-4012-a812-b78c9a8218a9">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1920:Manufacture of refined petroleum products</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2019-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
