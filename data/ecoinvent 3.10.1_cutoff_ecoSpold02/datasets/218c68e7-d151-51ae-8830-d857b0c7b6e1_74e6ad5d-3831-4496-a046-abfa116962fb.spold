<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="218c68e7-d151-51ae-8830-d857b0c7b6e1" activityNameId="919cdfc8-d945-49a3-a871-8e43db19279f" parentActivityId="31ddc5be-90aa-5003-bf1a-abff5e17f32b" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">clinker production</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts from the reception of raw materials at the clinker manufacturing plant.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the production of clinker at the factory gate. The activity includes the processing of materials and their transport within the factory gates. The dataset does not include the packaging.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of 1 kg clinker in Ecuador. Clinker is the main constituent of cement and the main responsible for its environmental impacts. The data is obtained for the year 2019 from the publication of Petroche &amp; Ramirez (2022), based on information from factories. </text>
          <text xml:lang="en" index="1">Reference: </text>
          <text xml:lang="en" index="2">Petroche, D. M., &amp; Ramirez, A. D. (2022). The Environmental Profile of Clinker, Cement, and Concrete: A Life Cycle Perspective Study Based on Ecuadorian Data. Buildings, 12(3), 311.</text>
        </generalComment>
        <tag>combined production</tag>
      </activity>
      <classification classificationId="36cd730c-4485-4fe9-8efe-8850f771796d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2394:Manufacture of cement, lime and plaster</classificationValue>
      </classification>
      <geography geographyId="0d0e72a0-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">EC</shortname>
        <comment>
          <text xml:lang="en" index="0">This dataset is representative of the production of clinker in Ecuador. </text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Current technology. Clinker is made by heating at high temperature in a rotary kiln a mixture of limestone and clays. In the production of clinker, 86% of the total raw materials are composed of limestone. Four types of clays are used, which come from different parts of </text>
          <text xml:lang="en" index="1">Ecuador; these clays represent 11% by mass, and other raw materials of mineral correction </text>
          <text xml:lang="en" index="2">represent 3%.</text>
        </comment>
      </technology>
      <timePeriod startDate="2019-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The time period is 2019 (year of the data collection) to 2023 (year of the compilation of the dataset). </text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
