      <intermediateExchange id="b84f80ff-2a38-5612-8a99-57985902e881" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="dimethyl_carb" casNumber="000616-38-6" amount="0.387283191322831" isCalculatedAmount="true" mathematicalRelation="(0.05 * 1.071 /(1*0.1*0.151905 + 0.05 * 1.321 + 0.05 * 1.071))-(vinyl_carb / 2)" intermediateExchangeId="53fd4bee-dffb-5151-9178-23ec0dfd622d" activityLinkId="27815812-f9be-564f-92fc-f21b0c18f35f">
        <name xml:lang="en">dimethyl carbonate</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value based on literature and on the density of the organic solvents. Ethylene carbonate (EC) and dimethyl carbonate (DMC) are typically used in ratio 1:1. Assuming the volume of the liquid solution equal to 0.1L, the amount of each organic solvent referred to 1 kg of reference product is calculated considering half of the liquid volume (L) multiplied by the solvent density (kg/L) and divided by the sum of the amounts (kg) of the two solvents and the lithium salt. To be able to include the amount of additive, which is known to be 2%wt of the electrolyte formulation, the amount of each solvent is reduced by 0.01 (i.e. half the amount of the additive).

EC density: 1.321 kg/L
DMC density: 1.071 kg/L</comment>
        <uncertainty>
          <lognormal meanValue="0.387283191322831" mu="-0.9485990930344352" variance="0.0006" varianceWithPedigreeUncertainty="0.0046"/>
          <pedigreeMatrix reliability="2" completeness="3" temporalCorrelation="2" geographicalCorrelation="5" furtherTechnologyCorrelation="2"/>
        </uncertainty>
