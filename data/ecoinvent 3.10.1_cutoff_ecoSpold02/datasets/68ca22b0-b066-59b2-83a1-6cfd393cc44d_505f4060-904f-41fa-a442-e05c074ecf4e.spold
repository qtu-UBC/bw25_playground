      <intermediateExchange id="3fd90faa-434c-58ef-9826-69e758ddbcfc" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" amount="-0.7685929862545534" isCalculatedAmount="true" mathematicalRelation="tungsten_carbide_powder*(1-deposition_efficiency)" intermediateExchangeId="6047c525-49b7-4a7d-baf6-a61283e5eda9" activityLinkId="e8842376-15ad-5c98-b413-af444191ffcb" productionVolumeVariableName="PV_hw" productionVolumeMathematicalRelation="hw*pv_hvof/abs(RP)">
