  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="44cffa5a-803c-5a52-87fb-d88d6cc5af67" activityNameId="95e769b5-fae4-4b56-a6c9-32ba630d3697" parentActivityId="9df6f5be-dcec-495a-a44f-361fd35f12d7" inheritanceDepth="-1" type="1" energyValues="1">
        <activityName xml:lang="en">heat production, coal tar, at industrial furnace 1MW</activityName>
        <includedActivitiesStart xml:lang="en">The dataset starts with the reception of coal tar at the furnace</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Heat delivered by the furnace not including losses during distribution in the factory.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This inventory describes the operation of a coal tar boiler, data related to fuel input. Due to lack of process data, the inventory is adapted from the proxy "heat production, heavy fuel oil, at industrial furnace 1 MW". The uncertainty has been adjusted accordingly.</text>
        </generalComment>
      </activity>
      <classification classificationId="f4d7a1e6-6ffc-413f-9e47-899971c64405">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">oil/heating systems</classificationValue>
      </classification>
      <classification classificationId="be3540ee-592f-46fd-bd68-c362a3bbccc6">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3530:Steam and air conditioning supply</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
        <comment>
          <text xml:lang="en" index="0">Assumption for operation in Europe.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Non-modulating furnace, efficiency 95%.</text>
        </comment>
      </technology>
      <timePeriod startDate="2000-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Estimation for efficiency of furnaces used in 2000.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
