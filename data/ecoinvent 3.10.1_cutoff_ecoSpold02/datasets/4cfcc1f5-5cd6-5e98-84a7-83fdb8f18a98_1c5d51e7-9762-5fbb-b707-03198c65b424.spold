<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="4cfcc1f5-5cd6-5e98-84a7-83fdb8f18a98" activityNameId="d6e2ebdd-f59f-4bde-ad7b-2999efcfd718" parentActivityId="24adbb77-fd6d-51eb-ab6c-c8fd90e27e31" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">natural gas, burned in gas turbine</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts with the input of natural gas, at high pressure.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The module includes fuel input, infrastructure (gas turbine), and emissions to air.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the combustion of natural gas in a gas turbine [MJ fuel input] with the specific gas supply in Algeria.</text>
          <text xml:lang="en" index="1">This activity represents burning of natural gas (supplied at high pressure) for the purpose of supplying energy to processes in the liquefaction/evaporation, (transport) transmission, and distribution of natural gas. As described in Bussa et al. (2023, section 4.2.2), this activity is intended to replace the three different datasets related to natural gas 'burned in' (in gas turbine, for compressor station, and in gas motor for storage) from previous studies by Schori and Frischknecht (2012) and Faist Emmenegger et al. (2007).</text>
          <text xml:lang="en" index="2">Reference(s):</text>
          <text xml:lang="en" index="3">Bussa, M., N. Jungbluth, Ch. Meili (2023) Life cycle inventories for long-distance transport and distribution of natural gas. ESU-services Ltd. Schaffhausen, Switzerland. Available from: http://esu-services.ch/data/public-lci-reports/</text>
        </generalComment>
      </activity>
      <classification classificationId="4c3b7870-d05d-41cf-9a2f-d901c183b0d8">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3510:Electric power generation, transmission and distribution</classificationValue>
      </classification>
      <geography geographyId="095ec4f2-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">DZ</shortname>
        <comment>
          <text xml:lang="en" index="0">Algeria</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Average installed gas turbine with 10MWe.</text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Data steem from the mid 1990s.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
