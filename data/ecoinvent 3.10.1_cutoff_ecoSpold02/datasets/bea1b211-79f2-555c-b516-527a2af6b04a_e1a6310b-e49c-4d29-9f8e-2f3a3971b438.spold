<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="bea1b211-79f2-555c-b516-527a2af6b04a" activityNameId="31223898-75fb-52b6-ba82-66515f94455c" parentActivityId="7d37d7d2-9385-5544-b29f-8065ea0623cd" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">regenerative thermal oxidation of nitrous oxide</activityName>
        <synonym xml:lang="en">RTO</synonym>
        <includedActivitiesStart xml:lang="en">Denitrification process starting with the operation of a plant.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with 1 kg retained N2O resulting from the denitrification process.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">In the regenerative thermal oxidation, nitrous oxide is broken down into N2 and O2.</text>
          <text xml:lang="en" index="1">References:</text>
          <text xml:lang="en" index="2">Lanxess (2021): LANXESS inaugurates nitrous oxide reduction plant in Antwerp, available here: https://lanxess.com/en/Media/Press-Releases/2021/02/LANXESS-inaugurates-nitrous-oxide-reduction-plant-in-Antwerp, last accessed 28-07-2022.</text>
          <text xml:lang="en" index="3">Chemical Engeneering (2021): A two-step process reduces nitrous oxide emissions, avaiable here: https://www.chemengonline.com/nitrous-oxide-emissions/, last accessed 28-07-2022.</text>
        </generalComment>
      </activity>
      <classification classificationId="4c3b7870-d05d-41cf-9a2f-d901c183b0d8">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3510:Electric power generation, transmission and distribution</classificationValue>
      </classification>
      <geography geographyId="0723d252-7e2a-11de-9820-0019e336be3a">
        <shortname xml:lang="en">RER</shortname>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">In the regenerative thermal oxidation, 1 kg of nitrous oxide is broken down into N2 and O2 at 1000°C. The treatment has a 95% yield for the N2O abatement.</text>
        </comment>
      </technology>
      <timePeriod startDate="2022-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
