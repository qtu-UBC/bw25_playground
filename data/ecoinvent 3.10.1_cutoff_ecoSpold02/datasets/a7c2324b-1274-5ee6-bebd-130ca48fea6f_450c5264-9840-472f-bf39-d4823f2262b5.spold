<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="a7c2324b-1274-5ee6-bebd-130ca48fea6f" activityNameId="c6b5ac48-ee16-48f6-8705-70848ee1f8bd" parentActivityId="79354615-5917-5548-8c91-463d8cdf9e16" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">cement production, type general use</activityName>
        <synonym xml:lang="en">cement type GU</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts with the reception of raw materials at the cement factory.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the production of 1 kg cement at the factory gate. The dataset includes the transport of materials within the factory area and related infrastructure. The dataset does not include packaging in cement bags, neither the production of waste.

</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset describes the production of 1 kg cement type general use by means of dry process in Ecuador. The data is mainly retrieved from the publication of Petroche &amp; Ramirez (2022), based on primary data from factories in Ecuador, and complemented with the information from local experts.</text>
          <text xml:lang="en" index="1">Reference: </text>
          <text xml:lang="en" index="2">Petroche, D. M., &amp; Ramirez, A. D. (2022). The environmental profile of clinker, cement, and concrete: a life cycle perspective study based on ecuadorian data. Buildings, 12(3), 311.</text>
        </generalComment>
      </activity>
      <classification classificationId="27f6acbc-2350-450e-9762-1ce00e12ecba">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2395:Manufacture of articles of concrete, cement and plaster</classificationValue>
      </classification>
      <geography geographyId="0d0e72a0-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">EC</shortname>
        <comment>
          <text xml:lang="en" index="0">This dataset is representative of the production of cement in Ecuador; data come from factories in the country. </text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Current production technology. The dataset covers the main technology for dry cement production in Ecuador. The cement is produced by adding a quantity of calcium sulfate, usually in form of gypsum (3%), and limestone (39%) to the clinker (58%). Then, in a cement mill, the mixture is ground to form the finished industrial powder. </text>
        </comment>
      </technology>
      <timePeriod startDate="2019-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The time period is from 2019 (year of the data collection) to 2023 (data of the compilation of the dataset).</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
