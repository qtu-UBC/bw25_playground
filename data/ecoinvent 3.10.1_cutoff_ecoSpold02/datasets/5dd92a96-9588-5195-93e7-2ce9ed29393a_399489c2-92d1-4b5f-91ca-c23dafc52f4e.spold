        <activityName xml:lang="en">containerboard production, linerboard, testliner</activityName>
        <synonym xml:lang="en"> containerboard</synonym>
        <synonym xml:lang="en"> recycled liner</synonym>
        <synonym xml:lang="en">linerboard</synonym>
        <includedActivitiesStart xml:lang="en">The process starts wih the reception of the recovered paper.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The process for the production of Testliner ends with the production of corrugated board base paper.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset was built as a weighted average of regional datasets of the same activityName. Weights are based on production volumes.</text>
          <text xml:lang="en" index="1">RER: production volume = 9.89e+09 kg/year, weight = 0.97266</text>
          <text xml:lang="en" index="2">CA-QC: production volume = 2.78e+08 kg/year, weight = 0.02734</text>
        </generalComment>
      </activity>
      <classification classificationId="5682ee05-067a-4dd3-a2b5-93f3f1d25c75">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
