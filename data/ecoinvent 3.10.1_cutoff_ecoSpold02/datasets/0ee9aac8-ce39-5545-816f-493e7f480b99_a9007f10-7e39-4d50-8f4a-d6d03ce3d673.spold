  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="0ee9aac8-ce39-5545-816f-493e7f480b99" activityNameId="40f3c7f2-97e2-4c50-8935-99b433ed2c08" parentActivityId="e5058328-ff53-57cd-8b43-5333c12f5c8c" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">natural gas, high pressure, import from NL</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts with output of the market for natural gas, high pressure, in the supplying geography.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply to the market for natural gas, high pressure, in the receiving geography. Neither losses, emissions, nor energy, infrastructure or transport requirements are considered in this proxy import activity.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the import of natural gas [m3] from the Netherlands to Switzerland. This import activity is only intended to connect the consumption mix of the supplying country to that of the receiving geography. Any losses, emissions, or energy, infrastructure and transport requirements are not considered in this activity. This import activity is establish as a proxy for the trade and domestic production situation in 2021 as reported EuroStat (2023a), respectively. Sources: EuroStat (2023a) Imports of natural gas by partner country [NRG_TI_GAS], accessed on 2023-06-06; EuroStat (2023b) Supply, transformation and consumption of gas [NRG_CB_GAS], accessed on 2023-06-06. Both datasets are available from https://ec.europa.eu/eurostat/</text>
        </generalComment>
      </activity>
      <classification classificationId="5020424a-5b73-4722-8000-ac205dbd592d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3520:Manufacture of gas; distribution of gaseous fuels through mains</classificationValue>
      </classification>
      <geography geographyId="131278d6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">CH</shortname>
        <comment>
          <text xml:lang="en" index="0">Switzerland</text>
        </comment>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
