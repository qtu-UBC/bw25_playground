<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="c5c06dc2-b6de-5d96-b3c1-139e060ffd7b" activityNameId="8ca7c1a9-0645-47b4-b443-709b955cd17c" parentActivityId="6cf67076-45d6-478f-8536-c54af3778609" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">hydrogen compression, from low to medium pressure</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts with hydrogen, gaseous, low pressure (25bar) at the factory gate. The dataset includes electricity to compress hydrogen and cooling water, and water release, for the intermediate cooling.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with hydrogen, gaseous, medium pressure (200 bar) at the factory gate ready for further processing or transport.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the compression of hydrogen, gaseous, low pressure at 25 bar to medium pressure gaseous hydrogen at 200 bar. The pressure of 200 bar is recommended as the functional unit by the IEA Hydrogen Task 36 (Iribarren et al, 2018).</text>
          <text xml:lang="en" index="1">This dataset was recontextualised from the European dataset.</text>
          <text xml:lang="en" index="2">References:</text>
          <text xml:lang="en" index="3">A. Valente, D. Iribarren and J. Dufour (2021): Comparative life cycle sustainability assessment of renewable and conventional hydrogen. Science of The Total Environment, 756, 144132.</text>
          <text xml:lang="en" index="4">Iribarren, D., Valente, A., Dufour, J., 2018. IEA Hydrogen Task 36 – Life Cycle Sustainability Assessment of Hydrogen Energy Systems – Final Report. IEA Hydrogen, Bethesda.</text>
        </generalComment>
      </activity>
      <classification classificationId="5020424a-5b73-4722-8000-ac205dbd592d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3520:Manufacture of gas; distribution of gaseous fuels through mains</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">This dataset represents the compression of hydrogen, gaseous, low pressure at 25 bar to medium pressure at 200 bar.</text>
          <text xml:lang="en" index="1">The electricity and cooling needed for conversion was calculated based on literature.</text>
          <text xml:lang="en" index="2">Reference:</text>
          <text xml:lang="en" index="3">Antonini C., Treyer K., Streb A., van der Spek M., Bauer C., Mazzotti M. (2020): Hydrogen production from natural gas and biomethane with carbon capture and storage – A techno-environmental analysis, Sustainable Energy Fuels.</text>
        </comment>
      </technology>
      <timePeriod startDate="2023-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
