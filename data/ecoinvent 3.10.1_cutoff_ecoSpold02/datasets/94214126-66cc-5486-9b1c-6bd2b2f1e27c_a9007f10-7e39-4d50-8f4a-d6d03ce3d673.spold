    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce" percent="100.0">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Literature. Online calculators for distances. The data for storage emissions are based on global data. The share of gas stored is a rough estimate based on European data. The average weighted transport distance is based on the trade movements 2021.</samplingProcedure>
        <extrapolations xml:lang="en">The consumption mixes for regions and non-european countries were calculated based on the production and trade statistics provided in BP (2022) . Data from Eurostat (2023) were used to modell consumption mixes for European countries. The British consumption mix is based on data from the Department for Business, Energy and Industrial Strategy (2022.)</extrapolations>
      </representativeness>
      <review reviewedMajorRelease="3" reviewedMinorRelease="0" reviewedMajorRevision="0" reviewedMinorRevision="1" reviewerId="44a0bdd8-6624-4a73-a661-7190ddf070b3" reviewerName="David FitzGerald" reviewerEmail="fitzgerald@ecoinvent.org" reviewDate="2023-10-24">
