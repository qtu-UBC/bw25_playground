<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="96985ec3-6d9e-547e-b40c-0885c9cfcb17" activityNameId="c935ecda-5c80-5ef0-b08b-b8aff4b3d135" parentActivityId="9708dc3d-00a3-4e9a-b658-413f31fad0bd" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">clay brick production, extruded</activityName>
        <synonym xml:lang="en">Ziegel</synonym>
        <synonym xml:lang="en">clay</synonym>
        <synonym xml:lang="en">Ton</synonym>
        <includedActivitiesStart xml:lang="en">From reception of clay at the factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This dataset ends with the storage of the produced and packed brick at the factory. This dataset includes the first ginding process, wet process (second ginding, mixing and plastifying), storage, forming (an extruding molding method) and cutting, drying, firing, loading, packing and storage. The dataset doesn't include the charge of the wastewater and solid waste. </includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of 1 kg of brick. Data was obtained from literature values (average data from 12 Swiss brick plants) that were corrected and updated for some flows. Note that no hard coal coke is used within these 12 plants.</text>
          <text xml:lang="en" index="1">includes first ginding process, wet process (includes second ginding, mixing and plastifying), storage, forming (extruding molding method) and cutting, drying, firing, loading, packing and storage</text>
          <text xml:lang="en" index="2">not included: charge of the wastewater and solid waste, it's assumed that the waste heat is totally reused for drying, no hard coal coke is used within these 12 plants</text>
          <imageUrl index="3">https://db3.ecoinvent.org/images/5f75aae1-2b50-4bb5-a700-883b436616cc</imageUrl>
          <text xml:lang="en" index="4">Clay brick. Image source: http://nbss.co.za/wp-content/uploads/2015/06/clay-stock-bricks.jpg, accessed 20151211</text>
        </generalComment>
      </activity>
      <classification classificationId="a5071d0a-6e4e-4fb6-a98b-940902b9a3c9">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2392:Manufacture of clay building materials</classificationValue>
      </classification>
