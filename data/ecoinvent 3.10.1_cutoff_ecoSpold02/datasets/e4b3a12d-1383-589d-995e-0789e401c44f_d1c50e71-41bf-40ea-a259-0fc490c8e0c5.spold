      <elementaryExchange id="3e58b9d7-b7a5-5d0e-91a5-af3f32d494fb" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="nickel_emissions_water" casNumber="014701-22-5" amount="0.00210126705225398" isCalculatedAmount="true" mathematicalRelation="((((1/process_efficiency)-1)*nickel_input))*0.1" elementaryExchangeId="6ec6cdaa-5a01-46d4-b716-1905e56690ea" formula="Ni+2">
        <name xml:lang="en">Nickel II</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value based on literature and estimates. In case of nickel (Ni), part of the unreacted volume evaporates is released as a part of wastewater. The efficiency of the waste water treatment plant (WWTP) is assumed to be 90%, i.e. 10% of the volume of nickel on the inflow to the WWTP is released to the environment.</comment>
