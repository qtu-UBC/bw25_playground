<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="71987b4a-8d9c-55ec-a12d-558a17f1dab4" activityNameId="37cac7e0-c133-4e0d-be57-372b7e46ab3c" parentActivityId="24148c15-b8e5-460d-adc4-af24b3969710" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">maintenance, transmission network, electricity, high voltage direct current aerial line</activityName>
        <includedActivitiesStart xml:lang="en">Manufacture and replacement of parts</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Decommissioning and disposal of parts</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the maintenance of 1 km and year of an high voltage direct current arieal line (FeAl conductor at 250/350 kV).</text>
          <text xml:lang="en" index="1"></text>
          <text xml:lang="en" index="2"></text>
          <text xml:lang="en" index="3">Literature data given for the entire lifetime per km was divided by lifetime (40 a) to get yearly values. </text>
          <text xml:lang="en" index="4">Source: Jorge, R., Hawkins, T.R., Hertwich, E..G (2012): Life cycle assessment of electricity transmission and distribution - part 1: power lines and cables. Int J Life Cycle Assess 17: 9-15. supplementary matierial p.12, table S10.</text>
        </generalComment>
      </activity>
      <classification classificationId="252082de-7cec-4d38-a58f-2819f633c6b6">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">4220:Construction of utility projects</classificationValue>
      </classification>
      <classification classificationId="d5e3f426-90f3-4336-80eb-808d14161792">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">electricity/distribution</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">The scope of the underlying literature source is Europe. Uncertainty was adjusted accordingly.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Maintenance is comprised of the replacement of parts</text>
        </comment>
      </technology>
      <timePeriod startDate="1998-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">refers to publication date of literature sources</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
