  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="c7bf394c-9003-5a5d-b599-7ff6c2b758bc" activityNameId="2b2f2996-9243-45d5-8f3a-00ed126ef7c5" parentActivityId="4be1c230-6878-53ed-8442-6a0774d426b5" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for potato</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts at the gate of potato cultivation farm.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'potato', to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for 'potato', in the geography of Wisconsin state in the United States of America.</text>
          <text xml:lang="en" index="2">Transport from producers to consumers of this product in the geography covered by the market is included.</text>
          <text xml:lang="en" index="3">The product 'potato' is a root vegetable. It is an annual crop. The ecoinvent database also contains this product from organic and Swiss integrated production.</text>
        </generalComment>
      </activity>
      <classification classificationId="70f60468-408c-443d-8737-73b65b804f9a">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0113:Growing of vegetables and melons, roots and tubers</classificationValue>
      </classification>
      <geography geographyId="60764ee9-9608-433e-a86d-96e993703bc7">
        <shortname xml:lang="en">US-WI</shortname>
        <comment>
          <text xml:lang="en" index="0">Data represent the situation in Wisconsin state in the United States of America.</text>
        </comment>
      </geography>
      <technology/>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The time period is the same as stated in the transforming activity for the same reference product.</text>
        </comment>
      </timePeriod>
