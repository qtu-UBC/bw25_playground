      <parameter parameterId="68f592ea-ec5e-40c3-8c86-c952c0763fc4" amount="0.2" variableName="fraction_time_reefer_transfer" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
        <name xml:lang="en">fraction, time to transfer the reefer between different modes of transport</name>
