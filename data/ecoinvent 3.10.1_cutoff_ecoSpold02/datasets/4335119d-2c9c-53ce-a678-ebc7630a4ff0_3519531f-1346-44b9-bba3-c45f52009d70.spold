<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="4335119d-2c9c-53ce-a678-ebc7630a4ff0" activityNameId="409e99b7-7e65-4705-b0fe-e4e3dacbd00d" parentActivityId="4b173bff-669e-474c-9ea9-51aac8c27dd6" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">frit production, for ceramic tile</activityName>
        <includedActivitiesStart xml:lang="en"> From reception of the reactants at the factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the production of frit. Infrastructures are calculated with standard values.
</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of frit in 2012. </text>
          <text xml:lang="en" index="1"></text>
          <text xml:lang="en" index="2">Frit is a ceramic chemicals that have been melted together and cooled rapidly, then ground to a fine powder. They are the main component of nearly all ceramic glazes and are present in many compositions of different materials where a glass faze is needed.</text>
          <text xml:lang="en" index="3"></text>
          <text xml:lang="en" index="4">This dataset is an approximation of frit production. The amount of intermediate exchanges have been calculated based on frit raw materials's composition used in ceramic tiles production. (Nicoletti G.M., Notarnicola B. and Tassielli G. (2002) Comparative Life Cylce Assessment of flooring materials: ceramic versus marble tiles. In: Journal of Cleaner Production). </text>
        </generalComment>
      </activity>
      <classification classificationId="28f738cc-bb73-48f8-b633-f83fb9bc5ddc">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2011:Manufacture of basic chemicals</classificationValue>
      </classification>
      <classification classificationId="7ac1cbc6-1385-4a68-8647-ed7aa78db201">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">chemicals/organics</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">data represents a rough estimation of the production process</text>
        </comment>
      </technology>
      <timePeriod startDate="2012-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Dataset based on modelling only, therefore data entry is the reference year</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
