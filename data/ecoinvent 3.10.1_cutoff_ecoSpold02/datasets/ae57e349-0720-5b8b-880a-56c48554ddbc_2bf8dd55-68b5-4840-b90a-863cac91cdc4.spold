<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="ae57e349-0720-5b8b-880a-56c48554ddbc" activityNameId="d0f0d0da-94eb-4217-a14b-b71bba78225e" parentActivityId="ae6382c7-2f14-44e0-a53c-0a5b3fee93f3" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for hydrocarbons, aromatic, cyclic (C9+)</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce hydrocarbons, aromatic, cyclic (C9+), within the geography of Global.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of hydrocarbons, aromatic, cyclic (C9+),  to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'hydrocarbons, aromatic, cyclic (C9+)' in the Global geography.</text>
          <text xml:lang="en" index="2">'hydrocarbons, aromatic, cyclic (C9+)' is usually not transported and directly consumed on site.</text>
          <text xml:lang="en" index="3">The product 'hydrocarbons, aromatic, cyclic (C9+)' represents a gaseous mixture of cyclic aromatic hydrocarbon compounds with 9 carbon atoms or more. It can be used in the following applications: chemical synthesis.</text>
        </generalComment>
      </activity>
      <classification classificationId="8714dc59-0b7b-4e7a-8227-e639051eb6e1">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">202:Manufacture of other chemical products</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology/>
      <timePeriod startDate="2022-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
