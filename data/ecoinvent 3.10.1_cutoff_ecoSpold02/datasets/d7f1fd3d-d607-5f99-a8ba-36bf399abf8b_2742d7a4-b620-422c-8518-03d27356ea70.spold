      <elementaryExchange id="94882324-836a-581d-84b6-0b396c6dc756" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="CO2" casNumber="000124-38-9" amount="2.10372694239819" isCalculatedAmount="true" mathematicalRelation="wood_fuel*EF_CO2" elementaryExchangeId="eba59fd6-f37e-41dc-9ca3-c7ea22d602c7" formula="CO2">
        <name xml:lang="en">Carbon dioxide, non-fossil</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value. Multiplying the kg of fuel (wood) per kg of clay brick by the emission factor of the pollutant (kg/kg). Since the wood chips are measured as dry mass, this is multiplied by the water mass of the wood, which is 2.1kg. Based on literature calculations and information provided by the owners of the factories. CO2 emission is produced from combustion of wood during the firing process. Reference: Jaya Sucozhañay, J. L., &amp; Gomezcoello Vásquez, J. L. (2012). Análisis comparativo de la contaminación atmosférica producida por la combustión en ladrilleras artesanales utilizando tres tipos de combustibles (Bachelor's thesis).</comment>
        <uncertainty>
          <lognormal meanValue="2.10372694239819" mu="0.7437105062242837" variance="0.0006" varianceWithPedigreeUncertainty="0.0031999999999999997"/>
          <pedigreeMatrix reliability="2" completeness="4" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
        <synonym xml:lang="en">Carbon dioxide</synonym>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.272916486782489" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
