      <intermediateExchange id="0d748ddf-dede-5d41-9989-a5a7893be3dd" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="wood_fuel" amount="1.29063002601116" isCalculatedAmount="true" mathematicalRelation="(260*25)/5036.3" intermediateExchangeId="7fe99768-d571-4bc2-a272-7df585bd0d48" activityLinkId="bd2a3b3f-1d76-5d82-80c1-70d3ff13a576">
        <name xml:lang="en">wood chips, wet, measured as dry mass</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value. The value represents the amount of used (old) pallets that are used as fuel in the firing process for the production of 1 kg of glazed clay roof tiles as informed by the owner of the factory. Wood chips are used as proxy for the used pallets used for the firing process. The number of pallets used per firing process is 260 units. Each unit weights 25kg. Since the wood chips are measured as dry mass, this is divided by the water mass of the wood, which is 2.1kg. This is then divived by the kg of clay roof tiles per firing process (5036.3 kg).</comment>
        <uncertainty>
          <lognormal meanValue="1.29063002601116" mu="0.2551304914056131" variance="0.0006" varianceWithPedigreeUncertainty="0.0026"/>
          <pedigreeMatrix reliability="1" completeness="4" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.494" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
