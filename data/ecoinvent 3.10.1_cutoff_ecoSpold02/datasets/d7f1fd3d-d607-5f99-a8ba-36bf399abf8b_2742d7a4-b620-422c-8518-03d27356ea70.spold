      <intermediateExchange id="4a9a4a3b-d430-5690-88d7-ec177acd404d" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="damaged_tiles" amount="-0.0416972777634374" isCalculatedAmount="true" mathematicalRelation="(250*0.84)/5036.3" intermediateExchangeId="09843005-5982-4018-b1e3-5dfb00b18c9a" activityLinkId="2dea91ac-2a54-5f6a-ae84-7bc983f45a9d" productionVolumeMathematicalRelation="damaged_tiles/clay_roof_tile_glazed*clay_roof_tile_glazed_PV">
