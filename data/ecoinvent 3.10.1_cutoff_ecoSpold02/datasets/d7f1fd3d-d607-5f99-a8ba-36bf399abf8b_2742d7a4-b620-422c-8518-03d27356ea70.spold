      <elementaryExchange id="f4b6b8d6-b2dc-5547-959e-57dba0ba251e" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="CO" casNumber="000630-08-0" amount="0.0254254115124199" isCalculatedAmount="true" mathematicalRelation="wood_fuel*EF_CO" elementaryExchangeId="2cb2333c-1599-46cf-8435-3dffce627524" formula="CO">
