<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="76b43702-a692-57d6-a8a1-66c10dc27e12" activityNameId="c935ecda-5c80-5ef0-b08b-b8aff4b3d135" parentActivityId="d1eba20c-a33a-4f04-b21b-bf40606e2b40" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">clay brick production, extruded</activityName>
        <synonym xml:lang="en">clay</synonym>
        <synonym xml:lang="en">Ton</synonym>
        <synonym xml:lang="en">Ziegel</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts with the reception of raw materials at the clay brick production site.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This dataset ends with the storage of the produced and packed brick at the factory. This datset includes the first ginding process, wet process (second ginding, mixing and plastifying), storage, forming (an extruding molding method) and cutting, drying, firing, loading, packing and storage. The dataset doesn't include the charge of the wastewater and solid waste. </includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of 1 kg of brick (extruded) in the Global geography. Data was obtained from literature values (average data from 12 Swiss brick plants) that were corrected and updated for some flows. Note that no hard coal coke is used within these 12 plants.</text>
          <text xml:lang="en" index="1">It includes first ginding process, wet process (includes second ginding, mixing and plastifying), storage, forming (extruding molding method) and cutting, drying, firing, loading, packing and storage.</text>
          <text xml:lang="en" index="2">not included: charge of the wastewater and solid waste, it's assumed that the waste heat is totally reused for drying, no hard coal coke is used within these 12 plants</text>
          <imageUrl index="3">https://db3.ecoinvent.org/images/5f75aae1-2b50-4bb5-a700-883b436616cc</imageUrl>
          <text xml:lang="en" index="4">Clay brick. Image source: http://nbss.co.za/wp-content/uploads/2015/06/clay-stock-bricks.jpg, accessed 20151211</text>
        </generalComment>
        <tag>construction_EC</tag>
      </activity>
      <classification classificationId="6619b78b-c653-4d19-9147-14f2dda9a249">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">construction materials/bricks</classificationValue>
      </classification>
