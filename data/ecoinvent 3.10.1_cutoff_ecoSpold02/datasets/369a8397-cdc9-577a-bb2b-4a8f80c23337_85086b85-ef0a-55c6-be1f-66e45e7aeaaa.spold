    <activityDescription>
      <activity specialActivityType="10" id="369a8397-cdc9-577a-bb2b-4a8f80c23337" activityNameId="cc9fced6-2cd1-4bec-b688-a5b43f5b7601" parentActivityId="95ede05c-d17a-49ff-8bcc-cea2902e0217" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market group for land use change, pasture, man made</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of markets that deliver 'land use change, pasture, man made', in geographies contained within the geography of this dataset.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'land use change, pasture, man made',  to the consumers of this product within the geography of Brazil.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset is a market group. Market groups represent a 'market of markets'. Their purpose is to group a set of markets into larger, geographically relevant datasets.</text>
          <text xml:lang="en" index="1">Market groups are created for convenience and ease of use. They only group other markets and/or market groups contained within their geography.</text>
          <text xml:lang="en" index="2">Losses and relevant exchanges (transport, transport infrastructure, etc.) are not included in this dataset. They are present in the contained markets.  </text>
          <text xml:lang="en" index="3">This is the market group for 'land use change, pasture, man made', in Brazil.</text>
        </generalComment>
      </activity>
      <classification classificationId="172f4d11-46f4-43f2-a49e-eae5e66dd79f">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0162:Support activities for animal production</classificationValue>
      </classification>
