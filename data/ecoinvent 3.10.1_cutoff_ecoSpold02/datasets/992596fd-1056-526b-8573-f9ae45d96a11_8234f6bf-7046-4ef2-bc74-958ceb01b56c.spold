<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="992596fd-1056-526b-8573-f9ae45d96a11" activityNameId="3f687c37-91bd-4eef-ab8e-3d7ae2e94661" parentActivityId="4faea8e9-7932-55c7-8d5d-d74951a67bc2" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">sulfur dioxide production, liquid</activityName>
        <synonym xml:lang="en">Sulfurous oxide</synonym>
        <synonym xml:lang="en">Schwefeldioxid</synonym>
        <synonym xml:lang="en">Sulfurous anhydride</synonym>
        <synonym xml:lang="en">Sulphur dioxide</synonym>
        <synonym xml:lang="en">Sulfur dioxide</synonym>
        <synonym xml:lang="en">7446-09-5</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts when the raw materials enter the process.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the production of 1 kg of liquid sulfur dioxide. The dataset includes the processing of the precursor, which is secondary sulfur obtained from refineries.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of 1 kg of liquid sulfur dioxide. Liquid sulfur dioxide is an inorganic chemical compound which is used primarily in the pulp and paper industry. There are many different processes that generate liquid sulfur dioxide.</text>
          <text xml:lang="en" index="1">The inventory is based on assumptions taken from literature as well as data from a large chemical plant (Gendorf 2016).</text>
          <text xml:lang="en" index="2">References:</text>
          <text xml:lang="en" index="3">Althaus H.-J., Chudacoff M., Hischier R., Jungbluth N., Osses M. and Primas A. (2007) Life Cycle Inventories of Chemicals. Final report ecoinvent data v2.0 No. 8. Swiss Centre for Life Cycle Inventories, Dübendorf, CH.</text>
          <text xml:lang="en" index="4">Gendorf (2016) Umwelterklärung 2015, Werk Gendorf Industriepark, www.gendorf.de.</text>
        </generalComment>
      </activity>
      <classification classificationId="28f738cc-bb73-48f8-b633-f83fb9bc5ddc">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2011:Manufacture of basic chemicals</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is modelled for Europe but is assumed to be representative of the global production. Some values are based on data from a large chemical factory located in Germany. These are assumed to be valid for this geography.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">There are widely varying processes for the production of liquid SO2. In this dataset, the SO2 production from the combustion of sulfur is chosen as the representative process: sulfur from natural deposits or from sulfur recovery is combusted in a chamber. The SO2 gas content is generally up to 18% by volume. This process is exothermic.</text>
          <text xml:lang="en" index="1">Chemical reaction formula:</text>
          <text xml:lang="en" index="2">S + O2 (g) → SO2</text>
          <text xml:lang="en" index="3">References:</text>
          <text xml:lang="en" index="4">Althaus H.-J., Chudacoff M., Hischier R., Jungbluth N., Osses M. and Primas A. (2007) Life Cycle Inventories of Chemicals. Final report ecoinvent data v2.0 No. 8. Swiss Centre for Life Cycle Inventories, Dübendorf, CH.</text>
        </comment>
      </technology>
      <timePeriod startDate="1997-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Time of publications. Some values are based on data published by the Gendorf factory that were collected between 2011 and 2015. The time period has been adjusted accordingly. For more details, see the comments of the exchanges.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
    <flowData>
      <intermediateExchange id="984c3a97-fb3d-507a-9ac2-d3d652b4febe" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="RP" casNumber="7446-09-5" amount="1.0" intermediateExchangeId="8234f6bf-7046-4ef2-bc74-958ceb01b56c" productionVolumeAmount="583397318.62381" productionVolumeVariableName="RP_PV">
        <name xml:lang="en">sulfur dioxide, liquid</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Liquid SO2 is a colorless liquid kept under pressure. It has a strong pungent odor. Liquid sulfur dioxide is an inorganic chemical compound which is used primarily in the pulp and paper industry. </comment>
