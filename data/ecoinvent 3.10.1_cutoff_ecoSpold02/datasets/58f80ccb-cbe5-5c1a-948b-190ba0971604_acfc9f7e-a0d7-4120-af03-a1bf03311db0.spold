    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">This dataset has been extrapolated from respective regional geographies (RER). Data were collected from the producers by CCB (Cepi ContainerBoard) and FEFCO (European Federation of Corrugated Board Manufacturers) for the European Database for Corrugated Board Life Cycle Studies), checked by technical experts and reviewed by the Institut für Energie- und Umweltforschung Heidelberg (ifeu). The data for Semichemical Fluting and Kraftliner jointly represent ca. 84% of the total annual production of corrugated base papers from primary fibres in Europe. Reference(s): https://www.fefco.org/sites/default/files/documents/2022-07-07_FEFCO%20LCA%202021.pdf, last accessed March 2023</samplingProcedure>
        <extrapolations xml:lang="en">This dataset has been extrapolated from respective regional geographies (RER). Additional air emissions from the combustion of fossil fuels estimated based on industrial heating datasets from the ecoinvent database: natural gas: heat production, natural gas, at industrial furnace &gt;100kW, Europe without Switzerland; heavy fuel oil: heat production, heavy fuel oil, at industrial furnace 1MW, Europe without Switzerland; light fuel oil: heat production, light fuel oil, at industrial furnace 1MW, Europe without Switzerland; diesel: heat production, light fuel oil, at industrial furnace 1MW, Europe without Switzerland; LPG: heat production, natural gas, at industrial furnace &gt;100kW, Europe without Switzerland; Coal: heat production, at hard coal industrial furnace 1-10MW, Europe without Switzerland; Peat: heat production, lignite briquette, at stove 5-15kW, Europe without Switzerland; biogas: heat production, natural gas, at industrial furnace &gt;100kW, Europe without Switzerland; Biofuel (bark, scrap wood, tall oil) and bark: heat production, wood chips from industry, at furnace 1000kW, CH; refused derived fuel, biomass: heat production, wood chips from post-consumer wood, at furnace 300kW. CO2, CO and CH4 emissions from biogas were modelled as non-fossil.</extrapolations>
      </representativeness>
      <review reviewedMajorRelease="3" reviewedMinorRelease="0" reviewedMajorRevision="0" reviewedMinorRevision="1" reviewerId="847a56f5-d9e5-4a65-ab51-b056e0039130" reviewerName="Avraam Symeonidis" reviewerEmail="Symeonidis@ecoinvent.org" reviewDate="2023-09-06">
        <otherDetails xml:lang="en"/>
      </review>
