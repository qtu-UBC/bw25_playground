          <lognormal meanValue="1.0798191851639835E-06" mu="-13.73871695198909" variance="0.65" varianceWithPedigreeUncertainty="0.6628000000000001"/>
          <pedigreeMatrix reliability="3" completeness="3" temporalCorrelation="2" geographicalCorrelation="5" furtherTechnologyCorrelation="3"/>
        </uncertainty>
        <synonym xml:lang="en">Zinc ion</synonym>
        <synonym xml:lang="en">Zinc (+2)</synonym>
        <synonym xml:lang="en">Zinc</synonym>
