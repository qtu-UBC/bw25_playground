      <elementaryExchange id="19ae857d-4af9-52a9-91f3-770f6039d016" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" casNumber="007732-18-5" amount="0.000965426270193802" elementaryExchangeId="8c75e7ab-8ab8-41e4-b394-c166ff5b050d" formula="H2O">
        <name xml:lang="en">Water, river</name>
        <unitName xml:lang="en">m3</unitName>
        <comment xml:lang="en">Calculated based on literature data published by the GENDORF Chemical Park. The factory produced an average of 2462760 tonnes of chemical substances (including intermediates) per year in the years 2015-2019. The average consumption of river water in the years 2015-2019 was 22000820 t per year. However, since the cooling water is modelled as an input, the amount of river water was adjusted to avoid double counting. 55% of the input amount of cooling water was deducted from the amount of river water, as that is the share of river water versus well water. This equals 0.00096543 m3/kg chemical produced.

References:
Chemiepark GENDORF, Umwelterklärung 2016, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit
Chemiepark GENDORF, Umwelterklärung 2017, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit
Chemiepark GENDORF, Umwelterklärung 2020, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit</comment>
        <uncertainty>
          <lognormal meanValue="0.000965426270193802" mu="-6.942940823388824" variance="0.0006" varianceWithPedigreeUncertainty="0.08380000000000001"/>
          <pedigreeMatrix reliability="2" completeness="4" temporalCorrelation="5" geographicalCorrelation="4" furtherTechnologyCorrelation="4"/>
        </uncertainty>
        <synonym xml:lang="en">oxidane</synonym>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
