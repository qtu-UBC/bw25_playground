        <property propertyId="38f94dd1-d5aa-41b8-b182-c0c42985d9dc" amount="2.0" unitId="7b75baf0-cbee-45e6-bf66-af119da06553">
          <name xml:lang="en">price</name>
          <unitName xml:lang="en">EUR2005</unitName>
          <comment xml:lang="en">Estimated value. The price is taken from the online shop of Casa Henkel, company producing a number of products for hosehold cleaning (source retrieved from: http://www.casahenkel.it/, accessed 13Feb 2018). The price range varies greatly according to the size and the type of product. An average price of 2 euros per kg of product is assumed. </comment>
        </property>
