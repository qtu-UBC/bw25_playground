    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Data from a single literature source: Golsteijn et al (2015). A compilation of life cycle studies for six household detergent product categories in Europe: the basis for product-specific A.I.S.E. Charter Advanced Sustainability Profiles. Environmental Science Europe (2015) 27:23.
The data is extracted from a single source. The source refers to LCIs of six household detergent product categories. The exchanges are calculated from the average of the five household detergent product. The exception is the compacter powder lawdry detergent.</samplingProcedure>
        <extrapolations xml:lang="en"/>
      </representativeness>
