<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="53a05ad8-6d1f-567a-84a8-d56e6f07efff" activityNameId="bf145dde-9cc9-4b9c-925a-af0d4e76073f" parentActivityId="15a49b79-4e7d-521b-8253-904744266d24" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">rape seed production</activityName>
        <synonym xml:lang="en">rapeseed</synonym>
        <includedActivitiesStart xml:lang="en">This activity starts with soil cultivation after the harvest of the previous crop.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the harvest of grains and their transport to the farm gate. The dataset includes all machine operations, corresponding infrastructure, fuel use and sheds. Machine operations are: soil cultivation (a mixture of no tillage and minimum tillage), sowing, fertilisation, pesticide application, harvesting, grain drying, and on-farm transport. Further, direct field emissions and land use change are included. Heavy metal uptake by the crop is considered. The inputs of seeds, fertilisers and pesticides as well as packaging of fertilisers and pesticides are considered.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of 1 kg of rape seed (fresh matter). The amounts of flows are weighted averages over all existing local crop production datasets available for this specific product. For references refer to the respective local datasets.</text>
          <text xml:lang="en" index="1"></text>
          <text xml:lang="en" index="2">This dataset was built as a weighted average of regional datasets of the same activityName. Weights are based on production volumes.</text>
          <text xml:lang="en" index="3">Canada without Quebec: production volume = 1.37e+10 kg/year, weight = 0.6292</text>
          <text xml:lang="en" index="4">DE: production volume = 3.5e+09 kg/year, weight = 0.1607</text>
          <text xml:lang="en" index="5">FR: production volume = 3.31e+09 kg/year, weight = 0.1516</text>
          <text xml:lang="en" index="6">US: production volume = 1.24e+09 kg/year, weight = 0.05706</text>
          <text xml:lang="en" index="7">CA-QC: production volume = 2.99e+07 kg/year, weight = 0.001373</text>
        </generalComment>
        <tag>WFLDB</tag>
      </activity>
      <classification classificationId="e2e1f67d-3393-4182-86f6-1ada2f77c3e5">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0111:Growing of cereals (except rice), leguminous crops and oil seeds</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">This dataset is a weighted average built from the following geographies: Canada without Quebec, DE, FR, US, CA-QC.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Conventional production.</text>
        </comment>
      </technology>
      <timePeriod startDate="2000-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The time period start (2000) and end (2012) are set according to the time periods of regional datasets for the same activity name.</text>
        </comment>
      </timePeriod>
