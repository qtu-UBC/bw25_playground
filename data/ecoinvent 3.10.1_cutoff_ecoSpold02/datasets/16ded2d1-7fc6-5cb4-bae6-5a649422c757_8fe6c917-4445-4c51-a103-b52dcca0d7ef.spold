<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="16ded2d1-7fc6-5cb4-bae6-5a649422c757" activityNameId="0612d146-f696-510f-b469-53f6706f0144" parentActivityId="e6bbcc22-ef94-58dd-83c5-794a8ba9d659" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">cement production, ART</activityName>
        <synonym xml:lang="en">ART</synonym>
        <synonym xml:lang="en"> Alta resistencia temprana</synonym>
        <includedActivitiesStart xml:lang="en">This activity starts with the reception of raw materials.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the cement produced in the cement mill. Packaging is not included and no production waste is assumed.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">The dataset describes the production of cement type ART (Alto Resistencia Temprano) according to technical norm NTC 121 (Icontec, 2014), which is based on the standard specification for hydraulic cement (ASTM standard n° C1157).</text>
          <text xml:lang="en" index="1">The weight composition of the cement is: 75% clinker, 3% gypsum, 7.3% blast funrace slag, 7.3% fly ash and 7.3% limestone (rounded numbers).</text>
          <text xml:lang="en" index="2">The cement density is 3g/ml and the resitance is 38-44MPa according to the NTC 220 (Cemex and Argos).</text>
        </generalComment>
        <tag>combined production</tag>
      </activity>
      <classification classificationId="36cd730c-4485-4fe9-8efe-8850f771796d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2394:Manufacture of cement, lime and plaster</classificationValue>
      </classification>
      <geography geographyId="0cc6c45a-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">CO</shortname>
        <comment>
          <text xml:lang="en" index="0">Representative production of cement type ART in Colombia. Data based from main cement producers and personal comunications with local experts.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Represent the current technology for cement production in Colombia.</text>
        </comment>
      </technology>
      <timePeriod startDate="2014-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The production volume of 2016 is considered. Data from sustainability reports of 2014 to 2017 is used.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
