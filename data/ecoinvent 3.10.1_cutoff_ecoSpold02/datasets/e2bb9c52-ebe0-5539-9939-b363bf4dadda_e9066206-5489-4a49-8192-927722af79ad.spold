<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="e2bb9c52-ebe0-5539-9939-b363bf4dadda" activityNameId="974f13f6-757f-5924-bf27-25274cefa108" parentActivityId="882f9d50-af76-5052-826b-49616903362e" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">clay brick production, moulded</activityName>
        <synonym xml:lang="en"> Ton</synonym>
        <synonym xml:lang="en"> ladrillo </synonym>
        <synonym xml:lang="en"> artesanal</synonym>
        <synonym xml:lang="en"> arcilla</synonym>
        <synonym xml:lang="en">clay</synonym>
        <synonym xml:lang="en"> Ziegel</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts with the reception of raw materials at the clay brick production site.
</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This dataset ends with the storage of the produced brick at the production site. This dataset includes the reception of raw materials, dosing, mixing, forming (moulding by hand), drying, firing, cooling, and storage. The dataset does not include the packaging.
</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset describes the production of traditional clay bricks in the area of San José de Balzay in Ecuador. The dataset represents the production of 1 kg of brick, with the following characteristics:  average weight of 4.72 kg and average dimensions of (13.5 x 26.5 x 7.75) cm (width x length x height). Data was obtained from measurements and information provided in the two factories visited, therefore the dataset contains weighted average values. Some data was calculated using literature values. The companies visits took place in March, May, and June 2022. This dataset was developed by Estefania Barros, Kristi Padrón, Jonnathan Aguirre and Juan Sebastian Martines, under the supervision of Prof. Dolores Sucozhañay and Prof. Paul Vanegas, from the Inclusive Circular Economy and Sustainable Development Research Group of the University of Cuenca (ECI) in the frame of the CEELA (Strengthening capacities for energy efficiency in buildings in Latin America) project with the support of the Swiss Agency for Development and Cooperation (SDC).</text>
        </generalComment>
      </activity>
      <classification classificationId="a5071d0a-6e4e-4fb6-a98b-940902b9a3c9">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2392:Manufacture of clay building materials</classificationValue>
      </classification>
      <geography geographyId="0d0e72a0-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">EC</shortname>
        <comment>
          <text xml:lang="en" index="0">Data was obtained in two factories of traditional clay bricks located in San José de Balzay and Racar, Cuenca, Ecuador. </text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Current production technology. This dataset corresponds to artisanal manufacturing of two traditional clay bricks factories, which do not incorporate any machinery in their process. The manufacturing process includes the reception of raw materials, dosing, mixing, forming, drying, firing of wood, cooling and storage of bricks. The mixing of raw materials is done with the help of the trampling of a horse, while the forming process is done by hand by the people working in the factory.</text>
        </comment>
      </technology>
      <timePeriod startDate="2022-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The time period is from 2022 (year of data collection) to 2023 (year of dataset compilation).</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
    <flowData>
      <intermediateExchange id="74458a3c-4c09-5512-9c1c-6f6198fbcc2b" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="clay_brick" amount="1.0" intermediateExchangeId="e9066206-5489-4a49-8192-927722af79ad" productionVolumeAmount="8401600000.0" productionVolumeVariableName="clay_brick_PV" productionVolumeMathematicalRelation="2000000000*0.89*4.72">
        <name xml:lang="en">clay brick</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">The dataset represents 1 kg of a solid clay brick, with measured average dimensions (13.5 x 26.5 x 7.75) cm (width x length x height) and measured average mass of 4.72 kg.</comment>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
