      <intermediateExchange id="6043538f-5fb1-5b46-8876-2b3f05d9b189" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="damaged_bricks" amount="-0.0295773279163622" isCalculatedAmount="true" mathematicalRelation="(241.049*4.72)/38467.007" intermediateExchangeId="1e16f9f6-0e0f-4cf0-ac68-a88372ee72de" activityLinkId="0bca4e96-52f9-5dde-8f5f-df8e7af42336" productionVolumeMathematicalRelation="damaged_bricks/clay_brick*clay_brick_PV">
        <name xml:lang="en">damaged clay material</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value. Multiplying the number of damaged bricks by the brick mass. This value is divided by the kg of bricks produced per firing process, to obtain the kg of damaged bricks per kg of clay brick. About 241 bricks are damaged in the oven, for each firing process, as informed by the owners of the factories is considered. These bricks are used to fill holes in the ground. Therefore, the disposal is modelled as open dumping.</comment>
        <uncertainty>
