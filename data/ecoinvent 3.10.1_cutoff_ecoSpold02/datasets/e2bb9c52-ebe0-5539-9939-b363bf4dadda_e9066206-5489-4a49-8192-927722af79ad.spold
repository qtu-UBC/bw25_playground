        <property propertyId="3a0af1d6-04c3-41c6-a3da-92c4f61e0eaa" amount="1.0" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
          <name xml:lang="en">dry mass</name>
          <unitName xml:lang="en">kg</unitName>
        </property>
        <property propertyId="38f94dd1-d5aa-41b8-b182-c0c42985d9dc" amount="0.027135707" unitId="7b75baf0-cbee-45e6-bf66-af119da06553">
          <name xml:lang="en">price</name>
          <unitName xml:lang="en">EUR2005</unitName>
          <comment xml:lang="en">Data provided by the owner of the factory. Price given as 0.0425 USD/kg clay brick, moulded and 0.068 USD/kg for clay brick, extruded. Both prices are for 2022. Weighted average of the prices based on the production volumes of both types of clay bricks was performed. The prices were converted to EUR based on the annual exchange rates published by the European Central Bank (https://sdw.ecb.europa.eu/quickview.do?SERIES_KEY=120.EXR.A.USD.EUR.SP00.A, last accessed on 2023-06-01) and adjusted for inflation relative to 2005 using the producer price index (PPI) of the euro area, published by eurostat (https://ec.europa.eu/eurostat/databrowser/view/STS_INPP_A__custom_6416181/default/table?lang=en, last accessed on 2023-06-01).</comment>
        </property>
        <property propertyId="a9358458-9724-4f03-b622-106eda248916" amount="0.0" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
          <name xml:lang="en">water content</name>
          <unitName xml:lang="en">dimensionless</unitName>
          <comment xml:lang="en">water mass/dry mass</comment>
        </property>
        <property propertyId="6d9e1462-80e3-4f10-b3f4-71febd6f1168" amount="0.0" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
          <name xml:lang="en">water in wet mass</name>
          <unitName xml:lang="en">kg</unitName>
        </property>
        <property propertyId="67f102e2-9cb6-4d20-aa16-bf74d8a03326" amount="1.0" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
          <name xml:lang="en">wet mass</name>
          <unitName xml:lang="en">kg</unitName>
        </property>
        <productionVolumeComment xml:lang="en">Calculated value. The clay brick mass multiplied by the number of bricks produced per year. Based on a study conducted by Swisscontact in Cuenca in 2016.  In which they identified that 2E09 clay bricks are produced per year and that 89% of brick factories are considered artisanal (which produce clay brick moulded) and the rest semi-mechanized. The weight of the moulded brick is 4.72 kg. References: Venegas, O. (2018). Evaluación de la energía contenida, emisiones de CO2 y material particulado en la fabricación del ladrillo semi-mecanizado tochano en cuenca, a través del análisis de ciclo de vida (ACV). [Master degree in Constructions, University of Cuenca]. https://dspace.ucuenca.edu.ec/bitstream/123456789/29319/1/MscArqAndr%C3%A9sVenegas.pdf</productionVolumeComment>
        <classification classificationId="39b0f0ab-1a2f-401b-9f4d-6e39400760a4">
          <classificationSystem xml:lang="en">By-product classification</classificationSystem>
          <classificationValue xml:lang="en">allocatable product</classificationValue>
        </classification>
        <classification classificationId="cedf3d60-b7f8-4ba8-8e9a-19fc5bb5abb2">
          <classificationSystem xml:lang="en">CPC</classificationSystem>
          <classificationValue xml:lang="en">37310: Bricks, blocks, tiles and other ceramic goods of siliceous earths</classificationValue>
        </classification>
        <classification classificationId="54930b58-fc29-5024-9153-ea80d1344975">
          <classificationSystem xml:lang="en">HS2017</classificationSystem>
          <classificationValue xml:lang="en">6901: Bricks, blocks, tiles and other ceramic goods of siliceous fossil meals (e.g. kieselguhr, tripolite or diatom[...]</classificationValue>
        </classification>
        <outputGroup>0</outputGroup>
      </intermediateExchange>
      <intermediateExchange id="b70b255a-54c4-5e80-9faf-0f47731f8f08" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" variableName="clay_input" amount="1.066919511" intermediateExchangeId="e89b4064-afcc-4f08-9481-651b7eaa90a1" activityLinkId="00986939-eef8-574d-a138-33dd215b1fbd">
        <name xml:lang="en">clay</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated value. This value represents the amount of various types of clay used for the production of 1 kg of clay brick, according to measurements and the information provided by the owners of the factories. The types of clay used are "tierra amarilla", "tierra roja" and "tierra negra". Tierra amarilla and tierra roja are more sandy, whereas tierra negra is also known as "tierra fina".
</comment>
        <uncertainty>
