      <elementaryExchange id="0b97022b-d5f4-5cc4-bff5-bf3d20517aee" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" casNumber="007732-18-5" amount="0.000146375853296985" isCalculatedAmount="true" mathematicalRelation="(rainwater + clay_input*WWM_clay)/1000 - ((1.335-1)/1.335)/1000" elementaryExchangeId="2404b41a-2eed-4e9d-8ab6-783946fdf5d6" formula="H2O">
        <name xml:lang="en">Water</name>
        <unitName xml:lang="en">m3</unitName>
        <comment xml:lang="en">Calculated value. The wastewater was modelled as the water difference between the amount of rainwater used in the process together with the water contained in the clay, and the water evaporated from the brick after the firing process. The water is captured in a hole in the ground, where the mixing takes place. Therefore, the excess water is infiltrated by the soil and follows a natural process, where it eventually reaches groundwater or a water body. </comment>
        <uncertainty>
          <lognormal meanValue="0.000146375853296985" mu="-8.829332906536587" variance="0.04" varianceWithPedigreeUncertainty="0.044000000000000004"/>
