      <intermediateExchange id="d1c76cc4-693a-5c90-9f4c-67cff5048b3b" unitId="77ae64fa-7e74-4252-9c3b-889c1cd20bfc" amount="0.002990952465688138" intermediateExchangeId="759b89bd-3aa6-42ad-b767-5bb9ef5d331d" activityLinkId="2f7693b0-cf15-5abe-90a4-7fee1601df9d">
        <name xml:lang="en">electricity, medium voltage</name>
        <unitName xml:lang="en">kWh</unitName>
        <comment xml:lang="en">This value is estimated based on the heating requirements of a similar process. Specifically, this value represents the direct hydration of isopropanol, which was reported by Chauvel, Alain, Gilles Lefebvre, and L. Castex in "Petrochemical processes. Technical and economical characteristics Vol. 2." (1989). The value of electricity input for the latter process is 0.09 kWh per kg. All in all, we assume that the electricity requirements for the hydration of isopropylene, based on a Deutsche Texaco process, and 2-methyl-2-butene are similar.</comment>
        <uncertainty>
          <lognormal meanValue="0.002990952465688138" mu="-5.812163391908577" variance="0.02" varianceWithPedigreeUncertainty="0.08600000000000002"/>
          <pedigreeMatrix reliability="4" completeness="5" temporalCorrelation="5" geographicalCorrelation="5" furtherTechnologyCorrelation="3"/>
          <comment xml:lang="en">Estimation</comment>
        </uncertainty>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
