      <intermediateExchange id="e36c94dc-68e9-5267-acaa-466681528e8f" unitId="77ae64fa-7e74-4252-9c3b-889c1cd20bfc" amount="0.05966280220849464" intermediateExchangeId="759b89bd-3aa6-42ad-b767-5bb9ef5d331d" activityLinkId="30a7f3e9-969c-58ed-80ff-a448a5952c9f">
