  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="59dd9472-8266-51d2-89c5-144933c2abd0" activityNameId="0cdd090f-79cf-4e3a-86ea-bd9a6852945d" parentActivityId="8405e9c5-a1a0-4412-b36a-4ed7c9c9fecc" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for heat pump, 30kW</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts with the built infrastructure ready to use.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the infrastructure made accessible to the users. Transport or losses are considered irrelevant for this product.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'heat pump, 30kW', in the Global geography.</text>
          <text xml:lang="en" index="2">Transport from producers to consumers of this product in the geography covered by the market is included.</text>
          <text xml:lang="en" index="3">This is an immobile infrastructure, representing the product of a 30 kW heat pump unit, used in one family house. The product consists of three individual pumps, each of them having heat capacity of 10 kW and its lifetime is assumed to be 20 years.</text>
        </generalComment>
        <tag>ConvertedDataset</tag>
      </activity>
