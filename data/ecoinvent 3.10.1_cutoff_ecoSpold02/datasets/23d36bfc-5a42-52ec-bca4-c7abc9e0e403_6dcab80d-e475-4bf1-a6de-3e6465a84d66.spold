<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="23d36bfc-5a42-52ec-bca4-c7abc9e0e403" activityNameId="c7e09022-b252-45a7-898a-cb8ef3303ed6" parentActivityId="287f8a76-39d3-40ed-8c93-af77e89703d2" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">furnace production, wood chips, with silo, 300kW</activityName>
        <synonym xml:lang="en"> wood fired boiler production</synonym>
        <synonym xml:lang="en">wood chips boiler production</synonym>
        <includedActivitiesStart xml:lang="en">From reception of furnace components at the factory gate</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the disposal of the device in the end of its lifetime. The dataset includes the most important materials used for the fabrication of the furnace, the accumulator hot water tanks, the screw conveyor system and the chimney flue pipes: steel, concrete, insulating materials, electronic components, plastics, polystyrene, lubricating oil, paint. The dataset includes the basement for the furnace (around 17m2) and the wood chips storage silo in concrete (dimensions: 7x7x4m), which is assumed to be built in an external space out from an existing building. The dataset includes the land transformation and occupation and the energy and heat for the construction and the disposal of the device.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represent the production and the disposal of a wood chips burning furnace for local heating networks, with a storage silo for the wood chips.</text>
        </generalComment>
        <tag>biomass power</tag>
      </activity>
      <classification classificationId="844bb5bd-c3ab-491d-bd6b-baea2f2ba27b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2815:Manufacture of ovens, furnaces and furnace burners</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
      </geography>
      <technology technologyLevel="2">
        <comment>
          <text xml:lang="en" index="0">Furnace of modern technology available on the European and Swiss market, with tilting grate technology and combustion chambers in refractory bricks, designed for an optimal combustion process (cyclone integrated). The model of reference is a woodchip boiler, brand Froling mod.Turbomat 320 kW. It was compared with another model with similar technology, brand Schmid mod.Pyrotronic UTSR 300 kW. Represent the typical boiler for providing heat for local heating networks, commercial premises and multi-storey housing.</text>
          <imageUrl index="1">https://db3.ecoinvent.org/images/a72d5cfd-c704-4fe4-8ea1-803b35adf55e</imageUrl>
          <text xml:lang="en" index="2">Source of image: http://www.froeling.com/ch/produkte/hackgut-ab-150kw/froeling-turbomat.html</text>
        </comment>
      </technology>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">This model of furnace is commercialized since 2010 in Europe and Switzerland and is still available on the market (end 2011)</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
