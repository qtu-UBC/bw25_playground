<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="a04557d8-ba49-51f3-af49-eb511995acf2" activityNameId="76b42bc8-fea0-437a-b5d8-a79b8e416f71" parentActivityId="903d5758-9dcb-4239-95b4-4cc8d62147b7" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">concrete production, 30MPa, for drilled piles, with cement ZN/D</activityName>
        <synonym xml:lang="en">Transportbeton</synonym>
        <synonym xml:lang="en">béton de pieu foré</synonym>
        <synonym xml:lang="en">ready-mixed concrete</synonym>
        <synonym xml:lang="en">Bohrpfahlbeton</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts with the ingredients for the concrete at the factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Includes the whole manufacturing processes to produce ready-mixed concrete, internal processes (transport, etc.) and infrastructure. No administration is included. </includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset contains the production of concrete used for drilled piles with cement Susteno (technical abbreviation according to SIA 2049: ZN/D) by Holcim Switzerland from primary aggregates (no input of recycled gravel or sand). This type of concrete is used in concrete pile construction under dry or wet conditions with high requirements (alkali-aggregate reaction (AAR), frost-dew resistance).</text>
          <text xml:lang="en" index="1">Density: 2400 kg/m3, content of cement: 355 kg/m3</text>
          <text xml:lang="en" index="2">Exposition class according to SN EN 206: no normative requirements</text>
          <text xml:lang="en" index="3">This dataset is a copy of the existing data set for concrete production, for drilled piles, in Switzerland; the original type of cement has been replaced by the cement Susteno.</text>
        </generalComment>
      </activity>
      <classification classificationId="a82c98c0-1e7e-495d-bad9-8b6d0d12e5c5">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">construction materials/concrete</classificationValue>
      </classification>
      <classification classificationId="27f6acbc-2350-450e-9762-1ce00e12ecba">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2395:Manufacture of articles of concrete, cement and plaster</classificationValue>
      </classification>
      <geography geographyId="131278d6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">CH</shortname>
        <comment>
          <text xml:lang="en" index="0">For some exchanges RER-modules have been used as proxy</text>
        </comment>
      </geography>
      <technology technologyLevel="2">
        <comment>
          <text xml:lang="en" index="0">New development of a resource saving, low carbon concrete by Holcim Switzerland</text>
          <text xml:lang="en" index="1">The cement Susteno is made of processed mixed granulate from demolition projects as a major additive. The cement Susteno reduces the clinker content of the cement and contributes to a closed material cycle.</text>
        </comment>
      </technology>
      <timePeriod startDate="2020-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
