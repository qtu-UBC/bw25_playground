    <activityDescription>
      <activity specialActivityType="0" id="b4004b37-bd52-54ca-8fd8-6decd76640aa" activityNameId="3eb159cc-6a1d-4e64-baec-0ff23f85b06a" parentActivityId="7688c145-6b71-481c-aa98-40748235045a" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">ammonium chloride production</activityName>
        <synonym xml:lang="en">NH4Cl</synonym>
        <includedActivitiesStart xml:lang="en">Activity begins at factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Includes emissions to air and water after wastewater treatment.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">A simple approximation of the production of ammonium chloride from ammonia and hydrogen chloride. This dataset is based on stoichiometric calculations (yield is assumed to be 95%) and on the default estimations described in (Wernet et al 2012).</text>
        </generalComment>
      </activity>
      <classification classificationId="04d83550-7c85-44f3-916b-424730a81963">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2012:Manufacture of fertilizers and nitrogen compounds</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2012-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Simple estimation, carried out in 2012. No actual </text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
