      <intermediateExchange id="211cf6f5-005d-56e3-bd10-8591d533030d" unitId="ae252091-811b-461b-8e89-8f3075639eb1" amount="1.86277676887616E-08" isCalculatedAmount="true" mathematicalRelation="(42671)/(57268000000*40)" sourceId="e5c28d59-2abe-4005-ad85-433ffc9ca8e6" sourceYear="2014" sourceFirstAuthor="Itten, R." intermediateExchangeId="46712f19-9f47-43d7-a13d-5fac729070ba" activityLinkId="120c3684-37ba-5fb8-a287-302d520dc503">
        <name xml:lang="en">transmission network, electricity, medium voltage</name>
        <unitName xml:lang="en">km</unitName>
        <comment xml:lang="en">Estimation. Data taken over from Switzerland. Swiss data are calculated values based on the electricity transported in this voltage level (57268 GWh) and the total medium voltage power line length in Switzerland (cables and aerial lines - 42671 km). Lifetime is assumed to be 40 years. See Itten et al. 2014, Tab. 4.1 and Tab. 4.3.</comment>
        <uncertainty>
          <lognormal meanValue="1.86277676887616E-08" mu="-17.798612482981905" variance="0.1" varianceWithPedigreeUncertainty="0.1187"/>
