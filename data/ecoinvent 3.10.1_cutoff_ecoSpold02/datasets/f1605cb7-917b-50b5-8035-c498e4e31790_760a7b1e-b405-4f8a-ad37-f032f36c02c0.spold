        <shortname xml:lang="en">EC</shortname>
        <comment>
          <text xml:lang="en" index="0">Data for Ecuador, provided by a bamboo pole factory "Unodec ", located in Portoviejo, Ecuador.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
