      <elementaryExchange id="24745ab3-d5be-5c12-b5f5-4758e6b0728e" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" variableName="water_w" casNumber="007732-18-5" amount="0.000816521839372613" elementaryExchangeId="67c40aae-d403-464d-9649-c12695e43ad8" formula="H2O">
        <name xml:lang="en">Water, well, in ground</name>
        <unitName xml:lang="en">m3</unitName>
        <comment xml:lang="en">Calculated based on literature data published by the GENDORF Chemical Park. The factory produced an average of 2462760 tonnes of chemical substances (including intermediates) per year in the years 2015-2019. The average consumption of well water in the years 2015-2019 was 18607480 t per year. However, since the cooling water is modelled as an input, the amount of well water was adjusted to avoid double counting. 45% of the input amount of cooling water was deducted from the amount of well water, as that is the share of well water versus river water. This equals 0.00081652 m3/kg chemical produced.

References:
Chemiepark GENDORF, Umwelterklärung 2016, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit
Chemiepark GENDORF, Umwelterklärung 2017, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit
Chemiepark GENDORF, Umwelterklärung 2020, https://www.gendorf.de/Nachbarn/Umweltschutz/Industrie%20und%20Nachhaltigkeit</comment>
        <uncertainty>
          <lognormal meanValue="0.000816521839372613" mu="-7.110456898363866" variance="0.0006" varianceWithPedigreeUncertainty="0.0454"/>
          <pedigreeMatrix reliability="2" completeness="4" temporalCorrelation="2" geographicalCorrelation="5" furtherTechnologyCorrelation="4"/>
        </uncertainty>
