    <activityDescription>
      <activity specialActivityType="10" id="321f5903-e965-5423-a09b-07f68d09b5d6" activityNameId="191a9d1f-6916-4201-a98d-4bab0b9ce7f2" parentActivityId="66245ce2-3bca-48cf-a3d0-a8e7b3efc1c5" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market group for land use change, annual crop</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of markets that deliver 'land use change, annual crop', in geographies contained within the geography of this dataset.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'land use change, annual crop',  to the consumers of this product within the geography of Europe.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset is a market group. Market groups represent a 'market of markets'. Their purpose is to group a set of markets into larger, geographically relevant datasets.</text>
          <text xml:lang="en" index="1">Market groups are created for convenience and ease of use. They only group other markets and/or market groups contained within their geography.</text>
          <text xml:lang="en" index="2">Losses and relevant exchanges (transport, transport infrastructure, etc.) are not included in this dataset. They are present in the contained markets.  </text>
          <text xml:lang="en" index="3">This is the market group for 'land use change, annual crop', in Europe.</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
