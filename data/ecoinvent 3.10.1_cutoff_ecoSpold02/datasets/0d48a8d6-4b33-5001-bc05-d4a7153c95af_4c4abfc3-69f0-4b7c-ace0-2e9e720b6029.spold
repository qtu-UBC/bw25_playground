<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="0d48a8d6-4b33-5001-bc05-d4a7153c95af" activityNameId="e5010bce-aebb-4471-9b60-2ac20fecea15" parentActivityId="56c8e48c-c4b8-4f6d-8b2c-5d494a92f882" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">trimesoyl chloride production, for membrane filtration production</activityName>
        <includedActivitiesStart xml:lang="en">With trimesic acid and thionyl chloride. </includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">With production of trimesoyl chloride production. The dataset includes main raw materials and emissions to air of substance released by reaction. Approximation for processes have been used when substance required was not available. Energy and waste associated with this production is excluded due to lack of data. </includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of trimesoyl chloride intended to be used for membrane filtration module production. This is a rough estimate of the production efforts of trimesoyl chloride based on literature (patent). Production of trimesoyl chloride is achieved by catalytic reaction of trimesic acid and thionyl chloride. FeCl3 acts as a catalyst. The reaction is: </text>
          <text xml:lang="en" index="1">C9H6O6 + 3SOCl2  ---(FeCl3) →C9H3Cl3O3+3SO2+3HCl</text>
        </generalComment>
      </activity>
      <classification classificationId="28f738cc-bb73-48f8-b633-f83fb9bc5ddc">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2011:Manufacture of basic chemicals</classificationValue>
      </classification>
      <classification classificationId="7ac1cbc6-1385-4a68-8647-ed7aa78db201">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">chemicals/organics</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2012-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Arbitrary time period chosen for the proxy. </text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
