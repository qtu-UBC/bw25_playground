<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="83ccaa4d-b4ba-5e21-9b59-ce7899c66bd5" activityNameId="f6d8c5f7-f163-461c-afa4-c2ec488eba4b" parentActivityId="524da8bc-3c35-4c05-9315-5a8417e4f0dd" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">furnace production, pellets, 9kW</activityName>
        <synonym xml:lang="en">wood fired stove production</synonym>
        <synonym xml:lang="en"> wood pellets stove production</synonym>
        <includedActivitiesStart xml:lang="en">From reception of furnace components at the factory gate</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the disposal of the device in the end of its lifetime. The dataset includes the most important materials used for the fabrication of the stove and the chimney flue pipes: steel, rock wool, aluminum, cast iron, ceramic tiles, lubricating oil, electronic components. It includes also the energy and heat for the construction and the disposal of the elements of the furnace. The dataset doesn't include the basement in concrete for the stove installation and the pellet storage silo (not necessary). Since it is used for domestic heating, transformation and land occupation are not considered.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represent the production and the disposal of a wood-pellets burning stove for domestic heating. Its assumed lifetime is 15 years, with an estimated operation time of 1700 h/a.</text>
        </generalComment>
        <tag>biomass power</tag>
      </activity>
      <classification classificationId="844bb5bd-c3ab-491d-bd6b-baea2f2ba27b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2815:Manufacture of ovens, furnaces and furnace burners</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
      </geography>
      <technology technologyLevel="2">
        <comment>
          <text xml:lang="en" index="0">Automatic pellets stove available on the European and Swiss market. The model of reference is the stove from Austrian brand Rika, model Como. Represent the typical wood pellets device for residential wood combustion in a domestic environment.</text>
          <imageUrl index="1">https://db3.ecoinvent.org/images/fed30e40-6615-422a-879f-73405d866485</imageUrl>
          <text xml:lang="en" index="2">Source of the image: http://www.rika.at/datasheet.php?IDofen=19</text>
        </comment>
      </technology>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">This stove model is commercialized since 2010 in Europe and Switzerland and is still available on the market (end 2011)</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
