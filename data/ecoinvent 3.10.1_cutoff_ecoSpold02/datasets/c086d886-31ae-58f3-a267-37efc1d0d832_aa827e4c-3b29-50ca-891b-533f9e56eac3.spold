<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="c086d886-31ae-58f3-a267-37efc1d0d832" activityNameId="b7568327-f6ca-52b0-afad-4c150451b6af" parentActivityId="1d23359b-bf98-5c6d-a6ba-c511d76236b7" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">planting with starter fertiliser or amendment, by no till planter</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts from the agricultural field foreseen to be processed.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The inventory takes into account the diesel fuel consumption and the amount of agricultural machinery and of the shed, which has to be attributed to the seeding operation. Also taken into consideration is the amount of emissions to the air from combustion and the emissions to soil from tyre abrasion during the work process. Seeds and fertilisers are not taken into account. Not included are dust other than from combustion. This activity ends with the transfer back to the shed and uncoupling of the implement from the tractor.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the service of planting by no till planter, with starter fertiliser or amendment. Seed and fertiliser are not included. The dataset covers the application of seeds and starter fertiliser in the field with a tractor of 250 hp and 10771 kg coupled to an implement that weighs 16000 kg. The functional unit (FU) is one ha seeded and the operation time is 0.21 h/FU.</text>
          <text xml:lang="en" index="1"> 40 m² are occupied inside the shed. The implement can be used to fertilising besides seeding. In this case, both activities are made in the same operation.</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is extrapolated from the geography of Brazil. Data quality indicators are adjusted accordingly.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Fuel consumption and emissions per kg diesel have been extrapolated to the US, but others inputs were taken from the original values.</text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
