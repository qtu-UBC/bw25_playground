        <property propertyId="c74c3729-e577-4081-b572-a283d2561a75" amount="0.249896086420479" isDefiningValue="false" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
          <name xml:lang="en">carbon content, fossil</name>
          <unitName xml:lang="en">dimensionless</unitName>
          <comment xml:lang="en">Estimated value. This product is the result of the reaction of sulfur trioxide (SO3) and dodecanol (C12H26O). Dodecanol can be both produced from coconut oil as well as from the Ziengler process (from ethylene). We therefore assume 50%carbon fossil and 50% non fossil. </comment>
        </property>
        <property propertyId="6393c14b-db78-445d-a47b-c0cb866a1b25" amount="0.249896086420479" isDefiningValue="false" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
          <name xml:lang="en">carbon content, non-fossil</name>
          <unitName xml:lang="en">dimensionless</unitName>
          <comment xml:lang="en">Estimated value. This product is the result of the reaction of sulfur trioxide (SO3) and dodecanol (C12H26O). Dodecanol can be both produced from coconut oil as well as from the Ziengler process (from ethylene). We therefore assume 50%carbon fossil and 50% non fossil. </comment>
        </property>
        <property propertyId="3a0af1d6-04c3-41c6-a3da-92c4f61e0eaa" amount="1.0" isDefiningValue="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
