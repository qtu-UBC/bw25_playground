      <parameter parameterId="de08658d-936a-46b6-b8e4-739e9b3f2399" amount="0.0243" variableName="electricity_transmission_losses" mathematicalRelation=" electricity_losses_total*0.648*0.5" isCalculatedAmount="true" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
        <name xml:lang="en">electricity transmission losses</name>
        <unitName xml:lang="en">dimensionless</unitName>
        <uncertainty>
          <lognormal meanValue="0.0243" mu="-3.7173" variance="0.006" varianceWithPedigreeUncertainty="0.006"/>
          <pedigreeMatrix reliability="1" completeness="1" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
          <comment xml:lang="en">Transmission losses AND transformation losses are integrated in this number.</comment>
        </uncertainty>
        <comment xml:lang="en">Measured/Estimated value. Losses of electricity during transmission and transformation in the high voltage grid. 2005 data: LV MV HV TOTAL Consumed Electricity (GWh) 89 423 18 386 62 632 170 440 Losses (GWh) 8 280 1 246 3 257 12 783 Losses per voltage % 9,3% 6,8% 5,2% 7,5% % of total losses 64,8% 9,7% 25,5% (The consumed energy includes the losses) Source: http://www.regie-energie.qc.ca/audiences/3541-04/RepHqdDDR/HQD-14_doc09_3541_01nov04.pdf It is estimated that the losses are split between transformation and transmission according to the split from Swiss datasets: High voltage: 100% is allocated to the market (as it contains transformation and transmission) Medium voltage: 38.5% of losses at this voltage are allocated to transmission and 61.5% to transformation Low voltage: 50% of losses at this voltage are allocated to transformation and 50% to transmission Losses of electricity during transfrormation</comment>
      </parameter>
      <parameter parameterId="c284793b-4b01-4b90-a12d-99b46685630e" amount="0.829457651958556" variableName="fraction" mathematicalRelation="89423/(18386+89423)" isCalculatedAmount="true" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
        <name xml:lang="en">fraction</name>
        <unitName xml:lang="en">dimensionless</unitName>
        <uncertainty>
          <lognormal meanValue="0.829457651958556" mu="-0.187" variance="0.0" varianceWithPedigreeUncertainty="0.04"/>
          <pedigreeMatrix reliability="5" completeness="1" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
        <comment xml:lang="en">Calculated/Estimated value. This parameter is used to split the common flows between the medium and the low voltage networks, as Hydro-Quebec data collection was made as a whole (the same division manages both networks). The split is based on the consumed energy at each voltage. This amounts have been estimated based on the consumption per electricity rate. LV MV HV TOTAL Consumed Electricity (GWh) 89 423 18 386 62 632 170 440 Source: http://www.regie-energie.qc.ca/audiences/3541-04/RepHqdDDR/HQD-14_doc09_3541_01nov04.pdf Table R-28.4 nan</comment>
      </parameter>
      <parameter parameterId="c2fdb4e1-7a14-40be-89f7-19806168530c" amount="216260000000.0" variableName="net_electricity_2008" mathematicalRelation="216260000000" isCalculatedAmount="true" unitId="77ae64fa-7e74-4252-9c3b-889c1cd20bfc">
        <name xml:lang="en">net electricity production in 2008</name>
        <unitName xml:lang="en">kWh</unitName>
        <uncertainty>
          <lognormal meanValue="216260000000.0" mu="26.0997" variance="0.0006" varianceWithPedigreeUncertainty="0.0006"/>
          <pedigreeMatrix reliability="1" completeness="1" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
        <comment xml:lang="en">Calculated value. Sum of produced and imported energy (including energy produced at the low voltage by photovoltaic panels) in 2008 minus losses and used at higher voltages and in transformation losses from High to Medium and from Medium to Low voltage. Electricity imports and productions in 2008 kWh high voltage, hydro, reservoir, import from CA-NF 2,90E+10 high voltage, import from CA-NB 1,30E+08 high voltage, import from CA-ON 5,51E+09 high voltage, import from NPCC, US only 1,35E+09 hydro, reservoir, non-alpine region 1,02E+11 hydro, run-of-river 6,11E+10 nuclear, PWR, heavy water moderated 3,60E+09 wind, &lt;1MW, onshore 1,06E+08 wind, 1-3MW, onshore 1,39E+09 wind, 2.3MW, precast concrete tower, onshore 3,28E+08 PV, 3kWp multi-Si, panel, mounted 6195,1 PV, 3kWp , single-Si, panel, mounted 4974,2 PV, 570kWp open ground installation, multi-Si 140,18 Annual production volumes are extracted from the corresponding dataset. LV MV HV TOTAL Consumed Electricity (GWh) 89 423 18 386 62 632 170 440 % of total consumed 52% 11% 37% The total consumed per voltage includes the losses and the consumption at each level.GWh amounts in the table are valid for 2004, they are used to calculate the percentage used at each voltage Source: http://www.regie-energie.qc.ca/audiences/3541-04/RepHqdDDR/HQD-14_doc09_3541_01nov04.pdf nan</comment>
      </parameter>
      <parameter parameterId="a5b1977a-ec47-4123-beac-51e2c634cfa3" amount="0.075" variableName="electricity_losses_total" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
        <name xml:lang="en">total electricity losses within the country</name>
        <unitName xml:lang="en">dimensionless</unitName>
        <uncertainty>
          <lognormal meanValue="0.075" mu="-2.5903" variance="0.0006" varianceWithPedigreeUncertainty="0.0006"/>
          <pedigreeMatrix reliability="1" completeness="1" temporalCorrelation="1" geographicalCorrelation="1" furtherTechnologyCorrelation="1"/>
        </uncertainty>
        <comment xml:lang="en">Measured value. Losses of electricity during transmission and transformation in the high voltage grid. LV MV HV TOTAL Consumed Electricity (GWh) 89 423 18 386 62 632 170 440 Losses (GWh) 8 280 1 246 3 257 12 783 Losses per voltage % 9,3% 6,8% 5,2% 7,5% % of total losses 64,8% 9,7% 25,5% Source: http://www.regie-energie.qc.ca/audiences/3541-04/RepHqdDDR/HQD-14_doc09_3541_01nov04.pdf Total losses of electricity from the net electricity fed into the grid until arriving at the end user (transmission and transformation losses).</comment>
      </parameter>
    </flowData>
    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Data collection from the company including all its activities</samplingProcedure>
        <extrapolations xml:lang="en">Assumptions for the amount of transmission network per kWh transported and emissions per kWh are based on Swiss data. Electricity losses data are based on IEA data and on data from Switzerland.</extrapolations>
      </representativeness>
      <review reviewedMajorRelease="3" reviewedMinorRelease="0" reviewedMajorRevision="0" reviewedMinorRevision="6" reviewerId="9a963412-20a7-428b-8740-3582e217c4b6" reviewerName="Carl Vadenbo" reviewerEmail="vadenbo@ifu.baug.ethz.ch" reviewDate="2015-07-29">
        <details>
          <text xml:lang="en" index="0">The update of the whole electricity sector for the ecoinvent v3.2 database consist of hundreds of datasets. All these datasets have passed through a streamlined review processes where the underlying modelling of production volumes, technology shares and efficiencies was reviewed in detail prior to the datasets being submitted to the database.</text>
        </details>
      </review>
