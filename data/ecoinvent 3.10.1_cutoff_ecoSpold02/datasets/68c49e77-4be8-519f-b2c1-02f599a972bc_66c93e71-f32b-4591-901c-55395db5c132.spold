<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <activityDataset>
    <activityDescription>
      <activity specialActivityType="4" id="68c49e77-4be8-519f-b2c1-02f599a972bc" activityNameId="19b983f0-8d57-487e-ab00-13321272916d" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">electricity, high voltage, production mix</activityName>
        <generalComment>
          <text xml:lang="en" index="0">The shares of electricity technologies on this market are valid for the year 2020-21. The fiscal year in India starts on 1 April 2020 and ends 31 March 2021. The shares been calculated by the data provider and don't correspond with the production volumes entered in the undefined datasets of the different electricity supplying technologies. The shares have been calculated based on statistics from 2020-21:</text>
          <text xml:lang="en" index="1">Electricity generation data is sourced from:</text>
          <text xml:lang="en" index="2">- General Review 2022, All India Electricity Statistics containing data for the year 2020-21, Central Electricity Authority, 2022</text>
          <text xml:lang="en" index="3">Technology splits are calculated based on:</text>
          <text xml:lang="en" index="4">- S&amp;P Global (2021). Platts World Electric Power Plant database (WEPP), version December 2021. https://www.spglobal.com</text>
          <text xml:lang="en" index="5">- The windpower (2022). Wind farms. https://www.thewindpower.net/windfarms_list_en.php</text>
          <text xml:lang="en" index="6">- For hydro the technology split was determined through individual research For each power plant.</text>
          <text xml:lang="en" index="7">Regional import are calculated based on:</text>
          <text xml:lang="en" index="8">- Grid-India (2021). Grid Controller of India Limited. URL: https://posoco.in/reports/monthly-reports/</text>
        </generalComment>
      </activity>
      <geography geographyId="25457a88-a525-4fd8-b73d-72fd3f37fc74">
        <shortname xml:lang="en">IN-Western grid</shortname>
      </geography>
      <technology/>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
