<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="3f71a33f-fd5d-5001-9e87-95a307503bd7" activityNameId="5fee2996-526f-43b9-93ec-59ba94d31192" parentActivityId="37104478-9865-4b32-a877-7c4c4ad7d9c7" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">copper sulfate production</activityName>
        <synonym xml:lang="en">CuSO4</synonym>
        <synonym xml:lang="en">bluestone</synonym>
        <synonym xml:lang="en">copper(II) sulfate</synonym>
        <synonym xml:lang="en">cupric sulfate</synonym>
        <synonym xml:lang="en">blue vitriol</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts when the raw materials enters the process.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Materials entering the process are included as well as energy uses, infrastructure and emissions. </includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">Copper sulfate (CuSO4) is a salt which exists as a series of compounds that differ in their degree of hydration. This activity presents basic production of copper sulfate pentahydrate.</text>
          <text xml:lang="en" index="1"></text>
          <text xml:lang="en" index="2">Data were obtained via stochiometric calculation. The amount of energy consumed (electricity and heat), cooling water and facilities is estimated based on data from Gendorf (2000).</text>
        </generalComment>
      </activity>
      <classification classificationId="28f738cc-bb73-48f8-b633-f83fb9bc5ddc">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2011:Manufacture of basic chemicals</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Production of copper sulfate varies depending on the degree of hydration which needs to be reached. This activity presents basic reaction with which copper sulfate pentahydrate is produced.</text>
          <text xml:lang="en" index="1"></text>
          <text xml:lang="en" index="2">Chemical reaction:</text>
          <text xml:lang="en" index="3"></text>
          <text xml:lang="en" index="4">CuO + H2SO4 -&gt; CuSO4 + H2O</text>
        </comment>
      </technology>
      <timePeriod startDate="2006-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">This activity presents basic chemical process and do not really change in time.</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
