      <elementaryExchange id="81bbe1d9-0421-59f2-af75-d42e56e16bcf" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" casNumber="007732-18-5" amount="0.000101631557855054" isCalculatedAmount="true" mathematicalRelation="(rainwater + clay_input*WWM_clay + straw_input*WWM_straw)/1000 - water_to_air" elementaryExchangeId="2404b41a-2eed-4e9d-8ab6-783946fdf5d6" formula="H2O">
        <name xml:lang="en">Water</name>
        <unitName xml:lang="en">m3</unitName>
        <comment xml:lang="en">Calculated value. The wastewater was modelled as the water difference between the amount of rainwater used in the process together with the water contained in the clay and straw and the water evaporated to air during the natural drying of the adobe brick. The water is captured in a hole in the ground, where the mixing takes place. Therefore, the excess water is infiltrated by the soil and follows a natural process, where it eventually reaches groundwater or a water body. </comment>
        <uncertainty>
          <lognormal meanValue="0.000101631557855054" mu="-9.194156462239235" variance="0.04" varianceWithPedigreeUncertainty="0.046000000000000006"/>
          <pedigreeMatrix reliability="3" completeness="4" temporalCorrelation="1" geographicalCorrelation="5" furtherTechnologyCorrelation="1"/>
        </uncertainty>
