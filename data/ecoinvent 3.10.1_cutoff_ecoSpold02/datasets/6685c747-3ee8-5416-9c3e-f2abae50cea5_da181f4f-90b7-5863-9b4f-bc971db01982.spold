<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="6685c747-3ee8-5416-9c3e-f2abae50cea5" activityNameId="ff371fcd-124c-533a-bfa1-5787f5a8c442" parentActivityId="c32752d7-1f2e-5b2c-9973-d504fb09d8fe" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">adobe brick production</activityName>
        <synonym xml:lang="en"> Mudbrick</synonym>
        <synonym xml:lang="en">Lehmziegel</synonym>
        <synonym xml:lang="en"> mud-brick</synonym>
        <includedActivitiesStart xml:lang="en">This dataset starts with the reception of raw materials at the adobe brick production site.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This dataset ends with the storage of the produced adobe brick.This dataset includes the whole manufacturing process to produce adobe bricks (reception of raw materials, dosing, mixing, forming, drying, and storage). The dataset does not include the packaging.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset is a copy of the regional dataset which describes the production of adobe bricks in the area of San José de Balzay in Ecuador and represents the production of 1 kg of adobe brick. Uncertainty is adjusted accordingly to represent the global situation. </text>
        </generalComment>
      </activity>
      <classification classificationId="a5071d0a-6e4e-4fb6-a98b-940902b9a3c9">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2392:Manufacture of clay building materials</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">This dataset represents the production of 1 kg adobe brick at global level. Original data comes from visits to factories in Ecuador. The uncertainty was adjusted accordingly.  </text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Current production technology. This dataset is a copy of the EC geography, and considered representative of the global production of adobe bricks. The manufacturing process includes the reception of raw materials, dosing, mixing, forming, drying, and storage of adobe bricks. The overall process applied in Ecuador implies that a selection of 2 or 3 types of clay is prepared, and mixed with straw and rainwater. The mix is made with the help of the trampling of a horse, then placed in a wooden mold with the shape of a brick (forming process, done by hands). The material in excess on the surface is taken away and reused for the next brick. The mass in the mold is left to dry under the sun. No electricity powered machine nor heat are used during the whole process. </text>
        </comment>
      </technology>
      <timePeriod startDate="2022-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">The time period is from 2022 (year of data collection) to 2023 (year of dataset compilation).</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
