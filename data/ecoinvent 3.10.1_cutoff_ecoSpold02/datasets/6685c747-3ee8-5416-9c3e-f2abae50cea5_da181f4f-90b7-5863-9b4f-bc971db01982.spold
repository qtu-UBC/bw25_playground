      <parameter parameterId="819a42ab-750e-582a-b9e0-2aa023e64b0f" amount="21.96" variableName="adobe_brick_mass" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
        <name xml:lang="en">adobe_brick_mass</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Mass of an adobe brick. Data from field visit, Cuenca, Ecuador.</comment>
      </parameter>
      <parameter parameterId="3fd0deb0-dd85-5dfa-93ea-5dcc7cc4c538" amount="24.2" variableName="clay_mass" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
        <name xml:lang="en">clay_mass</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">This value represents the sum of four types of clay used for the production of 1 kg of adobe brick, according to measurements and the information provided by the owner of the factory. The types of clay used are "fina, cera, cascajo and chagralpa". 
</comment>
      </parameter>
