        <property propertyId="a301a838-7975-4d89-9e74-8eb77ad03cd1" amount="0.680720880635528" isDefiningValue="false" isCalculatedAmount="false" unitId="577e242a-461f-44a7-922c-d8e1c3d2bf45">
