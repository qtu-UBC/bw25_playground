<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="3eb68265-7c0e-5c36-b106-8e5de5317b80" activityNameId="78b9cf2e-b44c-4e91-bab0-02d009f1d16b" parentActivityId="59aae60c-24b8-4ccf-bceb-fc77d60aa95c" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">sawing and planing, azobe, air dried</activityName>
        <synonym xml:lang="en">Lophira alata</synonym>
        <synonym xml:lang="en">Ekki</synonym>
        <synonym xml:lang="en">Bongassi</synonym>
        <includedActivitiesStart xml:lang="en">Sawing and planing processes starting from debarked Azobe logs at sawmill in Europe.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Includes transportation to sawmill by lorry; sawing and plaining of azobe log in 20 mm sawn timber boards; natural drying is assumed; 30% of log input (including sapwood) is generated as co-product that is sold or is used for energy recovery used outside this process.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the sawing and planing of one m3 Azobe logs. The debarked Azobe wood logs have been imported to Europe from Central Africa. </text>
          <text xml:lang="en" index="1"></text>
          <text xml:lang="en" index="2">The sawing and planing process produces panels of which production data are from a sawmill in the Netherlands. The sawmill uses modern equipment and is considered representative for Europe.</text>
          <text xml:lang="en" index="3"> </text>
          <text xml:lang="en" index="4">Natural drying is assumed. It is also assumed that 30% of log input, including sapwood, is generated as co-product that is sold or used for energy recovery outside this process.</text>
        </generalComment>
      </activity>
      <classification classificationId="45e0d63f-f176-49f2-a053-8033c5f89e77">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1610:Sawmilling and planing of wood</classificationValue>
      </classification>
      <classification classificationId="b134c592-95d3-4412-a56d-6c42650a5dbc">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">wooden materials/processing</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">Wood from Central Africa, sawing in Europe</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Data extrapolated from Meranti window production in the Netherlands. Depending on sawing technology, specific wood density of a particular log and type of sawn timber produced, data may vary</text>
        </comment>
      </technology>
      <timePeriod startDate="2000-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
