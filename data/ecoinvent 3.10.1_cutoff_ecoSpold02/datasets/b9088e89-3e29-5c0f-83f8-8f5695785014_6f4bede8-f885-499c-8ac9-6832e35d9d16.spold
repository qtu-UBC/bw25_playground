      <elementaryExchange id="c0170ddc-28b8-56e4-b447-582817eccf84" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" casNumber="007732-18-5" amount="0.014707" elementaryExchangeId="fc1c42ce-a759-49fa-b987-f1ec5e503db1" formula="H2O">
        <name xml:lang="en">Water, cooling, unspecified natural origin</name>
        <unitName xml:lang="en">m3</unitName>
        <comment xml:lang="en">Calculated based on literature data published by the GENDORF Chemical Park. The factory produced an average of 2462760 tonnes of chemical substances (including intermediates) per year in the years 2015-2019. The average amount of cooling water released in the years 2015-2019 was 34408800 t per year. It was assumed that 5% of the cooling water was emitted to air during its use, therefore, to calculate the input of cooling water, the output value reported by GENDORF was scaled up by the factor 1/0.95. This equals 0.014707 m3/kg chemical produced.</comment>
        <uncertainty>
          <lognormal meanValue="0.014707" mu="-4.2194317080639605" variance="0.0006" varianceWithPedigreeUncertainty="0.0852"/>
          <pedigreeMatrix reliability="2" completeness="4" temporalCorrelation="5" geographicalCorrelation="5" furtherTechnologyCorrelation="4"/>
        </uncertainty>
        <synonym xml:lang="en">oxidane</synonym>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.0011486573821716322" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
