<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="b9088e89-3e29-5c0f-83f8-8f5695785014" activityNameId="760fd28f-7f6f-41fc-8188-77e1cc94abe2" parentActivityId="36e9d7ad-ef9e-5ab4-93ba-30f271864f6e" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">ammonium sulfate production</activityName>
        <synonym xml:lang="en">Ammonsulfat</synonym>
        <includedActivitiesStart xml:lang="en">The activity starts when the raw materials enter the process.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">Materials entering the process are included as well as energy uses, infrastructure and emissions. The dataset considers no heat input.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This activity represents the production of ammonium sulfate from ammonia and sulfuric acid.</text>
          <text xml:lang="en" index="1">Ammonia and sulfuric acid react given the formula: 2 NH3 + H2SO4 → (NH4)2SO4.</text>
          <text xml:lang="en" index="2">The reaction yield is assumed to be 98.1%.</text>
          <text xml:lang="en" index="3">The vast majority of ammonium sulfate produced worldwide is further used in agriculture as a fertiliser.</text>
          <text xml:lang="en" index="4">Ammonium sulfate is mostly produced as by-product but this dataset describes a primary production of it. </text>
          <text xml:lang="en" index="5">The reaction is highly exothermic and it is assumed that it does not require an external input of heat. </text>
          <text xml:lang="en" index="6">References:</text>
          <text xml:lang="en" index="7">Gendorf (2016) Umwelterklärung 2015, Werk Gendorf Industriepark, www.gendorf.de</text>
          <text xml:lang="en" index="8">For more information on the model please refer to the dedicate ecoinvent report, access it in the Report section of ecoQuery (http://www.ecoinvent.org/login-databases.html)</text>
          <text xml:lang="en" index="9">Zapp, K.-H., Wostbrock, K.-H., Schäfer, M., Sato, K., Seiter, H., Zwick, W., … Leiter, H. (2012). Amino acids. In Ullmann’s Encyclopedia of Industrial Chemistry. In Ullmann’s Encyclopedia of Industrial Chemistry (Vol. 3, pp. 1–58). https://doi.org/10.1002/14356007.a02</text>
        </generalComment>
      </activity>
      <classification classificationId="04d83550-7c85-44f3-916b-424730a81963">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2012:Manufacture of fertilizers and nitrogen compounds</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">The inputs to the process are calculated based on stoichiometry and literature data, they are therefore considered to be valid for the chosen geography.</text>
        </comment>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="1998-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
