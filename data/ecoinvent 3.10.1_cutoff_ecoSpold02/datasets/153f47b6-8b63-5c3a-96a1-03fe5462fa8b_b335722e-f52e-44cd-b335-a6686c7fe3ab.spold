      <activity specialActivityType="0" id="153f47b6-8b63-5c3a-96a1-03fe5462fa8b" activityNameId="9d78a238-8cbe-4180-98ce-8c336eb14ebc" parentActivityId="3e33357f-06f7-4c69-b141-a1299d1318a6" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">treatment of used laptop computer, manual dismantling</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts with the waste being available at the gate of the treatment facility. Collection and transportation of the waste to the treatment plant is not included.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This  activity ends when the used laptop computer has been dismantled manually.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">The process represents the treatment 'used laptop computer' by manual dismantling in various fractions.</text>
        </generalComment>
      </activity>
      <classification classificationId="db303709-3eac-4c8b-9ed9-7e4888240c50">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3830:Materials recovery</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">Modelling parameters are not specific to this geography.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Commonly performed manual dismantling activities</text>
        </comment>
      </technology>
      <timePeriod startDate="2005-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
