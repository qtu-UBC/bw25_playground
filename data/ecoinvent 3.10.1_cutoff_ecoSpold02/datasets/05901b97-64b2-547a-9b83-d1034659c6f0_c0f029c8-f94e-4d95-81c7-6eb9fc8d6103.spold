  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="05901b97-64b2-547a-9b83-d1034659c6f0" activityNameId="6d42064f-ba3b-41d1-881b-406742ea903b" parentActivityId="a8bf56ef-b016-48ea-899f-8ec021f265c4" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for furnace, wood chips, softwood storage area, 300kW</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts with the built infrastructure ready to use.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the infrastructure made accessible to the users. Transport or losses are considered irrelevant for this product.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This is the market for  'furnace, wood chips, softwood storage area, 300kW', in the Global geography.</text>
          <text xml:lang="en" index="2">Transport from producers to consumers of this product in the geography covered by the market is included.</text>
          <text xml:lang="en" index="3">This is an immobile infrastructure, representing the product of a softwood wood chips furnace that includes the storage area. It has a lifetime of 20 years for the furnace the automatic control system, 80 years for the chimney, while its operation time is 2,100 h/year and capacity of 300 kW. A furnace of this capacity is used to heat a large building complex or to supply a smaller heat network.The process includes the most important materials used for the fabrication of the furnace, the water storage and the chimney, their decommission, softwood storage and energy used for the construction.   	</text>
        </generalComment>
        <tag>ConvertedDataset</tag>
      </activity>
      <classification classificationId="844bb5bd-c3ab-491d-bd6b-baea2f2ba27b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2815:Manufacture of ovens, furnaces and furnace burners</classificationValue>
      </classification>
