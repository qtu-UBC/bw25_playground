      <elementaryExchange id="fc780c3a-e7bc-5303-b06a-51fdf53093ee" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" casNumber="007732-18-5" amount="0.0150390618655492" elementaryExchangeId="2404b41a-2eed-4e9d-8ab6-783946fdf5d6" formula="H2O">
