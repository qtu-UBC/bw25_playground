<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="18403a28-c729-5beb-974d-0cbad11422df" activityNameId="94d747a2-84a1-5980-ad62-99f9f44616b0" parentActivityId="accb86df-3f38-5a57-a9a8-bb6138ac52a9" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">stalk shredding</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts from the agricultural field foreseen to be processed. </includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the production of stalk shredding. The inventory factors in diesel consumption, the allocation of agricultural machinery and shed resources specifically for the shredding process. It also considers emissions to the air from combustion and emissions to the soil from tire abrasion during the shredding operation. The work process in the dataset includes various activities: transportation to the field (assuming a 1 km distance), field work on a 1 ha land parcel, transportation back to the farm, and concluding work. Overlapping during field operations is considered. The database does not account for the quantity of harvested material, dust unrelated to combustion, or noise production.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset models the service of stalk shredding in relation to an agricultural field with an extension of one hectare (1 ha)</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory is extrapolated from the Global geography. Data quality indicators from adjusted accordingly.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Fuel consumption and emissions per kg diesel have been extrapolated to the US, while others inputs were taken from the original values.</text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
