<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="9454d5c3-1bdc-54b3-a8a0-6519d69ecc2c" activityNameId="c0b73cf1-9d05-4040-814e-972eb049c76f" parentActivityId="03d819f0-5f24-4e3c-bc4e-520d3a705eea" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">furnace production, pellets, 25kW</activityName>
        <synonym xml:lang="en">wood pellets boiler production</synonym>
        <synonym xml:lang="en"> wood fired boiler production</synonym>
        <includedActivitiesStart xml:lang="en">From reception of furnace components at the factory gate</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the disposal of the device in the end of its lifetime. The dataset includes the most important materials used for the fabrication of the furnace, the accumulator hot water tank (800 liters), the automatic screw conveyor and the chimney flue pipes: steel, rock wool, concrete, polystyrene, plastics, electronic components, lubricating oil, paint. The dataset includes the concrete basement for the furnace, the land transformation and occupation and the energy and heat for the construction and the disposal of the device. The dataset doesn't include the storage silo for pellets, since this boiler is has an internal pellet hopper</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represent the production and the disposal of a wood-pellets burning furnace for domestic heating system.</text>
        </generalComment>
        <tag>biomass power</tag>
      </activity>
      <classification classificationId="844bb5bd-c3ab-491d-bd6b-baea2f2ba27b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2815:Manufacture of ovens, furnaces and furnace burners</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
      </geography>
      <technology technologyLevel="2">
        <comment>
          <text xml:lang="en" index="0">Boiler of modern technology available on the European and Swiss market. The model of reference is a wood pellets boiler, mod.SL-P from Austrian brand Lindner&amp;Sommerauer. It was compared with other similar models from brands Oekofen and Hargassner. Represent the typical pellets boiler for a single house central heating.</text>
          <imageUrl index="1">https://db3.ecoinvent.org/images/ea9bb82c-bf91-4a78-b092-fafe5392f01a</imageUrl>
          <text xml:lang="en" index="2">Source of image: http://www.sl-heizung.at/</text>
        </comment>
      </technology>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">This model of furnace is commercialized since 2010 in Europe and Switzerland and is still available on the market (end 2011)</text>
        </comment>
      </timePeriod>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
