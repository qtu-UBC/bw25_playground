  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="e3234f1c-01d1-5054-b3f8-936678a7fde3" activityNameId="36f31696-8db2-44e4-aa5d-87320f8395b8" parentActivityId="ffa619e4-c400-53b4-9f84-15008ade3f43" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for cement, type general use</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the gate of the activities that produce 'cement, type general use', within the geography of Ecuador.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 'cement, type general use', to the consumers of this product. Transport is included. Product losses during transportation are assumed negligible and are therefore not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This market represents the 'cement, type general use' for construction in Ecuador.</text>
          <text xml:lang="en" index="2">Transport from producers to consumers of this product in the geography covered by the market is included. In this market, expert judgement was used to develop product specific transport distance estimations.</text>
          <text xml:lang="en" index="3">The cement, type general use is produced by adding a quantity of calcium sulfate, usually in form of gypsum (3%), and limestone (39%) to the clinker (58%). Then, in a cement mill, the mixture is ground to form the finished industrial powder.</text>
        </generalComment>
      </activity>
      <classification classificationId="36cd730c-4485-4fe9-8efe-8850f771796d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2394:Manufacture of cement, lime and plaster</classificationValue>
      </classification>
      <geography geographyId="0d0e72a0-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">EC</shortname>
        <comment>
          <text xml:lang="en" index="0">Transportation distance and truck type based on expert opinion specific for Ecuador.</text>
        </comment>
      </geography>
      <technology/>
      <timePeriod startDate="2019-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true">
        <comment>
          <text xml:lang="en" index="0">Time period was set identical to the corresponding transformation activity.</text>
