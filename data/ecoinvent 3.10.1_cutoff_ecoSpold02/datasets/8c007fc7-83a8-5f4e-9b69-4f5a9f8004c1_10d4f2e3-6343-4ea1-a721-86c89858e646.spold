  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="8c007fc7-83a8-5f4e-9b69-4f5a9f8004c1" activityNameId="063e2036-d47a-47a6-a109-480a84fbe1dd" parentActivityId="bee2a2f7-1f72-4643-b432-7b5eb66a902d" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">treatment of waste plastic plaster, collection for final disposal</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts with the waste being available at the gate of the treatment facility. Transportation of the waste to the treatment plant is not included.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity includes particulate matter emissions from dismantling and handling, and final disposal of waste material.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">The process represents the collection of 'waste plastic plaster' for final disposal. The waste contains 1kg plastic plaster, while its density is 1300 kg/m3.</text>
        </generalComment>
      </activity>
      <classification classificationId="9a63625a-358b-4c1d-bf95-50ba038a759b">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3821:Treatment and disposal of non-hazardous waste</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">Modelling parameters are not specific to this geography.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Building demolition with skid-steer loaders.</text>
        </comment>
      </technology>
      <timePeriod startDate="1994-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
