    <modellingAndValidation>
      <representativeness systemModelId="290c1f85-4cc4-4fa1-b0c8-2cb7f4276dce">
        <systemModelName xml:lang="en">Allocation, cut-off by classification</systemModelName>
        <samplingProcedure xml:lang="en">Transport distances were sourced from Jungbluth &amp; Meili (2018) Life cycle inventories of oil products distribution, table 8.1, which where based on estimated distances and modes of transport from the main countries of origin in 2016. The annual gross import (i.e., production volume of the activity) to Switzerland was taken from Swiss energy statistics for 2022 (BFE 2023. Schweizerische Gesamtenergiestatistik 2022, table 21. Available from: https://www.bfe.admin.ch/bfe/de/home/versorgung/statistik-und-geodaten/energiestatistiken/gesamtenergiestatistik.html/) </samplingProcedure>
      </representativeness>
