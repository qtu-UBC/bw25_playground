<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="64ed973d-9867-5ba3-9507-5e1a34141af1" activityNameId="b854d7eb-7edb-42f8-a411-52ca5dddd81c" parentActivityId="ee4838c8-c8a1-4484-bf3c-575cef237714" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">diesel, import from Europe</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts with the supply of the finished petroleum product from petroleum refinery operation in Europe without Switzerland.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity covers the transport requirements for import of the finished petroleum product to Switzerland. Only transport of the product to Switzerland is considered here, whereas losses and infrastructure requirements during the import activities are omitted. </includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the import of a refined petroleum product (diesel) from Europe (without Switzerland) into Switzerland. The quality of diesel imported is assumed to generally have a lower sulfur content ('diesel, low sulfur'). This dataset for 'diesel' should only be considered a proxy activity (withoug a real annual production volume) to enable the same share of import to be reflected in the supply of 'diesel'  for older activities in the database that are modelled with this diesel quality as an input. </text>
        </generalComment>
      </activity>
      <classification classificationId="0bef4135-5b56-4012-a812-b78c9a8218a9">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1920:Manufacture of refined petroleum products</classificationValue>
      </classification>
      <geography geographyId="131278d6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">CH</shortname>
        <comment>
          <text xml:lang="en" index="0">Switzerland</text>
        </comment>
      </geography>
      <technology technologyLevel="4"/>
      <timePeriod startDate="2000-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
