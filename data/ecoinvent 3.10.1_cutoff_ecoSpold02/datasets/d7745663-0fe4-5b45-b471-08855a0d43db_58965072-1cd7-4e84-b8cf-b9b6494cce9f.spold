      <elementaryExchange id="1b7f3c4f-3fae-5c98-923f-46e01ae65339" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" casNumber="000124-38-9" amount="0.123552613" isCalculatedAmount="true" mathematicalRelation="0.123552613*(IF(RP_para;para) + IF(RP_meta;meta) + IF(RP_ortho;ortho) )" elementaryExchangeId="f9749677-9c9f-4678-ab55-c607dfdc2cb9" formula="CO2">
        <name xml:lang="en">Carbon dioxide, fossil</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">Calculated losses, based on the boiling point of a chemical, to water or to air. In addition, unreacted chemicals are assumed to go to wastewater treatment, which has a conversion rate in biological treatment of 95% of carbon into carbon dioxide. The remaining 5% are released as emissions to water.</comment>
        <uncertainty>
          <lognormal meanValue="0.123552613" mu="-2.091088197438908" variance="0.0006" varianceWithPedigreeUncertainty="0.0046"/>
          <pedigreeMatrix reliability="2" completeness="3" temporalCorrelation="2" geographicalCorrelation="5" furtherTechnologyCorrelation="2"/>
          <comment xml:lang="en">Estimation</comment>
