      <elementaryExchange id="65fffd98-ba4e-5d64-9aae-c9ae96399c87" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" casNumber="007732-18-5" amount="0.0009654299999999999" isCalculatedAmount="true" mathematicalRelation="0.00096543*(IF(RP_para;para) + IF(RP_meta;meta) + IF(RP_ortho;ortho) )" elementaryExchangeId="8c75e7ab-8ab8-41e4-b394-c166ff5b050d" formula="H2O">
