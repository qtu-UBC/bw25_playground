<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="affb52c5-be8d-5401-bbeb-99b853130afc" activityNameId="6afcca48-1fd5-4861-aea4-e8899ae6108a" parentActivityId="2d638135-cb77-465d-aa7f-d16a2d735fce" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">pipeline construction, natural gas, low pressure distribution network</activityName>
        <includedActivitiesStart xml:lang="en"/>
        <includedActivitiesEnd xml:lang="en">This dataset describes the infrastructure needed for the Swiss low (&lt;0.1 bar) pressure distribution network.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">Pipeline infrastructure for gas distribution. Life time 40 years. Annual transport of about 110 PJ over 16'000 km including the house connecting pipelines; Geography: Data is based on Swiss data.</text>
          <text xml:lang="en" index="1">Material requirements of the pipeline system are round 3.3t/km steel, 6.1 t/km cast iron, 4.2t/km PE, 26.8 t/km gravel, 360t/km sandt. These values are calculated based on the material density, the thickness of the pipeline wall and the kilometers of the various pipeline types.</text>
        </generalComment>
      </activity>
      <classification classificationId="36cd4931-9fac-446f-97a6-c042ce523787">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">natural gas/fuels</classificationValue>
      </classification>
      <classification classificationId="252082de-7cec-4d38-a58f-2819f633c6b6">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">4220:Construction of utility projects</classificationValue>
      </classification>
      <geography geographyId="131278d6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">CH</shortname>
        <comment>
          <text xml:lang="en" index="0">Data is based on Swiss data.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">The length of the pipelines is based on statistics, whereas the thickness of the pipeline is estimated.</text>
        </comment>
      </technology>
      <timePeriod startDate="2012-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="false"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
