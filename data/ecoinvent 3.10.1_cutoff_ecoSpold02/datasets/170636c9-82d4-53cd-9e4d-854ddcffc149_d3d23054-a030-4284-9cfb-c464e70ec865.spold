<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="170636c9-82d4-53cd-9e4d-854ddcffc149" activityNameId="b04261d4-55a1-4b44-a327-b51c1ed5387f" parentActivityId="7eb2f266-8426-4ef6-be5d-ad98e8f49463" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">coke production</activityName>
        <includedActivitiesStart xml:lang="en">Activity starts with the reception of coal at plant-site.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the supply of 1 kg of coke, considering the by-product recovery, to global market. Transport is not included.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">The multioutput-process represents the supply of coke, producing coal gas, coal tar, sulfur and benzene as a byproduct.</text>
          <text xml:lang="en" index="1">This dataset was built as a weighted average of regional datasets of the same activityName.</text>
          <text xml:lang="en" index="2">This dataset was built as a weighted average of regional datasets of the same activityName.  Weights are based on production volumes.</text>
          <text xml:lang="en" index="3">CN, wet quenching: weight = 73.92 %</text>
          <text xml:lang="en" index="4">CN, dry quenching: weight = 22.08 %</text>
          <text xml:lang="en" index="5">US: weight = 2.277 %</text>
          <text xml:lang="en" index="6">DE: weight = 1.717 %</text>
          <text xml:lang="en" index="7">For more details please see the regional datasets</text>
        </generalComment>
      </activity>
      <classification classificationId="3aa0f2c5-1d26-4f98-8c2c-7406d4b7f2ae">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1910:Manufacture of coke oven products</classificationValue>
      </classification>
      <geography geographyId="7846b897-7c04-4f9f-b607-2b83fcd9a74c">
        <shortname xml:lang="en">RoW</shortname>
        <comment>
          <text xml:lang="en" index="0">This dataset is a weighted average built from the following geographies: CN (dry and wet quenching), US, DE.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">This dataset was built as a weighted average of regional datasets of the same activityName.  Weights are based on production volumes.</text>
          <text xml:lang="en" index="1">CN, wet quenching: weight = 73.92 %</text>
          <text xml:lang="en" index="2">CN, dry quenching: weight = 22.08 %</text>
          <text xml:lang="en" index="3">US: weight = 2.277 %</text>
          <text xml:lang="en" index="4">DE: weight = 1.717 %</text>
        </comment>
      </technology>
      <timePeriod startDate="1980-01-01" endDate="2024-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
