<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="7cb7e9cd-cc72-5aac-b765-c6725c3619c2" activityNameId="259bccb7-8822-44e7-8ca7-106235932ed6" parentActivityId="c9369455-4406-5540-b35e-af4f7ac88172" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">liquid manure spreading, by vacuum tanker</activityName>
        <synonym xml:lang="en">slurry spreading by vacuum tanker</synonym>
        <includedActivitiesStart xml:lang="en">The liquid manure loading and spreading activity starts from preliminary work at farm, like attaching the adequate machinery to the tractor</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with transfer back to farm and concluding work, like uncoupling the machine. The dataset includes mixing the slurry before pumping into tanker at farm; transfer to field; field spreading of 1 m3 of slurry, including field turning, idling and overlapping. The inventory takes into account the diesel fuel consumption and the amount of agricultural machinery and of the shed, which has to be attributed to the slurry loading and spreading. Also taken into consideration is the amount of emissions to the air from combustion and the emission to the soil from tyre abrasion during the work process. The amount of spread material is not taken into account, nor dust other than from combustion and noise.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the service of mixing and then pumping 1 m3 liquid slurry (1 t) from farm pit into tanker (average capacity 24.7 m3), and spreading the slurry onto field (low height nozzle spraying). Slurry production and any emission from slurry are not included.</text>
        </generalComment>
      </activity>
      <classification classificationId="bbe2eb06-fac9-48bb-9610-f402b9d3f2d0">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">0161:Support activities for crop production</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
        <comment>
          <text xml:lang="en" index="0">The inventory  is a copy of the geography of Quebec, Canada. Data quality indicators are adjusted accordingly.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Emissions by the newest models of tractors set into operation during the period from 1999 to 2001.</text>
        </comment>
      </technology>
      <timePeriod startDate="2021-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
