  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="324887ce-7c27-53d4-a2e4-65bcced072aa" activityNameId="b4581b7e-777b-43ea-beb7-f06cc78aa12d" parentActivityId="ddcfe505-6360-4ded-84b8-0f53093df229" inheritanceDepth="-1" type="1" energyValues="0">
        <activityName xml:lang="en">sodium aluminate production, powder</activityName>
        <synonym xml:lang="en">aluminium sodium oxide</synonym>
        <includedActivitiesStart xml:lang="en">Starts with the delivery of material and energy inputs on site.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the production of dried sodium aluminate. This datasets includes raw materials, energy uses, infrastructure and emissions (water produced by chemical reaction is assumed released to surface waters).</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This dataset represents the production of sodium aluminate from an ideal chemical reaction of  aluminium hydroxide with sodium hydroxide. This is a rough estimation created for the Tap water production dataset. Sodium aluminate is widely used in water treatment as a clarification agent, for pH adjustment and phosphorus removal.</text>
        </generalComment>
      </activity>
      <classification classificationId="28f738cc-bb73-48f8-b633-f83fb9bc5ddc">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2011:Manufacture of basic chemicals</classificationValue>
      </classification>
      <classification classificationId="d333c46f-d57f-4e12-9476-aff32bf29ad9">
        <classificationSystem xml:lang="en">EcoSpold01Categories</classificationSystem>
        <classificationValue xml:lang="en">chemicals/inorganics</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">Idealized reaction of aluminium hydroxide with sodium hydroxide: Al(OH)3 + NaOH =&gt; NaAlO2 + 2H2O   </text>
        </comment>
      </technology>
      <timePeriod startDate="2012-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
