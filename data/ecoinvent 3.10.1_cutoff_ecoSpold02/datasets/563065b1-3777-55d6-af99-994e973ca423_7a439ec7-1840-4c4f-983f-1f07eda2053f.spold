    <activityDescription>
      <activity specialActivityType="1" id="563065b1-3777-55d6-af99-994e973ca423" activityNameId="fa22da86-d3ff-49cf-aac2-6152586675c3" parentActivityId="00c29adc-aead-4c04-9b62-f52cc8015f23" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for cement, CEM II/A</activityName>
        <includedActivitiesStart xml:lang="en">The activity start with the product ready for transport at factory gate.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the product delivered to the consumer.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. Each market represents the consumption mix of a product in a given geography, connecting suppliers with consumers of the same product in the same geographical area. Markets group the producers and also the imports of the product (if relevant) within the same geographical area. They also account for transport to the consumer and for the losses during that process, when relevant.</text>
          <text xml:lang="en" index="1">This activity represent the market for 1kg of cement, alternative constituents 6-20%</text>
          <text xml:lang="en" index="2">In this market, expert judgement was used to develop product specific transport distance estimations.</text>
        </generalComment>
      </activity>
      <classification classificationId="36cd730c-4485-4fe9-8efe-8850f771796d">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2394:Manufacture of cement, lime and plaster</classificationValue>
      </classification>
      <geography geographyId="868a66d1-7428-4ba2-9125-253b07afc119">
        <shortname xml:lang="en">CA-QC</shortname>
      </geography>
