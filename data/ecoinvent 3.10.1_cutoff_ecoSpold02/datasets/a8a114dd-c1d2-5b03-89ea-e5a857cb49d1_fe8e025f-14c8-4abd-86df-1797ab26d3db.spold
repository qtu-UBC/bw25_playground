      <intermediateExchange id="a8871e17-a83f-569e-b2f4-e83880658539" unitId="de5b3c87-0e35-4fb0-9765-4f3ba34c99e5" amount="-3.031463198930755E-05" intermediateExchangeId="e8a51ec1-60cb-4ead-a948-ad1142c61918" activityLinkId="de95a419-d2dd-5849-9604-eed405a904e0" productionVolumeVariableName="PV_waste_water" productionVolumeMathematicalRelation="PV_RP*waste_water/RP">
        <name xml:lang="en">wastewater, average</name>
        <unitName xml:lang="en">m3</unitName>
        <comment xml:lang="en">This value is estimated based on the input of pure water to ensure the mass balance and the completeness of the dataset. Namely, an amount of 10.5 kg pure water input per kg H2 produced was reported by  Li, J. et al. (2022): "The carbon footprint and cost of coal-based hydrogen production with and without carbon capture and storage technology in China, Journal of Cleaner Production, 362, 132514", while 4.51 kg of steam were also cogenerated. Based on this, a total of 5.99 kg of water were assumed to be sent for treatment.</comment>
        <uncertainty>
          <lognormal meanValue="3.031463198930755E-05" mu="-10.40388005807199" variance="0.04" varianceWithPedigreeUncertainty="0.04520000000000001"/>
          <pedigreeMatrix reliability="2" completeness="4" temporalCorrelation="1" geographicalCorrelation="5" furtherTechnologyCorrelation="2"/>
        </uncertainty>
        <property propertyId="f2283db2-62e4-467f-b9ac-c4f45be563b4" amount="0.06729999999999985" isDefiningValue="false" isCalculatedAmount="false" unitId="487df68b-4994-4027-8fdc-a4dc298257b7">
