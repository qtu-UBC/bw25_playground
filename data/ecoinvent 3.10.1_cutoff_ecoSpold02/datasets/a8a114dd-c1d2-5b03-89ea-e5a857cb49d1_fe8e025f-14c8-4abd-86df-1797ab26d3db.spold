      <intermediateExchange id="1949fa6d-54ab-5afa-8df0-66342494c541" unitId="487df68b-4994-4027-8fdc-a4dc298257b7" amount="-0.001690492716697677" isCalculatedAmount="true" mathematicalRelation="172.1712/100.08* limestone_amount" intermediateExchangeId="27a9b2b8-30cd-45a6-bf1a-9c1f7afde003" activityLinkId="472aae01-a11f-53be-90da-4588d6117d2c" productionVolumeVariableName="PV_waste_gypsum" productionVolumeMathematicalRelation="PV_RP*waste_gypsum/RP">
        <name xml:lang="en">waste gypsum</name>
        <unitName xml:lang="en">kg</unitName>
        <comment xml:lang="en">This value is estimated based on the input of limestone (CaCO3) and the set of reaction given below. Besdies, Gypsum (CaSO4.2(H2O)) generated during the Flue Gas Desulfurization (FGD) stage of the hydrogen production plant. Namely, a mixture of limestone and water is used for the flue gas treatment, where the undesired SO2 content of the flue gas is converted to gypsum. At first, the limestone reacts with the SO2 in the flue gas to create insoluble calcium sulfite (CaSO3). Subsequently, the CaSO3 further reacts with oxygen to produce gypsum (CaSO4.2(H2O)).
CaCO3(s) + SO2(g) → CaSO3(s) + CO2(g)
CaSO3(s)+ ½O2(g) + 2H2O(l) → CaSO4·2(H2O)(s)</comment>
        <uncertainty>
          <lognormal meanValue="0.001690492716697677" mu="-6.382735244197293" variance="0.04" varianceWithPedigreeUncertainty="0.04520000000000001"/>
          <pedigreeMatrix reliability="2" completeness="4" temporalCorrelation="1" geographicalCorrelation="5" furtherTechnologyCorrelation="2"/>
        </uncertainty>
