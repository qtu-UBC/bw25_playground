  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="05152f29-c763-50ed-b089-fef95f6454da" activityNameId="feff7056-cc13-4980-9c32-ed2291b9bb62" parentActivityId="bdfc1288-68a5-4d9a-a893-e5706b786423" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">treatment of used industrial electronic device, mechanical treatment</activityName>
        <includedActivitiesStart xml:lang="en">The activity starts with the waste being available at the gate of the treatment facility. Collection and transportation of the waste to the treatment plant is not included.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This  activity ends when the used industrial electronic device has been dismantled mechanically.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">The process represents the treatment 'used industrial electronic device' by mechanical dismantling in various fractions.</text>
        </generalComment>
      </activity>
      <classification classificationId="db303709-3eac-4c8b-9ed9-7e4888240c50">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">3830:Materials recovery</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
        <comment>
          <text xml:lang="en" index="0">Modelling parameters are not specific to this geography.</text>
        </comment>
      </geography>
      <technology technologyLevel="3">
        <comment>
          <text xml:lang="en" index="0">4-step-procedure (shredder - separation - shredder - separation) as used currently</text>
        </comment>
      </technology>
      <timePeriod startDate="2005-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
