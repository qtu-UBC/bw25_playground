<?xml version='1.0' encoding='UTF-8'?>
<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="0" id="da340fde-6764-51a5-a959-3cc6eacb816c" activityNameId="00c011b4-1c99-5477-9000-dd6d7e7e015f" parentActivityId="f76cef95-eb06-5d7c-ad33-57630e16bc7f" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">container production, for collection of post-consumer waste plastic for recycling</activityName>
        <includedActivitiesStart xml:lang="en">Activity starts with the production of the container for the collection of post-consumer waste plastic packaging material intended for recycling.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the waste material generated by the container at the end of service. Neither losses during production, use and disposal nor infrastructure requirements have been included due to lack of data.</includedActivitiesEnd>
        <allocationComment>
          <text xml:lang="en" index="0">no allocation involved</text>
        </allocationComment>
        <generalComment>
          <text xml:lang="en" index="0">The functional unit of this activity is the production of a container, with the unit defined based on the typical material requirements for the collection of 1 kg of post-consumer waste plastic for recycling. The underlying data was obtained from PET Recycling Schweiz and this inventory represents the average material requirements over different types of single-way and reusable container types/systems. The inventory only represents a rough estmation of the manufacturing process.</text>
        </generalComment>
      </activity>
      <classification classificationId="14363e31-908b-4e16-a794-638f2affef72">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">2220:Manufacture of plastics products</classificationValue>
      </classification>
      <geography geographyId="13d387f6-7d7e-11de-9ae2-0019e336be3a">
        <shortname xml:lang="en">US</shortname>
      </geography>
      <technology technologyLevel="3"/>
      <timePeriod startDate="2010-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
