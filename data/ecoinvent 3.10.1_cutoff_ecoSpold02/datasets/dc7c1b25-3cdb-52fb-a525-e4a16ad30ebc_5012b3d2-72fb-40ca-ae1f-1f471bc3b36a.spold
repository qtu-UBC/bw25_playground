<ecoSpold xmlns="http://www.EcoInvent.org/EcoSpold02" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.EcoInvent.org/EcoSpold02 ../../schemas/datasets/EcoSpold02.xsd http://www.EcoInvent.org/UsedUserMasterData ../../schemas/datasets/EcoSpold02UserMasterData.xsd">
  <childActivityDataset>
    <activityDescription>
      <activity specialActivityType="1" id="dc7c1b25-3cdb-52fb-a525-e4a16ad30ebc" activityNameId="ea17ca1e-d6d5-4f40-9c81-dfbefad708a6" parentActivityId="372e3122-f5ee-44a6-88e5-a3dcc1482671" inheritanceDepth="-1" type="1">
        <activityName xml:lang="en">market for batch dyeing, fibre, cotton</activityName>
        <includedActivitiesStart xml:lang="en">This activity starts at the site that 'batch dyeing, fabric' is offered as service within the geography of this dataset.</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">This activity ends with the supply of 1 kg of 'batch dyeing, fibre' to the consumers of this product. Transport is not taken into account. No losses in service considered.</includedActivitiesEnd>
        <generalComment>
          <text xml:lang="en" index="0">This is a market activity. In the case of services or immobile infrastructures, markets are connecting suppliers and consumers at a global level. For specific connections at regional level, direct links between the local producing activities and the local consumers are preferred. Transport or losses are logically not relevant for this type of products.</text>
          <text xml:lang="en" index="1">This is the market for  'batch dyeing, fibre, cotton', in the Global geography.</text>
          <text xml:lang="en" index="2">This market contains no transport or losses, as they are irrelevant for the delivered product.</text>
          <text xml:lang="en" index="3">This is delivering the service of 'batch dyeing, fibre, cotton' and includes all necessary materials, energy, water, wastewater (produced within the process) and infrastructure in order to process 1 kg of fibre. Batch dyeing is a process that applies a uniform and desired colour on the material that is applied. A user should use this service alongside 1 kg of cotton fibre of their choice.</text>
        </generalComment>
      </activity>
      <classification classificationId="14181512-75f0-4c44-8bea-6245e2f21484">
        <classificationSystem xml:lang="en">ISIC rev.4 ecoinvent</classificationSystem>
        <classificationValue xml:lang="en">1313:Finishing of textiles</classificationValue>
      </classification>
      <geography geographyId="34dbbff8-88ce-11de-ad60-0019e336be3a">
        <shortname xml:lang="en">GLO</shortname>
      </geography>
      <technology/>
      <timePeriod startDate="2017-01-01" endDate="2023-12-31" isDataValidForEntirePeriod="true"/>
      <macroEconomicScenario macroEconomicScenarioId="d9f57f0a-a01f-42eb-a57b-8f18d6635801">
        <name xml:lang="en">Business-as-Usual</name>
      </macroEconomicScenario>
    </activityDescription>
