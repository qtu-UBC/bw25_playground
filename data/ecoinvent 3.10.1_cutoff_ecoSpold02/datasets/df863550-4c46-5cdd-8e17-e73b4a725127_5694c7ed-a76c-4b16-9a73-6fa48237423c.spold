        <includedActivitiesStart xml:lang="en">Activity starting with the input of sodium hydroxide</includedActivitiesStart>
        <includedActivitiesEnd xml:lang="en">The activity ends with the production sodium hydroxide for the generic market for neutralising agents.</includedActivitiesEnd>
